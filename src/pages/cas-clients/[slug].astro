---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import CtaBlock from '@components/CtaBlock.astro';
import { CASE_STUDIES } from '@lib/content-data';
import { caseStudySchema } from '@lib/schema';
import { SITE } from '@lib/site';

export function getStaticPaths() {
  return CASE_STUDIES.map((cs) => ({
    params: { slug: cs.slug },
    props: { cs },
  }));
}

const { cs } = Astro.props;
const url = `${SITE.url}/cas-clients/${cs.slug}`;

const breadcrumb = [
  { name: 'Cas clients', href: '/cas-clients' },
  { name: cs.client },
];

const schemas = [
  caseStudySchema({
    headline: cs.title,
    description: cs.metaDescription,
    url,
    image: `${SITE.url}/og-default.jpg`,
    datePublished: '2025-01-01',
    dateModified: '2026-05-03',
    client: cs.client,
    results: cs.results,
  }),
];
---

<PageLayout
  title={cs.title}
  description={cs.metaDescription}
  breadcrumb={breadcrumb}
  schemas={schemas}
  ogType="article"
>
  <Section spacing="lg">
    <Container size="default">
      <p class="text-(--text-small) text-(--color-bleu) font-semibold uppercase tracking-wider">
        Cas client · {cs.sector}
      </p>
      <h1 class="mt-4 text-(--text-h1) font-bold leading-(--leading-tight)">
        {cs.client} · {cs.headline}
      </h1>

      <dl class="mt-12 grid grid-cols-2 sm:grid-cols-3 gap-6 border-t border-(--color-gris-light) pt-8">
        {
          cs.results.map((r) => (
            <div>
              <dt class="text-(--text-small) text-(--color-gris) uppercase tracking-wider">
                {r.metric}
              </dt>
              <dd class="mt-2 text-(--text-h2) font-bold text-(--color-encre)">{r.value}</dd>
            </div>
          ))
        }
      </dl>
    </Container>
  </Section>

  <Section spacing="md">
    <Container size="default">
      <!-- TODO Théo : reprise du contenu existant Framer + restructuration éditoriale
           Sections : Le contexte · Le défi · Notre approche · Les résultats · Les learnings
           1500-2500 mots, citations client, chiffres en tableau HTML (pas image). -->
      <p class="text-(--text-body) text-(--color-gris)">
        Récit complet du cas en cours de rédaction.
      </p>
    </Container>
  </Section>

  <CtaBlock
    title="Vous voulez ce type de résultats ?"
    description="20 minutes en visio pour voir si votre cible est dans notre zone de jeu."
  />
</PageLayout>
