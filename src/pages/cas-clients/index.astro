---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import Card from '@components/ui/Card.astro';
import CtaBlock from '@components/CtaBlock.astro';
import { CASE_STUDIES } from '@lib/content-data';

const title = 'Cas clients Agence Simple';
const description =
  "Trois cas clients chiffrés : Happycolis (41 RDV/5 sem), Invent-App (151 RDV), Dunforce (14 % de réponse sur les bailleurs sociaux).";

const breadcrumb = [{ name: 'Cas clients' }];
---

<PageLayout title={title} description={description} breadcrumb={breadcrumb}>
  <Section spacing="lg">
    <Container size="default">
      <h1 class="text-(--text-h1) font-bold leading-(--leading-tight)">{title}</h1>
      <p class="mt-6 text-(--text-body) text-(--color-gris) max-w-2xl">{description}</p>
    </Container>
  </Section>

  <Section spacing="md">
    <Container size="wide">
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          CASE_STUDIES.map((cs) => (
            <li>
              <Card href={`/cas-clients/${cs.slug}`}>
                <p class="text-(--text-small) text-(--color-bleu) font-semibold uppercase tracking-wider">
                  {cs.sector}
                </p>
                <h2 class="mt-3 text-(--text-h3) font-semibold">{cs.client}</h2>
                <p class="mt-3 text-(--text-body) text-(--color-encre)">{cs.headline}</p>
                <span class="mt-4 inline-block text-(--text-small) text-(--color-bleu) underline-offset-4 hover:underline">
                  Lire le cas →
                </span>
              </Card>
            </li>
          ))
        }
      </ul>
    </Container>
  </Section>

  <CtaBlock
    title="Voir si on peut produire ce type de résultats pour vous"
    description="20 minutes en visio. On vous dit franchement si votre cible est compatible avec notre approche."
  />
</PageLayout>
