---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Container from '@components/ui/Container.astro';
import GlassButton from '@components/ui/GlassButton.astro';
import ArrowButton from '@components/ui/ArrowButton.astro';
import HighlightMarker from '@components/ui/HighlightMarker.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import VideoFacade from '@components/VideoFacade.astro';
import { videoObjectSchema } from '@lib/schema';

/**
 * Hub cas clients : charte v2 (hero encre + glows, corps creme arrondi).
 * Deux sections distinctes : les 3 cas ecrits chiffres (stat cards cliquables
 * vers les pages detail) et les 3 interviews video (VideoFacade + VideoObject).
 * Les videos (Komon, Daisy app, Les Epaulettes) sont des clients differents
 * des 3 cas ecrits, jamais melangees. Schemas : VideoObject x3 ; BreadcrumbList
 * via Breadcrumb.
 */

const metaTitle = 'Cas clients prospection B2B : chiffres vérifiés | Agence Simple';
const metaDescription =
  'Trois campagnes de prospection B2B réelles et chiffrées : 41 RDV en 5 semaines, 151 RDV sur 6 mois, 14 % de réponse. Chiffres validés par les clients.';

const breadcrumb = [{ name: 'Cas clients' }];

const cases = [
  {
    slug: 'happycolis',
    stat: '41',
    unit: 'RDV en 5 semaines',
    client: 'Happycolis',
    sector: 'Logistique e-commerce',
    body:
      "Une cible e-commerce D2C avec un vrai volume de commandes, un cold email travaillé sur les douleurs concrètes des marques, et un ciblage resserré. 41 rendez-vous qualifiés et 576 réponses en cinq semaines.",
  },
  {
    slug: 'invent-app',
    stat: '151',
    unit: 'RDV sur 6 mois',
    client: 'Invent-App',
    sector: 'Application événementielle',
    body:
      "Deux personas aux enjeux opposés, clubs d'affaires et agences événementielles, adressés en multicanal email et LinkedIn avec un copy distinct par cible. 151 rendez-vous et 7 % de taux de réponse.",
  },
  {
    slug: 'dunforce',
    stat: '14 %',
    unit: 'de taux de réponse',
    client: 'Dunforce',
    sector: 'Logiciel de recouvrement',
    body:
      "Une cible restreinte de bailleurs sociaux, plusieurs décideurs par organisation, des messages personnalisés par fonction. 14 % de réponse et 7 leads en phase de signature.",
  },
];

const videos = [
  {
    videoId: '-GaYHXJR-Hc',
    uploadDate: '2026-03-21T04:24:39-07:00',
    client: 'Komon',
    title: 'Interview Komon sur la collaboration avec Agence Simple',
    description:
      "Interview du client Komon sur la prospection B2B menée avec Agence Simple : ciblage, exécution et résultats.",
  },
  {
    videoId: 'fepN_sOkUAo',
    uploadDate: '2026-03-21T04:51:43-07:00',
    client: 'Daisy app',
    title: 'Interview Daisy app sur la collaboration avec Agence Simple',
    description:
      "Interview du client Daisy app sur la prospection B2B menée avec Agence Simple : ciblage, exécution et résultats.",
  },
  {
    videoId: 'h7vkCT5aDhY',
    uploadDate: '2026-03-20T10:28:25-07:00',
    client: 'Les Épaulettes',
    title: 'Interview Les Épaulettes sur la collaboration avec Agence Simple',
    description:
      "Interview du client Les Épaulettes sur la prospection B2B menée avec Agence Simple : ciblage, exécution et résultats.",
  },
];

const schemas = videos.map((v) =>
  videoObjectSchema({
    name: v.title,
    description: v.description,
    embedUrl: `https://www.youtube-nocookie.com/embed/${v.videoId}`,
    thumbnailUrl: `https://i.ytimg.com/vi/${v.videoId}/hqdefault.jpg`,
    uploadDate: v.uploadDate,
  })
);
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  schemas={schemas}
  bodyClass="!bg-[#0F1B3F]"
>
  <Header slot="header" variant="dark" />

  <div class="page bg-[#0F1B3F]">
    <!-- ============ HERO ENCRE + GLOWS ============ -->
    <section class="hero relative overflow-hidden pt-10 pb-20 sm:pb-24">
      <div aria-hidden="true" class="glow-bleu w-[30rem] h-[30rem] -top-24 -right-16 opacity-50"></div>
      <div aria-hidden="true" class="glow-violet w-[34rem] h-[34rem] top-64 -left-32 opacity-45"></div>
      <div aria-hidden="true" class="glow-orange w-[20rem] h-[20rem] top-10 left-1/3 opacity-30"></div>

      <Container size="default" class="relative z-10">
        <div class="hero__crumb">
          <Breadcrumb items={breadcrumb} />
        </div>

        <p class="eyebrow mt-10">Cas clients</p>
        <h1 class="hero__h1">
          Prospection B2B :
          <span class="accent-display">des campagnes réelles</span>,
          des chiffres
          <HighlightMarker>vérifiés</HighlightMarker>
        </h1>
        <p class="hero__lead">
          Pas de moyenne floue ni de promesse en « jusqu'à ». Chaque chiffre présenté ici a été validé
          par le client concerné avant publication. Trois campagnes, trois cibles très différentes, et
          le détail de ce qui a été mis en place pour y arriver.
        </p>
        <p class="hero__sub">
          En complément, trois fondateurs racontent en vidéo ce que la collaboration a changé pour eux.
          Ce sont des témoignages distincts des trois cas écrits, pas les mêmes entreprises.
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-4">
          <GlassButton href="#prendre-rendez-vous" size="lg" withArrow ariaLabel="Réserver un diagnostic gratuit">
            Réserver un diagnostic gratuit
          </GlassButton>
          <ArrowButton href="#cas" variant="ghost-dark" size="lg" withArrow={false}>
            Voir les cas chiffrés
          </ArrowButton>
        </div>
      </Container>
    </section>

    <!-- ============ CORPS CREME ============ -->
    <article class="body-creme">
      <Container size="default">
        <div class="prose-col">
          <h2 id="cas">Trois campagnes, trois résultats chiffrés</h2>
          <p>
            Chaque carte renvoie au récit complet du cas : le contexte, les défis rencontrés, le
            dispositif exact déployé, et pourquoi ça a fonctionné. Cliquez pour lire le détail.
          </p>
        </div>

        <div class="stats">
          {cases.map((c) => (
            <a class="stat-card stat-card--link" href={`/cas-clients/${c.slug}`}>
              <span class="stat-card__num">{c.stat}</span>
              <span class="stat-card__label">{c.unit}</span>
              <p class="stat-card__body">
                <strong>{c.client}</strong>, {c.sector}. {c.body}
              </p>
              <span class="stat-card__more">Lire le cas</span>
            </a>
          ))}
        </div>

        <div class="prose-col">
          <h2 id="videos">Ils en parlent en vidéo</h2>
          <p>
            Trois fondateurs reviennent sur leur collaboration avec notre équipe. Komon, Daisy app et
            Les Épaulettes ne sont pas les trois cas écrits ci-dessus : ce sont d'autres clients, qui
            ont accepté de témoigner à visage découvert.
          </p>
        </div>

        <div class="videos">
          {videos.map((v) => (
            <VideoFacade videoId={v.videoId} title={v.title} client={v.client} />
          ))}
        </div>

        <div class="prose-col">
          <p>
            Envie de comprendre comment ces résultats se produisent avant de nous parler ? Tout est
            décrit dans <a href="/">notre offre de prospection B2B clé en main</a>, et chaque page
            service détaille la méthode en 4 étapes appliquée à son canal.
          </p>
        </div>
      </Container>
    </article>

    <!-- ============ CTA FINAL : BANDE ENCRE + GLOWS ============ -->
    <section id="prendre-rendez-vous" class="final relative overflow-hidden py-20 sm:py-28">
      <div aria-hidden="true" class="glow-bleu w-[28rem] h-[28rem] -top-20 left-1/4 opacity-45"></div>
      <div aria-hidden="true" class="glow-orange w-[22rem] h-[22rem] bottom-0 right-10 opacity-35"></div>

      <Container size="narrow" class="relative z-10 text-center">
        <h2 class="final__h2">Voir si on peut produire ce type de résultats pour vous</h2>
        <p class="final__p">
          Le premier rendez-vous est un diagnostic gratuit de 30 minutes avec l'équipe. On regarde votre
          cible, votre panier moyen et votre stade, et on vous dit franchement si votre marché est
          compatible avec notre approche. Si la réponse est non, vous repartez avec les raisons.
        </p>
        <div class="mt-10 flex justify-center">
          <GlassButton href="/contact" size="lg" withArrow ariaLabel="Réserver un diagnostic gratuit">
            Réserver un diagnostic gratuit
          </GlassButton>
        </div>
      </Container>
    </section>
  </div>

  <!-- CTA sticky mobile -->
  <div class="sticky-cta">
    <a href="#prendre-rendez-vous">Réserver un diagnostic gratuit</a>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ============ HERO (dark) ============ */
  .hero__crumb :global(nav) {
    color: rgba(250, 247, 242, 0.55);
  }
  .hero__crumb :global(a) {
    color: rgba(250, 247, 242, 0.7);
  }
  .hero__crumb :global(a:hover) {
    color: var(--color-bleu);
  }
  .eyebrow {
    font-size: var(--text-eyebrow);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-orange);
  }
  .hero__h1 {
    margin-top: 1.25rem;
    max-width: 54rem;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: var(--color-creme);
  }
  .accent-display {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    color: var(--color-bleu);
  }
  .hero__lead {
    margin-top: 1.75rem;
    max-width: 46rem;
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: rgba(250, 247, 242, 0.85);
  }
  .hero__sub {
    margin-top: 1.25rem;
    max-width: 46rem;
    font-size: var(--text-body);
    line-height: var(--leading-relaxed);
    color: rgba(250, 247, 242, 0.6);
  }

  /* ============ CORPS CREME ============ */
  .body-creme {
    position: relative;
    z-index: 5;
    background: var(--color-creme);
    border-radius: 32px 32px 0 0;
    padding: 4.5rem 0 5rem;
  }
  @media (min-width: 768px) {
    .body-creme {
      padding: 6rem 0 7rem;
    }
  }

  .prose-col {
    max-width: 46rem;
  }
  .prose-col :global(p) {
    margin-top: 1.25rem;
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: rgba(15, 27, 63, 0.82);
  }
  .prose-col :global(h2) {
    margin-top: 4rem;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-h2);
    line-height: var(--leading-title);
    letter-spacing: -0.02em;
    color: var(--color-encre);
    scroll-margin-top: 5.5rem;
  }
  .prose-col :global(h2:first-child) {
    margin-top: 0;
  }
  .body-creme :global(a) {
    color: var(--color-bleu);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(30, 144, 255, 0.35);
    transition: text-decoration-color 200ms ease;
  }
  .body-creme :global(a:hover) {
    text-decoration-color: var(--color-bleu);
  }

  /* Stat cards résultats (cliquables) */
  .stats {
    margin-top: 2.5rem;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 900px) {
    .stats {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .stat-card {
    background: #ffffff;
    border: 1px solid rgba(15, 27, 63, 0.06);
    border-radius: 22px;
    padding: 1.9rem 1.6rem 1.7rem;
    box-shadow: 0 4px 16px rgba(15, 27, 63, 0.04);
    display: flex;
    flex-direction: column;
    transition: transform 250ms ease, box-shadow 250ms ease;
  }
  .stat-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 40px -15px rgba(15, 27, 63, 0.18);
  }
  .stat-card--link {
    text-decoration: none !important;
  }
  .stat-card__num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: clamp(2.6rem, 4vw, 3.4rem);
    line-height: 1;
    color: var(--color-bleu);
  }
  .stat-card__label {
    margin-top: 0.4rem;
    font-size: var(--text-caption);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-orange);
  }
  .stat-card__body {
    margin-top: 1rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(15, 27, 63, 0.72);
  }
  .stat-card__more {
    margin-top: 1.1rem;
    font-size: var(--text-caption);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-bleu);
  }
  .stat-card--link:hover .stat-card__more {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Grille vidéos */
  .videos {
    margin-top: 2.5rem;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .videos {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ============ CTA FINAL (dark) ============ */
  .final {
    scroll-margin-top: 4rem;
  }
  .final__h2 {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.9rem, 3.5vw, 2.8rem);
    letter-spacing: -0.02em;
    color: var(--color-creme);
  }
  .final__p {
    margin-top: 1.5rem;
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: rgba(250, 247, 242, 0.82);
  }

  /* Sticky mobile CTA */
  .sticky-cta {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 40;
    padding: 0.75rem 1rem calc(0.75rem + env(safe-area-inset-bottom));
    background: rgba(15, 27, 63, 0.9);
    backdrop-filter: blur(8px);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .sticky-cta a {
    display: block;
    text-align: center;
    padding: 0.85rem 1rem;
    border-radius: 9999px;
    background: var(--color-bleu);
    color: #ffffff;
    font-weight: 600;
    text-decoration: none;
  }
  @media (min-width: 768px) {
    .sticky-cta {
      display: none;
    }
  }
</style>
