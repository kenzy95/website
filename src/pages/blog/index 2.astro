---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Container from '@components/ui/Container.astro';
import GlassButton from '@components/ui/GlassButton.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

/**
 * Index blog charte v2 : hero encre + glows, corps creme arrondi,
 * filtres par cocon (chips, JS vanilla) et cards avec cover editoriale.
 */

const title = 'Blog prospection B2B : cold email et LinkedIn';
const description =
  "Cold email, LinkedIn, ciblage, délivrabilité : les méthodes que notre équipe applique réellement pour ses clients, documentées article par article.";

const breadcrumb = [{ name: 'Blog' }];

const articles = await getCollection('blog', ({ data }) => !data.draft);
articles.sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

/* Cocons : bucket -> label + couleur accent (aligne sur les covers) */
const COCONS: Record<string, { label: string; color: string }> = {
  A: { label: 'Cold email', color: '#1E90FF' },
  B: { label: 'Prospection', color: '#F47B3F' },
  C: { label: 'LinkedIn', color: '#764cdc' },
};

const readingTime = (body: string) => Math.max(2, Math.ceil(body.split(/\s+/).length / 220));

const fmtDate = (d: Date) =>
  new Date(d).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description} bodyClass="!bg-[#0F1B3F]">
  <Header slot="header" variant="dark" />

  <div class="bg-[#0F1B3F]">
    <!-- ============ HERO ENCRE ============ -->
    <section class="relative overflow-hidden pt-10 pb-16 sm:pb-20">
      <div aria-hidden="true" class="glow-bleu w-[28rem] h-[28rem] -top-20 -right-12 opacity-45"></div>
      <div aria-hidden="true" class="glow-violet w-[30rem] h-[30rem] top-40 -left-32 opacity-40"></div>

      <Container size="default" class="relative z-10">
        <div class="hero__crumb">
          <Breadcrumb items={breadcrumb} />
        </div>

        <p class="eyebrow mt-10">Blog</p>
        <h1 class="hero__h1">
          La prospection B2B,
          <span class="accent-display">documentée sur le terrain</span>.
        </h1>
        <p class="hero__lead">
          Cold email, LinkedIn, ciblage, délivrabilité : les méthodes que notre équipe applique
          réellement pour ses clients. Pas de théorie recyclée, des process testés en campagne.
        </p>
      </Container>
    </section>

    <!-- ============ CORPS CREME ============ -->
    <section class="body-creme">
      <Container size="wide">
        <!-- Filtres cocons -->
        <div class="filters" role="group" aria-label="Filtrer les articles par thème">
          <button class="filter-chip is-active" data-filter="all">Tous les articles</button>
          {Object.entries(COCONS).map(([key, c]) => (
            <button class="filter-chip" data-filter={key} style={`--chip-accent: ${c.color}`}>
              <span class="filter-chip__dot" aria-hidden="true"></span>
              {c.label}
            </button>
          ))}
        </div>

        <!-- Grille articles -->
        <ul class="articles-grid">
          {articles.map((article) => {
            const cocon = COCONS[article.data.bucket ?? 'A'];
            return (
              <li class="article-card-slot" data-bucket={article.data.bucket ?? 'A'}>
                <a href={`/blog/${article.slug}`} class="article-card">
                  <div class="article-card__media">
                    <img
                      src={article.data.cover}
                      alt={article.data.coverAlt}
                      loading="lazy"
                      width="1200"
                      height="630"
                    />
                  </div>
                  <div class="article-card__body">
                    <span class="article-card__tag" style={`--tag-accent: ${cocon.color}`}>
                      <span class="article-card__tag-dot" aria-hidden="true"></span>
                      {cocon.label}
                    </span>
                    <h2 class="article-card__title">{article.data.title}</h2>
                    <p class="article-card__desc">{article.data.description}</p>
                    <p class="article-card__meta">
                      {fmtDate(article.data.publishedAt)} · {readingTime(article.body)} min de lecture
                    </p>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      </Container>
    </section>

    <!-- ============ CTA FINAL ============ -->
    <section class="relative overflow-hidden py-16 sm:py-20">
      <div aria-hidden="true" class="glow-bleu w-[24rem] h-[24rem] -top-10 left-1/3 opacity-40"></div>
      <Container size="narrow" class="relative z-10 text-center">
        <h2 class="final__h2">Vous préférez que ce soit nous qui appliquions tout ça ?</h2>
        <p class="final__p">
          Ces méthodes sont celles que nous opérons chaque semaine pour nos clients.
          Le premier échange est un diagnostic gratuit de votre cible.
        </p>
        <div class="mt-8 flex justify-center">
          <GlassButton href="/contact" size="lg" withArrow ariaLabel="Prendre rendez-vous">
            Prendre RDV
          </GlassButton>
        </div>
      </Container>
    </section>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<script is:inline>
  (function () {
    function init() {
      var chips = document.querySelectorAll('.filter-chip');
      var cards = document.querySelectorAll('.article-card-slot');
      chips.forEach(function (chip) {
        chip.addEventListener('click', function () {
          chips.forEach(function (c) { c.classList.remove('is-active'); });
          chip.classList.add('is-active');
          var f = chip.getAttribute('data-filter');
          cards.forEach(function (card) {
            card.style.display = f === 'all' || card.getAttribute('data-bucket') === f ? '' : 'none';
          });
        });
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style>
  /* ============ HERO ============ */
  .hero__crumb :global(nav) { color: rgba(250, 247, 242, 0.55); }
  .hero__crumb :global(a) { color: rgba(250, 247, 242, 0.7); }
  .hero__crumb :global(a:hover) { color: var(--color-bleu); }

  .eyebrow {
    font-size: var(--text-eyebrow);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-orange);
  }
  .hero__h1 {
    margin-top: 1.25rem;
    max-width: 50rem;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: var(--color-creme);
  }
  .accent-display {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    color: var(--color-bleu);
  }
  .hero__lead {
    margin-top: 1.5rem;
    max-width: 44rem;
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: rgba(250, 247, 242, 0.8);
  }

  /* ============ CORPS CREME ============ */
  .body-creme {
    position: relative;
    z-index: 5;
    background: var(--color-creme);
    border-radius: 32px 32px 0 0;
    padding: 3.5rem 0 4.5rem;
  }
  @media (min-width: 768px) {
    .body-creme { padding: 4.5rem 0 5.5rem; }
  }

  /* Filtres */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2.5rem;
  }
  .filter-chip {
    --chip-accent: var(--color-encre);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1.1rem;
    border-radius: 9999px;
    border: 1px solid rgba(15, 27, 63, 0.14);
    background: #ffffff;
    color: var(--color-encre);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 180ms ease;
  }
  .filter-chip:hover {
    border-color: rgba(15, 27, 63, 0.35);
    transform: translateY(-1px);
  }
  .filter-chip.is-active {
    background: var(--color-encre);
    border-color: var(--color-encre);
    color: var(--color-creme);
  }
  .filter-chip__dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--chip-accent);
  }

  /* Grille */
  .articles-grid {
    display: grid;
    gap: 1.75rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .articles-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .articles-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .article-card-slot { list-style: none; }

  .article-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #ffffff;
    border: 1px solid rgba(15, 27, 63, 0.06);
    border-radius: 22px;
    overflow: hidden;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(15, 27, 63, 0.05);
    transition: transform 250ms ease, box-shadow 250ms ease;
  }
  .article-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 44px -16px rgba(15, 27, 63, 0.22);
  }
  .article-card__media {
    aspect-ratio: 1200 / 630;
    overflow: hidden;
    background: var(--color-encre);
  }
  .article-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease;
  }
  .article-card:hover .article-card__media img {
    transform: scale(1.03);
  }
  .article-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.4rem 1.4rem 1.3rem;
  }
  .article-card__tag {
    --tag-accent: var(--color-bleu);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    align-self: flex-start;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-encre);
    opacity: 0.85;
  }
  .article-card__tag-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--tag-accent);
  }
  .article-card__title {
    margin-top: 0.75rem;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.15rem;
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--color-encre);
    transition: color 200ms ease;
  }
  .article-card:hover .article-card__title {
    color: var(--color-bleu);
  }
  .article-card__desc {
    margin-top: 0.6rem;
    font-size: 0.9rem;
    line-height: 1.55;
    color: rgba(15, 27, 63, 0.65);
  }
  .article-card__meta {
    margin-top: auto;
    padding-top: 1rem;
    font-size: 0.8rem;
    color: rgba(15, 27, 63, 0.5);
  }

  /* ============ CTA FINAL ============ */
  .final__h2 {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    letter-spacing: -0.02em;
    color: var(--color-creme);
  }
  .final__p {
    margin-top: 1.25rem;
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: rgba(250, 247, 242, 0.75);
  }
</style>
