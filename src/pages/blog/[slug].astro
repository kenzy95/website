---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import CtaBlock from '@components/CtaBlock.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { articleSchema } from '@lib/schema';
import { SITE } from '@lib/site';

export async function getStaticPaths() {
  const articles = await getCollection('blog', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

interface Props {
  article: CollectionEntry<'blog'>;
}

const { article } = Astro.props;
const { Content } = await article.render();

const url = `${SITE.url}/blog/${article.slug}`;

const breadcrumb = [
  { name: 'Blog', href: '/blog' },
  { name: article.data.title },
];

const schemas = [
  articleSchema({
    headline: article.data.title,
    description: article.data.description,
    url,
    image: `${SITE.url}${article.data.cover}`,
    datePublished: article.data.publishedAt.toISOString(),
    dateModified: (article.data.updatedAt ?? article.data.publishedAt).toISOString(),
    authorName: article.data.author,
  }),
];
---

<PageLayout
  title={article.data.title}
  description={article.data.description}
  breadcrumb={breadcrumb}
  schemas={schemas}
  ogType="article"
  publishedAt={article.data.publishedAt.toISOString()}
  modifiedAt={(article.data.updatedAt ?? article.data.publishedAt).toISOString()}
>
  <Section spacing="lg">
    <Container size="narrow">
      <p class="text-(--text-small) text-(--color-bleu) font-semibold uppercase tracking-wider">
        Article · {article.data.author}
      </p>
      <h1 class="mt-4 text-(--text-h1) font-bold leading-(--leading-tight)">
        {article.data.title}
      </h1>
      <p class="mt-4 text-(--text-small) text-(--color-gris)">
        Publié le{' '}
        {new Date(article.data.publishedAt).toLocaleDateString('fr-FR', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
        {' '}· {Math.max(2, Math.ceil(article.body.split(/\s+/).length / 220))} min de lecture
      </p>

      <!-- Cover editoriale -->
      <div class="article-cover mt-10">
        <img
          src={article.data.cover}
          alt={article.data.coverAlt}
          width="1200"
          height="630"
          fetchpriority="high"
        />
      </div>
    </Container>
  </Section>

  <Section spacing="md">
    <Container size="narrow" class="prose-content">
      <Content />
    </Container>
  </Section>

  <CtaBlock title="Vous voulez en parler ?" description="20 minutes en visio. On vous dit franchement si on peut vous aider." />
</PageLayout>

<style is:global>
  .article-cover {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 18px 44px -18px rgba(15, 27, 63, 0.35);
  }
  .article-cover img {
    display: block;
    width: 100%;
    height: auto;
  }
  .prose-content {
    font-size: var(--text-body);
    line-height: var(--leading-loose);
    color: var(--color-encre);
  }
  .prose-content h2 {
    font-size: var(--text-h2);
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: var(--leading-tight);
  }
  .prose-content h3 {
    font-size: var(--text-h3);
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-content p {
    margin-bottom: 1.25rem;
  }
  .prose-content a {
    color: var(--color-bleu);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .prose-content ul,
  .prose-content ol {
    margin-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .prose-content li {
    margin-bottom: 0.5rem;
  }
  .prose-content blockquote {
    border-left: 3px solid var(--color-bleu);
    padding-left: 1.5rem;
    font-style: italic;
    color: var(--color-gris);
    margin: 1.5rem 0;
  }
  .prose-content code {
    background: var(--color-gris-light);
    padding: 0.15em 0.35em;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
  }
</style>
