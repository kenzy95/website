---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import CtaBlock from '@components/CtaBlock.astro';
import { getCollection } from 'astro:content';

const title = 'Blog Agence Simple';
const description =
  "Articles concrets sur la prospection B2B : cold email, LinkedIn outreach, SDR, ROI, méthodes de ciblage. Pas de bullshit, on partage ce qu'on fait vraiment.";

const breadcrumb = [{ name: 'Blog' }];

const articles = await getCollection('blog', ({ data }) => !data.draft);
articles.sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());
---

<PageLayout title={title} description={description} breadcrumb={breadcrumb}>
  <Section spacing="lg">
    <Container size="default">
      <h1 class="text-(--text-h1) font-bold leading-(--leading-tight)">{title}</h1>
      <p class="mt-6 text-(--text-body) text-(--color-gris) max-w-2xl">{description}</p>
    </Container>
  </Section>

  <Section spacing="md">
    <Container size="wide">
      {
        articles.length === 0 ? (
          <p class="text-(--text-body) text-(--color-gris)">
            Premiers articles à venir.
          </p>
        ) : (
          <ul class="grid gap-8 sm:grid-cols-2">
            {articles.map((article) => (
              <li>
                <a href={`/blog/${article.slug}`} class="group block">
                  <h2 class="text-(--text-h3) font-semibold group-hover:text-(--color-bleu) transition-colors">
                    {article.data.title}
                  </h2>
                  <p class="mt-3 text-(--text-body) text-(--color-gris)">
                    {article.data.description}
                  </p>
                  <p class="mt-3 text-(--text-small) text-(--color-gris)">
                    {new Date(article.data.publishedAt).toLocaleDateString('fr-FR', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </p>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </Container>
  </Section>

  <CtaBlock title="Vous avez un sujet en tête ?" description="On écrit aussi sur demande, si le sujet sert nos lecteurs." />
</PageLayout>
