---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import CtaBlock from '@components/CtaBlock.astro';
import { TOOLS } from '@lib/content-data';

export function getStaticPaths() {
  return TOOLS.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;

const breadcrumb = [
  { name: 'Outils', href: '/outils' },
  { name: tool.name },
];
---

<PageLayout title={tool.title} description={tool.metaDescription} breadcrumb={breadcrumb}>
  <Section spacing="lg">
    <Container size="default">
      <p class="text-(--text-small) text-(--color-bleu) font-semibold uppercase tracking-wider">
        Outil gratuit
      </p>
      <h1 class="mt-4 text-(--text-h1) font-bold leading-(--leading-tight)">{tool.title}</h1>
      <p class="mt-6 text-(--text-body) text-(--color-gris) max-w-2xl">{tool.description}</p>
    </Container>
  </Section>

  <Section spacing="md">
    <Container size="default">
      <!-- TODO : implémenter le calculateur en Astro Island (React) ou en JS vanilla.
           Inputs : variables métier (salaire SDR, charges, outils, taux de conversion, etc.).
           Output : graphique simple + tableau récap + CTA "Discuter de mes chiffres".
           Schema HowTo possible si on documente la méthode de calcul. -->
      <div class="rounded-(--radius-lg) bg-(--color-bleu-soft) p-8 text-center">
        <p class="text-(--text-body) text-(--color-gris)">
          Calculateur interactif en cours d'intégration.
        </p>
      </div>
    </Container>
  </Section>

  <CtaBlock title="Aller plus loin que le calculateur" description="20 minutes en visio pour discuter de vos chiffres réels." />
</PageLayout>
