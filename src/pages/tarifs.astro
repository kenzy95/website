---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import CtaBlock from '@components/CtaBlock.astro';

/* Règle Kenzy 2026-07-04 : aucun prix affiché. Le devis se construit après échange. */
const title = 'Tarifs Agence Simple';
const description =
  "Forfait mensuel transparent, sans engagement. Pas de mark-up sur les outils, garantie minimum vital incluse. Devis précis après un premier échange.";

const breadcrumb = [{ name: 'Tarifs' }];
---

<PageLayout title={title} description={description} breadcrumb={breadcrumb}>
  <Section spacing="lg">
    <Container size="default">
      <h1 class="text-(--text-h1) font-bold leading-(--leading-tight)">{title}</h1>
      <p class="mt-6 text-(--text-body) text-(--color-gris) max-w-2xl">{description}</p>
    </Container>
  </Section>

  <Section spacing="md">
    <Container size="default">
      <!-- TODO Théo : page tarifs SANS montant (règle Kenzy 2026-07-04)
           Structure du forfait : ce qui est inclus (sourcing, copy, envoi, qualification, reporting)
           Outils facturés au coût réel sans mark-up
           Garantie minimum vital expliquée (engagement chiffré de RDV, prolongation gratuite)
           Les 2 variables qui font le devis : volume cible + complexité de la cible
           FAQ tarifs (5 questions) -> schema FAQPage
           Lien comparatif SDR interne vs agence. -->
      <p class="text-(--text-body) text-(--color-gris)">Détails tarifaires en cours de rédaction.</p>
    </Container>
  </Section>

  <CtaBlock title="Devis personnalisé en 20 minutes" description="Le tarif final dépend du volume cible et du secteur. Échangeons." />
</PageLayout>
