---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import CtaBlock from '@components/CtaBlock.astro';

const title = 'Tarifs Agence Simple';
const description =
  "Forfait mensuel transparent à partir de 2 000 € HT. Pas de mark-up sur les outils, pas d'engagement long, garantie minimum vital incluse.";

const breadcrumb = [{ name: 'Tarifs' }];
---

<PageLayout title={title} description={description} breadcrumb={breadcrumb}>
  <Section spacing="lg">
    <Container size="default">
      <h1 class="text-(--text-h1) font-bold leading-(--leading-tight)">{title}</h1>
      <p class="mt-6 text-(--text-body) text-(--color-gris) max-w-2xl">{description}</p>
    </Container>
  </Section>

  <Section spacing="md">
    <Container size="default">
      <!-- TODO Théo : grille tarifaire claire
           Forfait standard : à partir de 2000 € HT/mois
           Inclus : sourcing, copy, envoi, qualification, reporting hebdo, accès Slack
           Non inclus : outils (Lemlist, Aimfox, etc. facturés au coût réel sans mark-up)
           Garantie minimum vital expliquée chiffrée
           FAQ tarifs (5 questions) -> schema FAQPage
           Tableau comparatif vs SDR interne sur la page comparatif (lien). -->
      <p class="text-(--text-body) text-(--color-gris)">Détails tarifaires en cours de rédaction.</p>
    </Container>
  </Section>

  <CtaBlock title="Devis personnalisé en 20 minutes" description="Le tarif final dépend du volume cible et du secteur. Échangeons." />
</PageLayout>
