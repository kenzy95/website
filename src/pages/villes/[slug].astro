---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Container from '@components/ui/Container.astro';
import GlassButton from '@components/ui/GlassButton.astro';
import ArrowButton from '@components/ui/ArrowButton.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import { CITIES } from '@lib/content-data';
import { CITIES_CONTENT } from '@lib/cities-content';
import { serviceSchema, faqSchema, breadcrumbSchema } from '@lib/schema';
import { SITE } from '@lib/site';

/**
 * Template unique des pages villes. Le contenu long-form vient de cities-content.ts,
 * la meta/keyword de content-data.ts. La CSS vit une seule fois ici et sert les 5 pages.
 * Honnêteté géographique : Agence Simple opère pour des clients partout en France, siège
 * unique à Paris (229 rue Saint-Honoré). La ville est une ZONE D'INTERVENTION, pas une
 * fausse agence locale. Le schema Service ne porte qu'une adresse (Paris) et un areaServed
 * ciblé sur la ville (type City), jamais de fausse adresse locale.
 * getStaticPaths filtre sur les villes qui ont un contenu, pour rester vert commit par commit.
 * Schemas : Service (areaServed City) + FAQPage + BreadcrumbList.
 */

export function getStaticPaths() {
  return CITIES.filter((c) => CITIES_CONTENT[c.slug]).map((city) => ({
    params: { slug: city.slug },
    props: { city, content: CITIES_CONTENT[city.slug] },
  }));
}

const { city, content } = Astro.props;
const url = `${SITE.url}/villes/${city.slug}`;

const breadcrumb = [
  { name: 'Villes', href: '/villes' },
  { name: city.name },
];

const schemas = [
  {
    ...serviceSchema({
      name: city.title,
      description: city.description,
      url,
      serviceType: content.serviceType,
    }),
    areaServed: { '@type': 'City', name: city.name },
  },
  faqSchema(content.faq.map((f) => ({ question: f.question, answer: f.answer }))),
  breadcrumbSchema([
    { name: 'Accueil', url: `${SITE.url}/` },
    { name: 'Villes', url: `${SITE.url}/villes` },
    { name: city.name, url },
  ]),
];
---

<BaseLayout
  title={`${city.title} | Agence Simple`}
  description={city.metaDescription}
  schemas={schemas}
  bodyClass="!bg-[#0F1B3F]"
>
  <Header slot="header" variant="dark" />

  <div class="page bg-[#0F1B3F]">
    <!-- HERO ENCRE COMPACT -->
    <section class="hero relative overflow-hidden pt-10 pb-20 sm:pb-24">
      <div aria-hidden="true" class="glow-bleu w-[30rem] h-[30rem] -top-24 -right-16 opacity-50"></div>
      <div aria-hidden="true" class="glow-violet w-[34rem] h-[34rem] top-64 -left-32 opacity-45"></div>

      <Container size="default" class="relative z-10">
        <div class="hero__crumb">
          <Breadcrumb items={breadcrumb} />
        </div>

        <p class="eyebrow mt-10">Zone d'intervention · {city.name}</p>
        <h1 class="hero__h1">{city.title}</h1>
        <p class="hero__lead">{content.heroLead}</p>
        <p class="hero__sub">{content.heroSub}</p>

        <div class="mt-9 flex flex-wrap items-center gap-4">
          <GlassButton href="#prendre-rendez-vous" size="lg" withArrow ariaLabel="Réserver un diagnostic gratuit">
            Réserver un diagnostic gratuit
          </GlassButton>
          <ArrowButton href="#cibles" variant="ghost-dark" size="lg" withArrow={false}>
            Les cibles atteignables
          </ArrowButton>
        </div>
      </Container>
    </section>

    <!-- CORPS CREME -->
    <article class="body-creme">
      <Container size="default">
        <div class="prose-col">
          <h2 id="pourquoi">Prospecter en B2B sur {city.name}</h2>
          {content.intro.map((p) => <p>{p}</p>)}

          <h2 id="cibles">Les cibles B2B atteignables localement</h2>
          <p>
            Le tissu économique local dessine des poches de comptes que nous savons cibler et joindre.
            Voici les profils que nous adressons le plus souvent sur ce territoire, et la façon dont
            nous les traitons.
          </p>
        </div>

        <div class="steps">
          {content.cibles.map((c, i) => (
            <div class="step-card">
              <div class="step-card__head">
                <span class="step-card__num">0{i + 1}</span>
              </div>
              <h3 class="step-card__title">{c.titre}</h3>
              <p class="step-card__body">{c.texte}</p>
            </div>
          ))}
        </div>

        <div class="prose-col">
          <h2 id="distance">Comment nous travaillons pour un client {city.name}</h2>
          {content.distance.map((p) => <p>{p}</p>)}

          <h2 id="cas-client">Un résultat concret, quelle que soit la géographie</h2>
          <p>{content.casClient.texte}</p>
        </div>

        <div class="panel panel--inclus">
          <p class="panel__intro">Pour aller plus loin</p>
          <ul class="feature-list">
            <li>
              Le format complet, cold email et LinkedIn orchestrés avec garantie de rendez-vous, est
              décrit dans <a href="/">notre offre d'agence de prospection B2B</a>.
            </li>
            <li>
              Le service le plus adapté à ce type de client : <a href={content.maillage.service.href}>{content.maillage.service.label}</a>.
            </li>
            <li>
              Un cas client comparable : <a href={content.maillage.caseStudy.href}>{content.maillage.caseStudy.label}</a>.
            </li>
            <li>
              Pour creuser la méthode : <a href={content.maillage.article.href}>{content.maillage.article.label}</a>.
            </li>
          </ul>
        </div>

        <div class="prose-col">
          <h2 id="faq">Questions fréquentes sur la prospection à {city.name}</h2>
          <ul class="faq">
            {content.faq.map((item) => (
              <li class="faq__item">
                <details>
                  <summary>
                    <span class="faq__q">{item.question}</span>
                    <span class="faq__toggle" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <line x1="2" y1="7" x2="12" y2="7" />
                        <line x1="7" y1="2" x2="7" y2="12" class="faq__toggle-v" />
                      </svg>
                    </span>
                  </summary>
                  <p class="faq__a">{item.answer}</p>
                </details>
              </li>
            ))}
          </ul>
        </div>
      </Container>
    </article>

    <!-- CTA FINAL ENCRE -->
    <section id="prendre-rendez-vous" class="final relative overflow-hidden py-20 sm:py-28">
      <div aria-hidden="true" class="glow-bleu w-[28rem] h-[28rem] -top-20 left-1/4 opacity-45"></div>
      <div aria-hidden="true" class="glow-orange w-[22rem] h-[22rem] bottom-0 right-10 opacity-35"></div>

      <Container size="narrow" class="relative z-10 text-center">
        <h2 class="final__h2">Parlons de votre prospection à {city.name}</h2>
        <p class="final__p">
          Le premier rendez-vous est un diagnostic gratuit de 30 minutes avec Kenzy. On regarde votre
          cible, votre panier moyen et votre stade, et on vous dit franchement si la prospection sortante
          est le bon levier pour vous. Sur {city.name}, on peut aussi se voir en présentiel quand cela a
          du sens. Si c'est oui, vous repartez avec une proposition et un engagement chiffré de rendez-vous.
        </p>
        <div class="mt-10 flex justify-center">
          <GlassButton href="/contact" size="lg" withArrow ariaLabel="Réserver un diagnostic gratuit">
            Réserver un diagnostic gratuit
          </GlassButton>
        </div>
      </Container>
    </section>
  </div>

  <div class="sticky-cta">
    <a href="#prendre-rendez-vous">Réserver un diagnostic gratuit</a>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .hero__crumb :global(nav) {
    color: rgba(250, 247, 242, 0.55);
  }
  .hero__crumb :global(a) {
    color: rgba(250, 247, 242, 0.7);
  }
  .hero__crumb :global(a:hover) {
    color: var(--color-bleu);
  }
  .eyebrow {
    font-size: var(--text-eyebrow);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-orange);
  }
  .hero__h1 {
    margin-top: 1.25rem;
    max-width: 54rem;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: var(--color-creme);
  }
  .hero__lead {
    margin-top: 1.75rem;
    max-width: 46rem;
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: rgba(250, 247, 242, 0.85);
  }
  .hero__sub {
    margin-top: 1.25rem;
    max-width: 46rem;
    font-size: var(--text-body);
    line-height: var(--leading-relaxed);
    color: rgba(250, 247, 242, 0.6);
  }

  .body-creme {
    position: relative;
    z-index: 5;
    background: var(--color-creme);
    border-radius: 32px 32px 0 0;
    padding: 4.5rem 0 5rem;
  }
  @media (min-width: 768px) {
    .body-creme {
      padding: 6rem 0 7rem;
    }
  }

  .prose-col {
    max-width: 46rem;
  }
  .prose-col :global(p) {
    margin-top: 1.25rem;
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: rgba(15, 27, 63, 0.82);
  }
  .prose-col :global(h2) {
    margin-top: 4rem;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-h2);
    line-height: var(--leading-title);
    letter-spacing: -0.02em;
    color: var(--color-encre);
    scroll-margin-top: 5.5rem;
  }
  .prose-col :global(h2:first-child) {
    margin-top: 0;
  }
  .body-creme :global(a) {
    color: var(--color-bleu);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(30, 144, 255, 0.35);
    transition: text-decoration-color 200ms ease;
  }
  .body-creme :global(a:hover) {
    text-decoration-color: var(--color-bleu);
  }

  .steps {
    margin-top: 2.5rem;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .steps {
      grid-template-columns: 1fr 1fr;
    }
  }
  .step-card {
    background: #ffffff;
    border: 1px solid rgba(15, 27, 63, 0.06);
    border-radius: 22px;
    padding: 1.75rem 1.6rem 1.6rem;
    box-shadow: 0 4px 16px rgba(15, 27, 63, 0.04);
    transition: transform 250ms ease, box-shadow 250ms ease;
  }
  .step-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 40px -15px rgba(15, 27, 63, 0.18);
  }
  .step-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .step-card__num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: 1.9rem;
    color: var(--color-bleu);
    line-height: 1;
  }
  .step-card__title {
    margin-top: 1rem;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.1rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-encre);
  }
  .step-card__body {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(15, 27, 63, 0.72);
  }

  .panel {
    margin-top: 3rem;
    max-width: 52rem;
    border-radius: 24px;
    padding: 2rem 2rem 1.9rem;
  }
  .panel--inclus {
    background: #ffffff;
    border: 1px solid rgba(15, 27, 63, 0.06);
    box-shadow: 0 4px 20px rgba(15, 27, 63, 0.05);
  }
  .panel__intro {
    font-size: var(--text-eyebrow);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-orange);
    margin-bottom: 1.25rem;
  }

  .feature-list {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .feature-list li {
    position: relative;
    padding-left: 1.9rem;
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: rgba(15, 27, 63, 0.82);
  }
  .feature-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    top: 0.05em;
    font-weight: 700;
    color: var(--color-bleu);
  }

  .faq {
    margin-top: 1.5rem;
    border-top: 1px solid rgba(15, 27, 63, 0.1);
  }
  .faq__item {
    border-bottom: 1px solid rgba(15, 27, 63, 0.1);
    list-style: none;
  }
  .faq__item details {
    width: 100%;
  }
  .faq__item summary {
    list-style: none;
    cursor: pointer;
    padding: 1.5rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    color: var(--color-encre);
    transition: color 200ms ease;
  }
  .faq__item summary::-webkit-details-marker {
    display: none;
  }
  .faq__item summary:hover {
    color: var(--color-bleu);
  }
  .faq__q {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.4;
  }
  .faq__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: rgba(15, 27, 63, 0.05);
    border: 1px solid rgba(15, 27, 63, 0.12);
    color: var(--color-encre);
    flex-shrink: 0;
    transition: all 200ms ease;
  }
  .faq__item details[open] .faq__toggle {
    background: var(--color-bleu);
    border-color: var(--color-bleu);
    color: #ffffff;
  }
  .faq__item details[open] .faq__toggle-v {
    display: none;
  }
  .faq__a {
    padding: 0 0 1.75rem 0 !important;
    margin-top: 0 !important;
    color: rgba(15, 27, 63, 0.7) !important;
    font-size: 1rem !important;
    line-height: 1.65 !important;
    max-width: 56rem;
  }

  .final {
    scroll-margin-top: 4rem;
  }
  .final__h2 {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.9rem, 3.5vw, 2.8rem);
    letter-spacing: -0.02em;
    color: var(--color-creme);
  }
  .final__p {
    margin-top: 1.5rem;
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: rgba(250, 247, 242, 0.82);
  }

  .sticky-cta {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 40;
    padding: 0.75rem 1rem calc(0.75rem + env(safe-area-inset-bottom));
    background: rgba(15, 27, 63, 0.9);
    backdrop-filter: blur(8px);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .sticky-cta a {
    display: block;
    text-align: center;
    padding: 0.85rem 1rem;
    border-radius: 9999px;
    background: var(--color-bleu);
    color: #ffffff;
    font-weight: 600;
    text-decoration: none;
  }
  @media (min-width: 768px) {
    .sticky-cta {
      display: none;
    }
  }
</style>
