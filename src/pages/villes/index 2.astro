---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import Card from '@components/ui/Card.astro';
import CtaBlock from '@components/CtaBlock.astro';
import { CITIES } from '@lib/content-data';

const title = "Agence prospection B2B en France";
const description =
  "Basée à Paris, Agence Simple opère la prospection B2B de ses clients partout en France : Paris, Lyon, Bordeaux, Lille, Marseille et toutes les régions.";

const breadcrumb = [{ name: 'Villes' }];
---

<PageLayout title={title} description={description} breadcrumb={breadcrumb}>
  <Section spacing="lg">
    <Container size="default">
      <h1 class="text-(length:--text-h1) font-bold leading-(--leading-tight)">{title}</h1>
      <p class="mt-6 text-(length:--text-body) text-(--color-gris) max-w-2xl">{description}</p>
    </Container>
  </Section>

  <Section spacing="md">
    <Container size="wide">
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          CITIES.map((city) => (
            <li>
              <Card href={`/villes/${city.slug}`}>
                <h2 class="text-(length:--text-h3) font-semibold">{city.name}</h2>
                <p class="mt-3 text-(length:--text-body) text-(--color-gris)">{city.description}</p>
                <span class="mt-4 inline-block text-(length:--text-small) text-(--color-bleu) underline-offset-4 hover:underline">
                  Page locale →
                </span>
              </Card>
            </li>
          ))
        }
      </ul>
    </Container>
  </Section>

  <CtaBlock title="Vous n'êtes pas dans une de ces villes ?" description="On intervient partout en France à distance, et présentiel ponctuel sur demande." />
</PageLayout>
