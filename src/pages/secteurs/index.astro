---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import Card from '@components/ui/Card.astro';
import CtaBlock from '@components/CtaBlock.astro';
import { SECTORS } from '@lib/content-data';

const title = 'Nos secteurs de spécialisation';
const description =
  "Approche prospection adaptée à votre secteur : SaaS, ESN, cabinet conseil, scale-up post-levée, agences. Pain points spécifiques, ICP par segment.";

const breadcrumb = [{ name: 'Secteurs' }];
---

<PageLayout title={title} description={description} breadcrumb={breadcrumb}>
  <Section spacing="lg">
    <Container size="default">
      <h1 class="text-(--text-h1) font-bold leading-(--leading-tight)">{title}</h1>
      <p class="mt-6 text-(--text-body) text-(--color-gris) max-w-2xl">{description}</p>
    </Container>
  </Section>

  <Section spacing="md">
    <Container size="wide">
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          SECTORS.map((sector) => (
            <li>
              <Card href={`/secteurs/${sector.slug}`}>
                <h2 class="text-(--text-h3) font-semibold">{sector.shortName}</h2>
                <p class="mt-3 text-(--text-body) text-(--color-gris)">{sector.description}</p>
                <span class="mt-4 inline-block text-(--text-small) text-(--color-bleu) underline-offset-4 hover:underline">
                  Voir la page secteur →
                </span>
              </Card>
            </li>
          ))
        }
      </ul>
    </Container>
  </Section>

  <CtaBlock
    title="Votre secteur n'est pas listé ?"
    description="On a probablement déjà prospecté pour des entreprises similaires. Échangeons 20 minutes."
  />
</PageLayout>
