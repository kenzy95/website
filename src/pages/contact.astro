---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import { contactPointSchema } from '@lib/schema';
import { SITE } from '@lib/site';

const title = 'Contact Agence Simple';
const description =
  "20 minutes en visio pour clarifier votre besoin. Pas de discours commercial, on regarde si on peut vous aider et on vous le dit franchement.";

const breadcrumb = [{ name: 'Contact' }];
const schemas = [contactPointSchema()];
---

<PageLayout title={title} description={description} breadcrumb={breadcrumb} schemas={schemas}>
  <Section spacing="lg">
    <Container size="default">
      <h1 class="text-(--text-h1) font-bold leading-(--leading-tight)">{title}</h1>
      <p class="mt-6 text-(--text-body) text-(--color-gris) max-w-2xl">{description}</p>
    </Container>
  </Section>

  <Section spacing="md">
    <Container size="default">
      <div class="grid gap-12 md:grid-cols-2">
        <div>
          <h2 class="text-(--text-h3) font-semibold">Réserver un créneau</h2>
          <p class="mt-3 text-(--text-body) text-(--color-gris)">
            20 minutes en visio. Cadrage du besoin et avis honnête sur ce qu'on peut faire pour vous.
          </p>
          <!-- Calendly inline : charge en lazy quand le bloc devient visible (perf mobile) -->
          <div
            id="calendly-embed"
            data-url="https://calendly.com/agencesimple?hide_gdpr_banner=1&primary_color=1e90ff"
            class="mt-6 rounded-(--radius-lg) overflow-hidden border border-(--color-encre)/10 bg-white"
            style="min-height: 660px;"
          >
            <noscript>
              <a href="https://calendly.com/agencesimple" rel="noopener noreferrer" target="_blank">
                Réserver un créneau sur Calendly
              </a>
            </noscript>
          </div>
        </div>

        <div>
          <h2 class="text-(--text-h3) font-semibold">Coordonnées directes</h2>
          <ul class="mt-4 space-y-3 text-(--text-body)">
            <li>
              <span class="text-(--color-gris)">Email :</span>{' '}
              <a href={`mailto:${SITE.contact.email}`} class="text-(--color-bleu) underline-offset-4 hover:underline">
                {SITE.contact.email}
              </a>
            </li>
            <li>
              <span class="text-(--color-gris)">Téléphone :</span>{' '}
              <a href={`tel:${SITE.contact.phone.replace(/\s+/g, '')}`} class="text-(--color-bleu) underline-offset-4 hover:underline">
                {SITE.contact.phone}
              </a>
            </li>
            <li>
              <span class="text-(--color-gris)">LinkedIn :</span>{' '}
              <a
                href={SITE.social.linkedinFounder}
                rel="noopener noreferrer"
                target="_blank"
                class="text-(--color-bleu) underline-offset-4 hover:underline"
              >
                Kenzy Gasmi
              </a>
            </li>
          </ul>

          <address class="not-italic mt-8 text-(--text-body) text-(--color-gris)">
            {SITE.contact.address.street}<br />
            {SITE.contact.address.postalCode} {SITE.contact.address.city}<br />
            France
          </address>
        </div>
      </div>
    </Container>
  </Section>
</PageLayout>

<script is:inline>
  /* Charge le widget Calendly uniquement quand le bloc entre dans le viewport. */
  (function () {
    var el = document.getElementById('calendly-embed');
    if (!el) return;
    var loaded = false;
    function load() {
      if (loaded) return;
      loaded = true;
      var s = document.createElement('script');
      s.src = 'https://assets.calendly.com/assets/external/widget.js';
      s.async = true;
      s.onload = function () {
        if (window.Calendly) {
          window.Calendly.initInlineWidget({ url: el.getAttribute('data-url'), parentElement: el });
        }
      };
      document.head.appendChild(s);
    }
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { load(); io.disconnect(); }
        });
      }, { rootMargin: '200px' });
      io.observe(el);
    } else {
      load();
    }
  })();
</script>
