---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import { SITE } from '@lib/site';

const title = 'Mentions légales';
const description = 'Mentions légales et informations sur l\'éditeur du site Agence Simple.';
const breadcrumb = [{ name: 'Mentions légales' }];
---

<PageLayout title={title} description={description} breadcrumb={breadcrumb} noindex>
  <Section spacing="lg">
    <Container size="narrow">
      <h1 class="text-(--text-h1) font-bold leading-(--leading-tight)">{title}</h1>

      <div class="mt-12 space-y-8 text-(--text-body) text-(--color-encre)">
        <section>
          <h2 class="text-(--text-h3) font-semibold">Éditeur du site</h2>
          <p class="mt-3 text-(--color-gris)">
            {SITE.legalName}<br />
            {SITE.contact.address.street}<br />
            {SITE.contact.address.postalCode} {SITE.contact.address.city}<br />
            France<br />
            SIRET : {SITE.legal.siret}<br />
            Email : <a href={`mailto:${SITE.contact.email}`} class="text-(--color-bleu) underline-offset-4 hover:underline">{SITE.contact.email}</a><br />
            Directeur de la publication : {SITE.founder.name}
          </p>
        </section>

        <section>
          <h2 class="text-(--text-h3) font-semibold">Hébergeur</h2>
          <p class="mt-3 text-(--color-gris)">
            Cloudflare, Inc.<br />
            101 Townsend Street, San Francisco, CA 94107, USA
          </p>
        </section>

        <section>
          <h2 class="text-(--text-h3) font-semibold">Propriété intellectuelle</h2>
          <p class="mt-3 text-(--color-gris)">
            L'ensemble du contenu du site (textes, graphismes, logos, images) est la propriété de {SITE.legalName} ou de ses partenaires.
            Toute reproduction sans autorisation est interdite.
          </p>
        </section>

        <section>
          <h2 class="text-(--text-h3) font-semibold">Contact</h2>
          <p class="mt-3 text-(--color-gris)">
            Pour toute question : <a href={`mailto:${SITE.contact.email}`} class="text-(--color-bleu) underline-offset-4 hover:underline">{SITE.contact.email}</a>
          </p>
        </section>
      </div>
    </Container>
  </Section>
</PageLayout>
