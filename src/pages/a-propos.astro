---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import CtaBlock from '@components/CtaBlock.astro';
import { SITE } from '@lib/site';

const title = `À propos de ${SITE.name}`;
const description =
  "Agence Simple, agence de prospection B2B fondée par Kenzy Gasmi. Mission : générer des rendez-vous qualifiés pour des dirigeants lassés des agences qui survendent.";

const breadcrumb = [{ name: 'À propos' }];
---

<PageLayout title={title} description={description} breadcrumb={breadcrumb}>
  <Section spacing="lg">
    <Container size="default">
      <h1 class="text-(--text-h1) font-bold leading-(--leading-tight)">{title}</h1>
      <p class="mt-6 text-(--text-body) text-(--color-gris) max-w-2xl">{description}</p>
    </Container>
  </Section>

  <Section spacing="md">
    <Container size="narrow">
      <!-- TODO Théo : narratif fondateur Kenzy
           Pourquoi Agence Simple existe, pourquoi le modèle "garantie minimum vital",
           qui sont les freelances/équipe, quels clients, pourquoi le ton "premier degré".
           Schema Person + Organization déjà actifs. -->
      <p class="text-(--text-body) text-(--color-gris)">Page À propos en cours de rédaction.</p>
    </Container>
  </Section>

  <CtaBlock title="Faire connaissance en 20 minutes" />
</PageLayout>
