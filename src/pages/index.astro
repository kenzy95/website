---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import ArrowButton from '@components/ui/ArrowButton.astro';
import GlassButton from '@components/ui/GlassButton.astro';
import HighlightMarker from '@components/ui/HighlightMarker.astro';
import { LampContainer } from '@components/ui/Lamp';
import LogoMarquee from '@components/LogoMarquee.astro';
import PartnerWilco from '@components/PartnerWilco.astro';
import GuaranteeCards from '@components/GuaranteeCards.astro';
import LeadGenSection from '@components/LeadGenSection.astro';
import ContainerScroll from '@components/animations/ContainerScroll.astro';
import WhatWeDo from '@components/animations/WhatWeDo.astro';
import ScrollExpansionHero from '@components/animations/ScrollExpansionHero.astro';
import StoryScroll from '@components/animations/StoryScroll.astro';
import StorySection from '@components/animations/StorySection.astro';
import MailboxDashboard from '@components/MailboxDashboard.astro';
import ServiceTakeover from '@components/ServiceTakeover.astro';
import ProcessSteps from '@components/ProcessSteps.astro';
import RoiCalculator from '@components/RoiCalculator.astro';
import ClientInterviews from '@components/ClientInterviews.astro';
import ToolsConstellation from '@components/ToolsConstellation.astro';
import FaqSection from '@components/FaqSection.astro';
import FinalCta from '@components/FinalCta.astro';
import { localBusinessSchema, faqSchema } from '@lib/schema';

/**
 * Home Agence Simple v3 - reprise dynamique Framer + charte v2.
 * Architecture funnel commercial inspiree du site actuel :
 * Hero -> ContainerScroll dashboard mail -> Logos clients (marquee)
 * Suite (PR 2-4) : cards garanties, 4 piliers, What We Do, calculateur, processus, valeurs, interviews, FAQ.
 */

const title = 'Agence prospection B2B Paris - rendez-vous garantis';
const description =
  "Agence Simple génère des rendez-vous B2B qualifiés. Forfait 2 000 € par mois, sans engagement. Si on ne tient pas le minimum sur 3 mois, on continue gratuitement.";

const faq = [
  { question: 'Comment vous calculez le minimum vital ?', answer: 'On regarde votre taux de conversion en clientèle et combien de clients il vous faut pour rentabiliser. On en déduit ensemble un seuil chiffré.' },
  { question: 'Et si je n\'atteins pas le minimum ?', answer: 'On continue gratuitement jusqu\'à l\'atteindre. Pas de petites lignes, pas de remboursement compliqué.' },
];

const schemas = [localBusinessSchema(), faqSchema(faq)];
---

<BaseLayout
  title={title}
  description={description}
  schemas={schemas}
  bodyClass="!bg-[#0F1B3F]"
>
  <Header slot="header" variant="dark" />

  <main class="bg-[#0F1B3F] text-[#FAF7F2] min-h-screen">
    <!-- ============ HERO (Aceternity Lamp Effect, charte bleu) ============ -->
    <section class="relative overflow-hidden">
      <LampContainer client:load>
        <h1
          class="mt-8 py-4 leading-(--leading-tight) tracking-tight max-w-5xl mx-auto text-center"
          style="font-family: var(--font-sans); font-weight: 700; font-size: var(--text-h1-hero); color: var(--color-creme);"
        >
          Payez
          <HighlightMarker>seulement</HighlightMarker>
          quand vous avez<br />
          un
          <span style="font-family: var(--font-display); font-style: italic; font-weight: 600; color: var(--color-bleu);">RDV qualifié</span>.
        </h1>
      </LampContainer>

      <!-- Paragraphe + CTAs : overlap le bas de la lamp (negative margin), pb 0 pour rapprocher dashboard au max -->
      <div class="relative z-10 -mt-64 sm:-mt-72 pb-0 text-center px-5" style="background-color: var(--color-encre);">
        <p class="text-(--color-creme)/75 max-w-2xl mx-auto text-(--text-body-lg) leading-(--leading-relaxed)">
          Une équipe complète de prospection qui prend tout en charge. On vous livre des rendez-vous qualifiés. Vous décidez s'ils sont bons.
        </p>

        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <GlassButton href="/contact" size="lg" withArrow ariaLabel="Prendre rendez-vous">
            Prendre RDV
          </GlassButton>
          <ArrowButton href="#comment-ca-marche" variant="ghost-dark" size="lg" withArrow={false}>
            En savoir plus
          </ArrowButton>
        </div>
      </div>
    </section>

    <!-- ============ CONTAINER SCROLL : DASHBOARD MAIL (gap modere avec CTAs) ============ -->
    <section class="relative flex flex-col overflow-hidden -mt-2">
      <ContainerScroll>
        <MailboxDashboard />
      </ContainerScroll>
    </section>

    <!-- ============ PARTENAIRE WILCO (avant LogoMarquee comme sur agencesimple.fr Framer) ============ -->
    <PartnerWilco />

    <!-- ============ LOGOS CLIENTS (MARQUEE) ============ -->
    <LogoMarquee />

    <!-- ============ 2 CARDS BICOLORES GARANTIES ============ -->
    <GuaranteeCards />

    <!-- ============ SECTION "RDV QUALIFIES" + 2 CARDS INFRA/OPTIM ============ -->
    <LeadGenSection />

    <!-- ============ CE QU'ON FAIT (split text + sphere) ============ -->
    <WhatWeDo />

    <!-- ============ SCROLL EXPANSION HERO : gestion complète prospection ============ -->
    <ScrollExpansionHero
      mediaSrc="/images/mockup-macbook.jpg"
      mediaType="image"
      bgImageSrc="/images/workshop-postits.jpg"
      title="Gestion complète"
      date="De A à Z"
      scrollToExpand="Faites défiler pour découvrir"
    >
      <div class="max-w-3xl mx-auto text-center text-(--color-creme)">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
          Ce qu'on prend en charge
        </p>
        <h3
          class="mt-5 leading-(--leading-title)"
          style="font-family: var(--font-display); font-style: italic; font-weight: 600; font-size: clamp(1.75rem, 3vw, 2.5rem);"
        >
          De la stratégie à la prise de RDV, tout sauf la vente.
        </h3>
        <p class="mt-6 text-(--color-creme)/75 text-(--text-body-lg) leading-(--leading-relaxed)">
          Stratégie, sourcing, infrastructure email, outils, copywriting, pilotage hebdo.
          Vous récupérez les rendez-vous qualifiés directement dans votre agenda.
        </p>
      </div>
    </ScrollExpansionHero>

    <!-- ============ CE QU'ON PREND EN CHARGE (5 cards) ============ -->
    <ServiceTakeover />

    <!-- ============ PROCESSUS (4 etapes + sticky visuel) ============ -->
    <ProcessSteps />

    <!-- ============ STORY SCROLL placeholder (a remplir par Kenzy plus tard) ============ -->
    <StoryScroll ariaLabel="Story scroll Agence Simple">
      {/* Layout identique au pattern source GSAP : eyebrow + hr + titre enorme + body + hr */}
      <StorySection bg="creme" ariaLabel="Story 1">
        <div class="mx-auto max-w-4xl text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
            Histoire — 01
          </p>
          <h2
            class="mt-5 leading-(--leading-tight)"
            style="font-family: var(--font-display); font-style: italic; font-weight: 600; font-size: clamp(2.5rem, 6vw, 4.5rem); color: var(--color-encre);"
          >
            Première page du<br />story scroll.
          </h2>
          <p class="mt-6 text-(--color-encre)/65 text-(--text-body-lg) max-w-2xl mx-auto">
            Placeholder — à remplir avec ton contenu (chiffres clés, anecdote client, manifeste illustré...).
          </p>
        </div>
      </StorySection>

      <StorySection bg="encre" ariaLabel="Story 2">
        <div class="mx-auto max-w-4xl text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
            Histoire — 02
          </p>
          <h2
            class="mt-5 leading-(--leading-tight)"
            style="font-family: var(--font-display); font-style: italic; font-weight: 600; font-size: clamp(2.5rem, 6vw, 4.5rem); color: var(--color-creme);"
          >
            Deuxième page<br />du deck.
          </h2>
          <p class="mt-6 text-(--color-creme)/65 text-(--text-body-lg) max-w-2xl mx-auto">
            La section s'empile sur la précédente avec une rotation depuis 30 degrés.
          </p>
        </div>
      </StorySection>

      <StorySection bg="orange-soft" ariaLabel="Story 3">
        <div class="mx-auto max-w-4xl text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-encre)">
            Histoire — 03
          </p>
          <h2
            class="mt-5 leading-(--leading-tight)"
            style="font-family: var(--font-display); font-style: italic; font-weight: 600; font-size: clamp(2.5rem, 6vw, 4.5rem); color: var(--color-encre);"
          >
            Troisième et dernière<br />page.
          </h2>
          <p class="mt-6 text-(--color-encre)/65 text-(--text-body-lg) max-w-2xl mx-auto">
            Le scroll continue normalement après. Tu peux ajouter autant de sections que tu veux.
          </p>
        </div>
      </StorySection>
    </StoryScroll>

    <!-- ============ CALCULATEUR ROI COLD EMAIL ============ -->
    <RoiCalculator />

    <!-- ============ CONSTELLATION OUTILS ============ -->
    <ToolsConstellation />

    <!-- ============ INTERVIEWS CLIENTS ============ -->
    <ClientInterviews />

    <!-- ============ FAQ ============ -->
    <FaqSection />

    <!-- ============ CTA FINAL ============ -->
    <FinalCta />
  </main>

  <Footer slot="footer" />
</BaseLayout>
