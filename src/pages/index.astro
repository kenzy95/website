---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import Card from '@components/ui/Card.astro';
import Button from '@components/ui/Button.astro';
import Highlight from '@components/ui/Highlight.astro';
import MockupMail from '@components/MockupMail.astro';
import { localBusinessSchema, faqSchema } from '@lib/schema';
import { CASE_STUDIES } from '@lib/content-data';

/**
 * Home Agence Simple v2 - architecture funnel commercial charte v2.
 * 11 sections : Hero - 4 piliers - Logos - Manifeste - Comment ça se passe - Preuves - Qui est derriere - Tarif - FAQ - CTA - Footer.
 */

const title = 'Agence prospection B2B Paris - rendez-vous garantis';
const description =
  "Agence Simple génère des rendez-vous B2B garantis. Forfait à partir de 2 000 € par mois, sans engagement. Si on ne tient pas le minimum sur 3 mois, on continue gratuitement.";

const faq = [
  {
    question: "Comment vous calculez le minimum vital de RDV ?",
    answer:
      "On regarde votre taux de conversion en clientèle (combien de RDV se transforment en signature chez vous) et combien de clients il vous faut pour rentabiliser notre forfait. On en déduit ensemble un seuil chiffré. C'est conservateur, on préfère sous-promettre et sur-livrer.",
  },
  {
    question: "Et si je n'atteins pas le minimum vital ?",
    answer:
      "On continue gratuitement jusqu'à l'atteindre. Pas de petites lignes. Pas de remboursement compliqué à demander. On reste, on bosse, on livre.",
  },
  {
    question: "Pourquoi sans engagement si vous garantissez ?",
    answer:
      "Parce que la garantie protège votre risque, pas notre cash flow. Si Simple ne vous est plus utile, vous devez pouvoir partir. C'est cohérent.",
  },
  {
    question: "Qu'est-ce qui rend un rendez-vous qualifié ?",
    answer:
      "Vous. Pas nous. Après chaque RDV, vous nous dites qualifié ou pas qualifié. Pas de critère imposé. Pas de débat. Vous corrigez le tir, on suit.",
  },
  {
    question: "C'est qui mon interlocuteur ?",
    answer:
      "Moi, Kenzy. Pas de chargé de compte. Pas d'équipe junior. Vous parlez à la personne qui pilote vos campagnes.",
  },
  {
    question: "Quels volumes ?",
    answer:
      "On envoie entre 300 et 400 messages par jour, ajustables si votre marché est plus petit. Sur 3 mois, ça fait entre 18 000 et 24 000 décideurs touchés. Largement de quoi atteindre le minimum vital.",
  },
];

const schemas = [localBusinessSchema(), faqSchema(faq)];

const piliers = [
  {
    num: '01',
    title: 'Vos résultats, garantis.',
    body: "On ne tient pas le minimum sur 3 mois ? On continue gratuitement jusqu'à le tenir.",
    master: true,
  },
  {
    num: '02',
    title: 'Vos premiers RDV en 15 jours.',
    body: 'Vous signez aujourd\'hui, votre première campagne tourne dans deux semaines.',
  },
  {
    num: '03',
    title: "Pas besoin d'embaucher.",
    body: 'On gère votre prospection de A à Z. Vous gardez votre énergie pour vendre.',
  },
  {
    num: '04',
    title: 'Vous partez quand vous voulez.',
    body: "Si Simple ne vous est plus utile, vous partez. Pas de durée, pas de pénalité.",
  },
];

const etapes = [
  {
    num: '01',
    title: 'On calcule votre minimum vital',
    body: 'Avec vous. Pas en théorie. Avec votre vrai taux de conversion et votre vraie cible client.',
  },
  {
    num: '02',
    title: 'On installe l\'infrastructure',
    body: 'Boîtes secondaires dédiées, warmup, outils. On protège votre domaine principal.',
  },
  {
    num: '03',
    title: 'On lance dans 15 jours',
    body: 'Pas besoin de recruter. Pas d\'engagement. Pas de slides chaque lundi.',
  },
  {
    num: '04',
    title: 'Vous validez les rendez-vous',
    body: 'On livre. Vous décidez s\'ils sont bons. Si on ne tient pas le minimum à 3 mois, on continue gratuitement.',
  },
];

const clients = ['Trimble', 'Yannod', 'John Tuchson Partners', 'Solunea', 'Wedoit', 'Happycolis', 'Invent-App', 'Dunforce'];
---

<PageLayout title={title} description={description} schemas={schemas} showBreadcrumb={false}>
  <!-- 1. HERO -->
  <Section spacing="xl" class="relative overflow-hidden">
    <!-- Cercle decoratif chaleur (charte v2) -->
    <div
      aria-hidden="true"
      class="absolute -top-32 -right-32 w-[28rem] h-[28rem] rounded-full bg-(--color-orange-soft) opacity-60 blur-2xl"
    >
    </div>

    <Container size="wide" class="relative">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <!-- Texte -->
        <div class="lg:col-span-7">
          <p class="text-(--text-eyebrow) text-(--color-orange) font-semibold uppercase tracking-wider">
            Promesse maîtresse
          </p>
          <h1
            class="mt-6 text-(--color-encre) leading-(--leading-tight) tracking-tight"
            style="font-family: var(--font-display); font-weight: 600; font-size: var(--text-h1-hero);"
          >
            Vos rendez-vous,<br />
            <Highlight>garantis</Highlight>.
          </h1>
          <p
            class="mt-8 text-(--color-encre)/80 max-w-xl leading-(--leading-relaxed)"
            style="font-family: var(--font-display); font-style: italic; font-weight: 400; font-size: var(--text-body-lg);"
          >
            On définit ensemble le minimum de RDV qualifiés dont vous avez besoin sur 3 mois pour rentabiliser. Si on n'y arrive pas, on continue jusqu'à y arriver. <Highlight>Sans facturer.</Highlight>
          </p>
          <div class="mt-10 flex flex-wrap items-center gap-4">
            <Button href="/contact" variant="bleu" size="lg">Réserver un appel</Button>
            <Button href="#comment-ca-marche" variant="ghost" size="lg">Comment ça marche</Button>
          </div>
        </div>

        <!-- Mockup boite mail -->
        <div class="lg:col-span-5">
          <MockupMail />
        </div>
      </div>
    </Container>
  </Section>

  <!-- 2. LES 4 PILIERS -->
  <Section spacing="md">
    <Container size="wide">
      <div class="max-w-2xl mb-12">
        <p class="text-(--text-eyebrow) text-(--color-orange) font-semibold uppercase tracking-wider">
          Quatre engagements
        </p>
        <h2
          class="mt-4 text-(--color-encre) leading-(--leading-title) tracking-tight"
          style="font-family: var(--font-sans); font-weight: 700; font-size: var(--text-h2);"
        >
          Ce qui nous différencie. Vraiment.
        </h2>
      </div>
      <ul class="grid gap-5 sm:grid-cols-2">
        {
          piliers.map((p) => (
            <li>
              <Card variant={p.master ? 'encre' : 'creme'}>
                <div class="flex items-start justify-between gap-4">
                  <h3
                    class={`leading-(--leading-title) ${p.master ? 'text-(--color-creme)' : 'text-(--color-encre)'}`}
                    style="font-family: var(--font-display); font-weight: 600; font-size: var(--text-h3);"
                  >
                    {p.title}
                  </h3>
                  <span
                    class={`flex-shrink-0 ${p.master ? 'text-(--color-bleu)' : 'text-(--color-orange)'}`}
                    style="font-family: var(--font-display); font-style: italic; font-weight: 500; font-size: 1rem;"
                  >
                    {p.num}
                  </span>
                </div>
                <p
                  class={`mt-4 ${p.master ? 'text-(--color-creme)/80' : 'text-(--color-gris)'}`}
                  style="font-size: var(--text-body); line-height: var(--leading-normal);"
                >
                  {p.body}
                </p>
              </Card>
            </li>
          ))
        }
      </ul>
    </Container>
  </Section>

  <!-- 3. ILS NOUS FONT CONFIANCE -->
  <Section spacing="sm">
    <Container size="wide">
      <p class="text-(--text-eyebrow) text-(--color-gris) font-medium uppercase tracking-wider text-center">
        Ils nous font confiance
      </p>
      <ul class="mt-8 flex flex-wrap items-center justify-center gap-x-12 gap-y-6">
        {
          clients.map((c) => (
            <li
              class="text-(--color-encre)/40 hover:text-(--color-encre)/80 transition-colors"
              style="font-family: var(--font-display); font-weight: 600; font-size: 1.5rem; letter-spacing: -0.02em;"
            >
              {c}
            </li>
          ))
        }
      </ul>
    </Container>
  </Section>

  <!-- 4. NOTRE ENGAGEMENT (MANIFESTE) -->
  <Section spacing="lg">
    <Container size="default">
      <Card variant="orange" class="!p-10 sm:!p-16">
        <p class="text-(--text-eyebrow) text-(--color-orange) font-semibold uppercase tracking-wider">
          Notre engagement
        </p>
        <h2
          class="mt-6 text-(--color-encre) leading-(--leading-title)"
          style="font-family: var(--font-display); font-weight: 600; font-size: var(--text-h2);"
        >
          Le seul juge des rendez-vous qu'on vous livre, c'est vous.
        </h2>
        <div
          class="mt-10 space-y-6 text-(--color-encre)"
          style="font-family: var(--font-display); font-style: italic; font-weight: 400; font-size: var(--text-body-lg); line-height: var(--leading-relaxed);"
        >
          <p>Vous avez besoin de rendez-vous. Pas d'une équipe qui vous explique pendant trois mois ce qu'elle va faire.</p>
          <p>
            Chez Simple, on commence par calculer <Highlight>avec vous</Highlight> le minimum de rendez-vous qualifiés dont vous avez besoin pour rentabiliser. Pas en théorie. Avec votre vrai taux de conversion et votre vraie cible client.
          </p>
          <p>
            Ensuite on lance. Vos premiers rendez-vous arrivent <Highlight>dans 15 jours</Highlight>. Pas besoin de recruter. Pas d'engagement. Pas de slides chaque lundi.
          </p>
          <p>
            On vous livre des rendez-vous. Vous décidez s'ils étaient bons. Si on ne tient pas le minimum sur 3 mois, on continue <Highlight>gratuitement</Highlight> jusqu'à le tenir.
          </p>
          <p>C'est notre métier. Et c'est aussi simple que notre nom.</p>
        </div>
      </Card>
    </Container>
  </Section>

  <!-- 5. COMMENT CA SE PASSE -->
  <Section spacing="md" id="comment-ca-marche">
    <Container size="wide">
      <div class="max-w-2xl mb-12">
        <p class="text-(--text-eyebrow) text-(--color-orange) font-semibold uppercase tracking-wider">
          Comment ça se passe
        </p>
        <h2
          class="mt-4 text-(--color-encre) leading-(--leading-title) tracking-tight"
          style="font-family: var(--font-sans); font-weight: 700; font-size: var(--text-h2);"
        >
          Quatre étapes. Aucun bullshit.
        </h2>
      </div>
      <ol class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          etapes.map((e) => (
            <li>
              <Card variant="ghost" class="h-full">
                <span
                  class="text-(--color-orange) block"
                  style="font-family: var(--font-display); font-style: italic; font-weight: 500; font-size: 1.125rem;"
                >
                  {e.num}
                </span>
                <h3
                  class="mt-4 text-(--color-encre) leading-(--leading-title)"
                  style="font-family: var(--font-sans); font-weight: 600; font-size: var(--text-h3);"
                >
                  {e.title}
                </h3>
                <p class="mt-3 text-(--color-gris) text-(--text-body) leading-(--leading-normal)">
                  {e.body}
                </p>
              </Card>
            </li>
          ))
        }
      </ol>
    </Container>
  </Section>

  <!-- 6. PREUVES (cas clients chiffres) -->
  <Section spacing="md" id="preuves">
    <Container size="wide">
      <div class="max-w-2xl mb-12">
        <p class="text-(--text-eyebrow) text-(--color-orange) font-semibold uppercase tracking-wider">
          Preuves
        </p>
        <h2
          class="mt-4 text-(--color-encre) leading-(--leading-title) tracking-tight"
          style="font-family: var(--font-sans); font-weight: 700; font-size: var(--text-h2);"
        >
          Trois cas. Trois résultats chiffrés.
        </h2>
      </div>
      <ul class="grid gap-5 sm:grid-cols-3">
        {
          CASE_STUDIES.map((cs) => (
            <li>
              <Card href={`/cas-clients/${cs.slug}`}>
                <p
                  class="text-(--color-orange)"
                  style="font-family: var(--font-display); font-style: italic; font-weight: 500; font-size: 1rem;"
                >
                  {cs.sector}
                </p>
                <h3
                  class="mt-4 text-(--color-encre) leading-(--leading-title)"
                  style="font-family: var(--font-display); font-weight: 600; font-size: 1.5rem;"
                >
                  {cs.client}
                </h3>
                <p
                  class="mt-6 text-(--color-encre) leading-(--leading-title)"
                  style="font-family: var(--font-sans); font-weight: 700; font-size: 2rem;"
                >
                  {cs.headline}
                </p>
                <span class="mt-6 inline-flex items-center gap-1 text-(--text-caption) text-(--color-bleu) font-medium">
                  Lire le cas →
                </span>
              </Card>
            </li>
          ))
        }
      </ul>
    </Container>
  </Section>

  <!-- 7. QUI EST DERRIERE -->
  <Section spacing="md">
    <Container size="default">
      <div class="grid md:grid-cols-3 gap-10 items-center">
        <div class="md:col-span-1">
          <!-- TODO Iris : portrait Kenzy noir & blanc grain leger -->
          <div
            aria-hidden="true"
            class="aspect-square rounded-(--radius-xl) bg-gradient-to-br from-(--color-encre) to-(--color-encre-soft) flex items-center justify-center text-(--color-creme)/30"
            style="font-family: var(--font-display); font-style: italic; font-size: 1rem;"
          >
            Photo Kenzy
          </div>
        </div>
        <div class="md:col-span-2">
          <p class="text-(--text-eyebrow) text-(--color-orange) font-semibold uppercase tracking-wider">
            Qui est derrière
          </p>
          <h2
            class="mt-4 text-(--color-encre) leading-(--leading-title) tracking-tight"
            style="font-family: var(--font-display); font-weight: 600; font-size: var(--text-h2);"
          >
            Moi, Kenzy.
          </h2>
          <p class="mt-6 text-(--color-encre) text-(--text-body-lg) leading-(--leading-relaxed)">
            Pas de chargé de compte. Pas d'équipe junior qui se forme sur votre dos. Vous parlez à la personne qui pilote vos campagnes du brief jusqu'au reporting.
          </p>
          <p class="mt-4 text-(--color-gris) text-(--text-body) leading-(--leading-normal)">
            Solo, avec un réseau de freelances triés sur le volet pour la production. Mode opérationnel court, sans intermédiaire commercial qui dilue le message.
          </p>
        </div>
      </div>
    </Container>
  </Section>

  <!-- 8. TARIF -->
  <Section spacing="md">
    <Container size="default">
      <Card variant="encre" class="!p-10 sm:!p-16 text-center">
        <p class="text-(--text-eyebrow) text-(--color-orange) font-semibold uppercase tracking-wider">
          Le tarif
        </p>
        <p
          class="mt-6 text-(--color-creme) leading-(--leading-tight)"
          style="font-family: var(--font-sans); font-weight: 700; font-size: clamp(2.5rem, 5vw, 4rem);"
        >
          À partir de <span class="text-(--color-bleu)">2 000 €</span> par mois.
        </p>
        <p
          class="mt-6 text-(--color-creme)/85 max-w-xl mx-auto leading-(--leading-relaxed)"
          style="font-family: var(--font-display); font-style: italic; font-weight: 400; font-size: var(--text-body-lg);"
        >
          Forfait. Sans engagement. Garantie minimum vital sur 3 mois. Pas de mark-up sur les outils, pas de frais cachés.
        </p>
        <div class="mt-10">
          <Button href="/contact" variant="bleu" size="lg">Demander un devis</Button>
        </div>
      </Card>
    </Container>
  </Section>

  <!-- 9. FAQ OFFICIELLE -->
  <Section spacing="md">
    <Container size="default">
      <div class="max-w-2xl mb-12">
        <p class="text-(--text-eyebrow) text-(--color-orange) font-semibold uppercase tracking-wider">
          FAQ
        </p>
        <h2
          class="mt-4 text-(--color-encre) leading-(--leading-title) tracking-tight"
          style="font-family: var(--font-display); font-weight: 600; font-size: var(--text-h2);"
        >
          Six objections frontales.
        </h2>
      </div>
      <dl class="space-y-6">
        {
          faq.map((item) => (
            <div class="border-t border-(--color-encre)/10 pt-6">
              <dt
                class="text-(--color-encre)"
                style="font-family: var(--font-display); font-style: italic; font-weight: 600; font-size: var(--text-h3);"
              >
                {item.question}
              </dt>
              <dd class="mt-3 text-(--color-gris) text-(--text-body) leading-(--leading-relaxed) max-w-3xl">
                {item.answer}
              </dd>
            </div>
          ))
        }
      </dl>
    </Container>
  </Section>

  <!-- 10. CTA FINAL -->
  <Section spacing="lg" class="relative overflow-hidden">
    <div
      aria-hidden="true"
      class="absolute -bottom-32 -left-32 w-[28rem] h-[28rem] rounded-full bg-(--color-bleu-soft) opacity-50 blur-2xl"
    >
    </div>
    <Container size="default" class="relative">
      <div class="text-center">
        <h2
          class="text-(--color-encre) leading-(--leading-title) tracking-tight"
          style="font-family: var(--font-display); font-weight: 600; font-size: var(--text-h2);"
        >
          On regarde vos chiffres.<br />
          On vous dit si on peut tenir.
        </h2>
        <p class="mt-6 text-(--color-encre)/75 text-(--text-body-lg) max-w-2xl mx-auto leading-(--leading-relaxed)">
          20 minutes en visio. Si on ne peut pas, on vous le dit franchement. Si on peut, on signe la semaine d'après.
        </p>
        <div class="mt-10">
          <Button href="/contact" variant="bleu" size="lg">Réserver un appel</Button>
        </div>
      </div>
    </Container>
  </Section>
</PageLayout>
