---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import ArrowButton from '@components/ui/ArrowButton.astro';
import GlassButton from '@components/ui/GlassButton.astro';
import HighlightMarker from '@components/ui/HighlightMarker.astro';
import LogoMarquee from '@components/LogoMarquee.astro';
import PartnerWilco from '@components/PartnerWilco.astro';
import GuaranteeCards from '@components/GuaranteeCards.astro';
import MethodeVennEnrichi from '@components/methode/MethodeVennEnrichi.astro';
import ContainerScroll from '@components/animations/ContainerScroll.astro';
import WhatWeDo from '@components/animations/WhatWeDo.astro';
import ScrollExpansionHero from '@components/animations/ScrollExpansionHero.astro';
import StoryScroll from '@components/animations/StoryScroll.astro';
import StorySection from '@components/animations/StorySection.astro';
import HeroShowcase from '@components/HeroShowcase.astro';
import ShaderBg from '@components/ui/ShaderBg';
import ServiceTakeover from '@components/ServiceTakeover.astro';
import RoiCalculator from '@components/RoiCalculator.astro';
import ClientInterviews from '@components/ClientInterviews.astro';
import ToolsConstellation from '@components/ToolsConstellation.astro';
import FaqSection from '@components/FaqSection.astro';
import FinalCta from '@components/FinalCta.astro';
import { localBusinessSchema, faqSchema } from '@lib/schema';
import { HOME_FAQ } from '@lib/content-data';

/**
 * Home Agence Simple v3 - reprise dynamique Framer + charte v2.
 * Architecture funnel commercial inspiree du site actuel :
 * Hero -> ContainerScroll dashboard mail -> Logos clients (marquee)
 * Suite (PR 2-4) : cards garanties, 4 piliers, What We Do, calculateur, processus, valeurs, interviews, FAQ.
 */

const title = 'Agence de prospection B2B : RDV qualifiés garantis';
const description =
  "Agence de prospection B2B : rendez-vous qualifiés par cold email et LinkedIn. Forfait mensuel sans engagement, garantie minimum vital incluse.";

/* Schema FAQPage synchronise avec la FAQ visible (FaqSection <- HOME_FAQ). */
const schemas = [
  localBusinessSchema(),
  faqSchema(HOME_FAQ.map((f) => ({ question: f.q, answer: f.a }))),
];

/* Config ShaderGradient de reference (Kenzy) : seules les 3 couleurs changent
   par fiche process, le mouvement (uSpeed 0.4, uDensity 1.3...) reste identique. */
const shaderUrl = (c1: string, c2: string, c3: string) =>
  `https://www.shadergradient.co/customize?animate=on&axesHelper=off&brightness=1.2&cAzimuthAngle=180&cDistance=3.6&cPolarAngle=90&cameraZoom=1&color1=%23${c1}&color2=%23${c2}&color3=%23${c3}&destination=onCanvas&embedMode=off&envPreset=city&format=gif&fov=45&frameRate=10&gizmoHelper=hide&grain=off&lightType=3d&pixelDensity=1&positionX=-1.4&positionY=0&positionZ=0&range=disabled&rangeEnd=40&rangeStart=0&reflection=0.1&rotationX=0&rotationY=10&rotationZ=50&shader=defaults&type=plane&uAmplitude=1&uDensity=1.3&uFrequency=5.5&uSpeed=0.4&uStrength=4&uTime=0&wireframe=false`;

/* Fond hero : gradient ShaderGradient 'Interstellar' (config exacte Kenzy),
   sphere orange/bleu animee sur fond noir, rendu par ShaderBg (lazy three.js). */
const HERO_SHADER =
  'https://www.shadergradient.co/customize?animate=on&axesHelper=off&bgColor1=%23000000&bgColor2=%23000000&brightness=0.8&cAzimuthAngle=67&cDistance=0.5&cPolarAngle=107&cameraZoom=15.1&color1=%23709ac4&color2=%23ff810a&color3=%23ceb990&destination=onCanvas&embedMode=off&envPreset=city&format=gif&fov=45&frameRate=10&gizmoHelper=hide&grain=on&lightType=env&pixelDensity=1&positionX=-0.1&positionY=0&positionZ=0&range=disabled&rangeEnd=40&rangeStart=0&reflection=0.4&rotationX=0&rotationY=130&rotationZ=70&shader=defaults&type=sphere&uAmplitude=3.2&uDensity=0.8&uFrequency=5.5&uSpeed=0.3&uStrength=0.3&uTime=0&wireframe=false';

const STORY_SHADERS = {
  cadrage: shaderUrl('dbba95', 'f2e3cf', '99a0e1'),
  infra: shaderUrl('0f1b3f', '2a3fbf', '7a5fd0'),
  lancement: shaderUrl('ff5005', 'dbba95', '99a0e1'),
  agenda: shaderUrl('99a0e1', 'c5caf2', 'dbba95'),
};
---

<BaseLayout
  title={title}
  description={description}
  schemas={schemas}
  bodyClass="!bg-[#0F1B3F]"
>
  <Header slot="header" variant="dark" />

  <main class="bg-[#0F1B3F] text-[#FAF7F2] min-h-screen">
    <!-- ============ ZONE GRADIENT : hero -> references (canvas sticky plein viewport) ============ -->
    <div class="hero-zone relative">
      <div class="hero-zone__bg" aria-hidden="true">
        <div class="hero-zone__bg-sticky">
          <img
            src="/images/hero-gradient-poster.webp"
            alt=""
            width="1200"
            height="750"
            loading="eager"
            class="hero-zone__poster"
          />
          <ShaderBg client:load urlString={HERO_SHADER} mode="idle" minWidth={768} />
        </div>
      </div>

      <!-- HERO -->
      <section class="relative">
      <div class="hero-shader__scrim" aria-hidden="true"></div>
      <div class="relative z-10 min-h-[92vh] flex flex-col items-center justify-center text-center px-5 pt-20 pb-10">
        <h1
          class="py-4 leading-(--leading-tight) tracking-tight max-w-5xl mx-auto text-center"
          style="font-family: var(--font-sans); font-weight: 700; font-size: var(--text-h1-hero); color: var(--color-creme); text-shadow: 0 2px 30px rgba(0, 0, 0, 0.45);"
        >
          Payez
          <HighlightMarker>seulement</HighlightMarker>
          quand vous avez<br />
          un
          <span style="font-family: var(--font-display); font-style: italic; font-weight: 600; color: var(--color-bleu);">RDV qualifié</span>.
        </h1>

        <p class="mt-6 text-(--color-creme)/85 max-w-2xl mx-auto text-(length:--text-body-lg) leading-(--leading-relaxed)" style="text-shadow: 0 1px 18px rgba(0, 0, 0, 0.5);">
          Une équipe complète de prospection B2B qui prend tout en charge. On vous livre des rendez-vous qualifiés. Vous décidez s'ils sont bons.
        </p>

        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <GlassButton href="/contact" size="lg" withArrow ariaLabel="Prendre RDV">
            Prendre RDV
          </GlassButton>
          <ArrowButton href="#comment-ca-marche" variant="ghost-dark" size="lg" withArrow={false}>
            En savoir plus
          </ArrowButton>
        </div>
      </div>
    </section>

    <!-- ============ CONTAINER SCROLL : DASHBOARD MAIL (espace genere par pb des CTAs) ============ -->
    <section class="relative flex flex-col overflow-hidden">
      <ContainerScroll>
        <HeroShowcase />
      </ContainerScroll>
    </section>

    <!-- ============ 2. ILS NOUS FONT CONFIANCE : encart Wilco (reduit, chevauchement) + logos ============ -->
    <div class="relative z-[2]">
      <PartnerWilco />
      <LogoMarquee />
    </div>

      <div class="hero-zone__fade" aria-hidden="true"></div>
    </div>

    <!-- ============ 3. AVANTAGES CLES : frais + garantie minimum + aucun engagement ============ -->
    <GuaranteeCards />

    <!-- ============ 4. CE QU'ON FAIT POUR VOUS : sphere multi-services ============ -->
    <div id="comment-ca-marche">
      <WhatWeDo />
    </div>

    <!-- ============ 5. CE QU'ON PREND EN CHARGE (5 cards detaillees) ============ -->
    <ServiceTakeover />

    <!-- ============ 6. GESTION COMPLETE : expansion sur calendrier plein de RDV ============ -->
    <ScrollExpansionHero
      mediaSrc="/images/calendrier-rdv.webp"
      mediaSmallSrc="/images/agenda-jour.webp"
      mediaType="image"
      bgImageSrc="/images/bg-shader-kenzy.webp"
      title="Gestion complète"
      date="De A à Z"
      scrollToExpand="Faites défiler pour découvrir"
    >
      <ShaderBg client:load slot="background" />
      <div class="max-w-3xl mx-auto text-center text-(--color-creme)">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
          Le résultat concret
        </p>
        <h3
          class="mt-5 leading-(--leading-title)"
          style="font-family: var(--font-display); font-style: italic; font-weight: 600; font-size: clamp(1.75rem, 3vw, 2.5rem);"
        >
          Un agenda qui se remplit de RDV qualifiés.
        </h3>
        <p class="mt-6 text-(--color-creme)/75 text-(length:--text-body-lg) leading-(--leading-relaxed)">
          Stratégie, sourcing, infrastructure email, outils, copywriting, pilotage hebdo.
          Vous récupérez les rendez-vous qualifiés directement dans votre agenda.
        </p>
      </div>
    </ScrollExpansionHero>

    <!-- ============ 7. METHODOLOGIE : Ciblage x Copy x Infra (Venn enrichi) ============ -->
    <MethodeVennEnrichi />

    <!-- ============ 8. PROCESS : les 4 etapes en story scroll ============ -->
    <StoryScroll ariaLabel="Le process Agence Simple en 4 etapes">
      <StorySection bg="custom" customBg="url('/images/story-cadrage.webp') center / cover no-repeat" textColor="var(--color-encre)" ariaLabel="Process etape 1">
        <ShaderBg client:load urlString={STORY_SHADERS.cadrage} slot="background" />
        <div class="mx-auto max-w-4xl text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
            Process · Semaine 1
          </p>
          <h2
            class="mt-5 leading-(--leading-tight)"
            style="font-family: var(--font-display); font-style: italic; font-weight: 600; font-size: clamp(2.5rem, 6vw, 4.5rem); color: var(--color-encre);"
          >
            On cadre<br />votre cible.
          </h2>
          <p class="mt-6 text-(length:--text-body-lg) max-w-2xl mx-auto opacity-80">
            Un atelier pour définir les segments visés, les angles de message et les critères
            d'exclusion. Vous validez le document stratégique avant que le moindre message parte.
          </p>
        </div>
      </StorySection>

      <StorySection bg="custom" customBg="url('/images/story-infra.webp') center / cover no-repeat" textColor="var(--color-creme)" ariaLabel="Process etape 2">
        <ShaderBg client:load urlString={STORY_SHADERS.infra} slot="background" />
        <div class="mx-auto max-w-4xl text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
            Process · Semaine 2
          </p>
          <h2
            class="mt-5 leading-(--leading-tight)"
            style="font-family: var(--font-display); font-style: italic; font-weight: 600; font-size: clamp(2.5rem, 6vw, 4.5rem); color: var(--color-creme);"
          >
            Listes, copy,<br />infrastructure.
          </h2>
          <p class="mt-6 text-(length:--text-body-lg) max-w-2xl mx-auto opacity-85">
            Listes construites sur mesure, séquences rédigées et validées par vous mot par mot,
            domaines dédiés montés en réputation. Votre domaine principal n'est jamais exposé.
          </p>
        </div>
      </StorySection>

      <StorySection bg="custom" customBg="url('/images/story-lancement.webp') center / cover no-repeat" textColor="var(--color-encre)" ariaLabel="Process etape 3">
        <ShaderBg client:load urlString={STORY_SHADERS.lancement} slot="background" />
        <div class="mx-auto max-w-4xl text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-encre)">
            Process · Semaines 3 à 6
          </p>
          <h2
            class="mt-5 leading-(--leading-tight)"
            style="font-family: var(--font-display); font-style: italic; font-weight: 600; font-size: clamp(2.5rem, 6vw, 4.5rem); color: var(--color-encre);"
          >
            Lancement<br />et itérations.
          </h2>
          <p class="mt-6 text-(length:--text-body-lg) max-w-2xl mx-auto opacity-80">
            Envois progressifs pour protéger la délivrabilité, arbitrages chaque semaine :
            on coupe ce qui ne répond pas, on double sur ce qui fonctionne.
          </p>
        </div>
      </StorySection>

      <StorySection bg="custom" customBg="url('/images/story-agenda.webp') center / cover no-repeat" textColor="var(--color-encre)" ariaLabel="Process etape 4">
        <ShaderBg client:load urlString={STORY_SHADERS.agenda} slot="background" />
        <div class="mx-auto max-w-4xl text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
            Process · Mois 2 et suivants
          </p>
          <h2
            class="mt-5 leading-(--leading-tight)"
            style="font-family: var(--font-display); font-style: italic; font-weight: 600; font-size: clamp(2.5rem, 6vw, 4.5rem); color: var(--color-encre);"
          >
            Des RDV dans<br />votre agenda.
          </h2>
          <p class="mt-6 text-(length:--text-body-lg) max-w-2xl mx-auto opacity-80">
            Chaque réponse positive est qualifiée puis transformée en rendez-vous posé dans votre
            agenda, avec le contexte complet. Reporting mensuel avec les vrais chiffres.
          </p>
        </div>
      </StorySection>
    </StoryScroll>

    <!-- ============ 9. CALCULATEUR ROI COLD EMAIL ============ -->
    <RoiCalculator />

    <!-- ============ CONSTELLATION OUTILS ============ -->
    <ToolsConstellation />

    <!-- ============ INTERVIEWS CLIENTS ============ -->
    <ClientInterviews />

    <!-- ============ FAQ ============ -->
    <FaqSection />

    <!-- ============ CTA FINAL ============ -->
    <FinalCta />
  </main>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Zone gradient : le canvas Interstellar (100vh, sticky) suit le scroll
     du hero jusqu'aux references, fondu vers l'encre en bas de zone */
  .hero-zone {
    background: radial-gradient(ellipse 90% 70% at 60% 30%, #16233f, #000000);
  }
  .hero-zone__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .hero-zone__bg-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
  }
  /* Poster statique du gradient : rendu immediat (et definitif sur mobile),
     le canvas anime se monte par-dessus apres interaction/idle (desktop) */
  .hero-zone__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-zone__fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 16rem;
    pointer-events: none;
    z-index: 1;
    background: linear-gradient(180deg, transparent, #0F1B3F 88%);
  }
  /* Scrim de lisibilite du hero (radial centre + attenuation haut header) */
  .hero-shader__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 78% 60% at 50% 44%, rgba(8, 14, 34, 0.52), transparent 72%),
      linear-gradient(180deg, rgba(15, 27, 63, 0.4), transparent 22%);
  }
</style>
