---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import ArrowButton from '@components/ui/ArrowButton.astro';
import GlassButton from '@components/ui/GlassButton.astro';
import HighlightMarker from '@components/ui/HighlightMarker.astro';
import { LampContainer } from '@components/ui/Lamp';
import LogoMarquee from '@components/LogoMarquee.astro';
import PartnerWilco from '@components/PartnerWilco.astro';
import GuaranteeCards from '@components/GuaranteeCards.astro';
import MethodeVennEnrichi from '@components/methode/MethodeVennEnrichi.astro';
import ContainerScroll from '@components/animations/ContainerScroll.astro';
import WhatWeDo from '@components/animations/WhatWeDo.astro';
import ScrollExpansionHero from '@components/animations/ScrollExpansionHero.astro';
import StoryScroll from '@components/animations/StoryScroll.astro';
import StorySection from '@components/animations/StorySection.astro';
import MailboxDashboard from '@components/MailboxDashboard.astro';
import ShaderBg from '@components/ui/ShaderBg';
import ServiceTakeover from '@components/ServiceTakeover.astro';
import RoiCalculator from '@components/RoiCalculator.astro';
import ClientInterviews from '@components/ClientInterviews.astro';
import ToolsConstellation from '@components/ToolsConstellation.astro';
import FaqSection from '@components/FaqSection.astro';
import FinalCta from '@components/FinalCta.astro';
import { localBusinessSchema, faqSchema } from '@lib/schema';
import { HOME_FAQ } from '@lib/content-data';

/**
 * Home Agence Simple v3 - reprise dynamique Framer + charte v2.
 * Architecture funnel commercial inspiree du site actuel :
 * Hero -> ContainerScroll dashboard mail -> Logos clients (marquee)
 * Suite (PR 2-4) : cards garanties, 4 piliers, What We Do, calculateur, processus, valeurs, interviews, FAQ.
 */

const title = 'Agence de prospection B2B : rendez-vous qualifiés garantis';
const description =
  "Agence de prospection B2B : rendez-vous qualifiés par cold email et LinkedIn. Forfait mensuel sans engagement, garantie minimum vital incluse.";

/* Schema FAQPage synchronise avec la FAQ visible (FaqSection <- HOME_FAQ). */
const schemas = [
  localBusinessSchema(),
  faqSchema(HOME_FAQ.map((f) => ({ question: f.q, answer: f.a }))),
];
---

<BaseLayout
  title={title}
  description={description}
  schemas={schemas}
  bodyClass="!bg-[#0F1B3F]"
>
  <Header slot="header" variant="dark" />

  <main class="bg-[#0F1B3F] text-[#FAF7F2] min-h-screen">
    <!-- ============ HERO (Aceternity Lamp Effect, charte bleu) ============ -->
    <section class="relative overflow-hidden">
      <LampContainer client:load>
        <h1
          class="mt-8 py-4 leading-(--leading-tight) tracking-tight max-w-5xl mx-auto text-center"
          style="font-family: var(--font-sans); font-weight: 700; font-size: var(--text-h1-hero); color: var(--color-creme);"
        >
          Payez
          <HighlightMarker>seulement</HighlightMarker>
          quand vous avez<br />
          un
          <span style="font-family: var(--font-display); font-style: italic; font-weight: 600; color: var(--color-bleu);">RDV qualifié</span>.
        </h1>
      </LampContainer>

      <!-- Paragraphe + CTAs : overlap le bas de la lamp (negative margin), pb 12 pour aerer avant le dashboard -->
      <div class="relative z-10 -mt-64 sm:-mt-72 pb-12 sm:pb-16 text-center px-5" style="background-color: var(--color-encre);">
        <p class="text-(--color-creme)/75 max-w-2xl mx-auto text-(--text-body-lg) leading-(--leading-relaxed)">
          Une équipe complète de prospection B2B qui prend tout en charge. On vous livre des rendez-vous qualifiés. Vous décidez s'ils sont bons.
        </p>

        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <GlassButton href="/contact" size="lg" withArrow ariaLabel="Prendre rendez-vous">
            Prendre RDV
          </GlassButton>
          <ArrowButton href="#comment-ca-marche" variant="ghost-dark" size="lg" withArrow={false}>
            En savoir plus
          </ArrowButton>
        </div>
      </div>
    </section>

    <!-- ============ CONTAINER SCROLL : DASHBOARD MAIL (espace genere par pb des CTAs) ============ -->
    <section class="relative flex flex-col overflow-hidden">
      <ContainerScroll>
        <MailboxDashboard />
      </ContainerScroll>
    </section>

    <!-- ============ 2. ILS NOUS FONT CONFIANCE : encart Wilco (reduit, chevauchement) + logos ============ -->
    <PartnerWilco />
    <LogoMarquee />

    <!-- ============ 3. AVANTAGES CLES : frais + garantie minimum + aucun engagement ============ -->
    <GuaranteeCards />

    <!-- ============ 4. CE QU'ON FAIT POUR VOUS : sphere multi-services ============ -->
    <div id="comment-ca-marche">
      <WhatWeDo />
    </div>

    <!-- ============ 5. CE QU'ON PREND EN CHARGE (5 cards detaillees) ============ -->
    <ServiceTakeover />

    <!-- ============ 6. GESTION COMPLETE : expansion sur calendrier plein de RDV ============ -->
    <ScrollExpansionHero
      mediaSrc="/images/calendrier-rdv.webp"
      mediaSmallSrc="/images/agenda-jour.webp"
      mediaType="image"
      bgImageSrc="/images/bg-shader-kenzy.webp"
      title="Gestion complète"
      date="De A à Z"
      scrollToExpand="Faites défiler pour découvrir"
    >
      <ShaderBg client:load slot="background" />
      <div class="max-w-3xl mx-auto text-center text-(--color-creme)">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
          Le résultat concret
        </p>
        <h3
          class="mt-5 leading-(--leading-title)"
          style="font-family: var(--font-display); font-style: italic; font-weight: 600; font-size: clamp(1.75rem, 3vw, 2.5rem);"
        >
          Un agenda qui se remplit de RDV qualifiés.
        </h3>
        <p class="mt-6 text-(--color-creme)/75 text-(--text-body-lg) leading-(--leading-relaxed)">
          Stratégie, sourcing, infrastructure email, outils, copywriting, pilotage hebdo.
          Vous récupérez les rendez-vous qualifiés directement dans votre agenda.
        </p>
      </div>
    </ScrollExpansionHero>

    <!-- ============ 7. METHODOLOGIE : Ciblage x Copy x Infra (Venn enrichi) ============ -->
    <MethodeVennEnrichi />

    <!-- ============ 8. PROCESS : les 4 etapes en story scroll ============ -->
    <StoryScroll ariaLabel="Le process Agence Simple en 4 etapes">
      <StorySection bg="creme" ariaLabel="Process etape 1">
        <div class="mx-auto max-w-4xl text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
            Process · Semaine 1
          </p>
          <h2
            class="mt-5 leading-(--leading-tight)"
            style="font-family: var(--font-display); font-style: italic; font-weight: 600; font-size: clamp(2.5rem, 6vw, 4.5rem); color: var(--color-encre);"
          >
            On cadre<br />votre cible.
          </h2>
          <p class="mt-6 text-(--color-encre)/65 text-(--text-body-lg) max-w-2xl mx-auto">
            Un atelier pour définir les segments visés, les angles de message et les critères
            d'exclusion. Vous validez le document stratégique avant que le moindre message parte.
          </p>
        </div>
      </StorySection>

      <StorySection bg="encre" ariaLabel="Process etape 2">
        <div class="mx-auto max-w-4xl text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
            Process · Semaine 2
          </p>
          <h2
            class="mt-5 leading-(--leading-tight)"
            style="font-family: var(--font-display); font-style: italic; font-weight: 600; font-size: clamp(2.5rem, 6vw, 4.5rem); color: var(--color-creme);"
          >
            Listes, copy,<br />infrastructure.
          </h2>
          <p class="mt-6 text-(--color-creme)/65 text-(--text-body-lg) max-w-2xl mx-auto">
            Listes construites sur mesure, séquences rédigées et validées par vous mot par mot,
            domaines dédiés montés en réputation. Votre domaine principal n'est jamais exposé.
          </p>
        </div>
      </StorySection>

      <StorySection bg="orange-soft" ariaLabel="Process etape 3">
        <div class="mx-auto max-w-4xl text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-encre)">
            Process · Semaines 3 à 6
          </p>
          <h2
            class="mt-5 leading-(--leading-tight)"
            style="font-family: var(--font-display); font-style: italic; font-weight: 600; font-size: clamp(2.5rem, 6vw, 4.5rem); color: var(--color-encre);"
          >
            Lancement<br />et itérations.
          </h2>
          <p class="mt-6 text-(--color-encre)/65 text-(--text-body-lg) max-w-2xl mx-auto">
            Envois progressifs pour protéger la délivrabilité, arbitrages chaque semaine :
            on coupe ce qui ne répond pas, on double sur ce qui fonctionne.
          </p>
        </div>
      </StorySection>

      <StorySection bg="bleu-soft" ariaLabel="Process etape 4">
        <div class="mx-auto max-w-4xl text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
            Process · Mois 2 et suivants
          </p>
          <h2
            class="mt-5 leading-(--leading-tight)"
            style="font-family: var(--font-display); font-style: italic; font-weight: 600; font-size: clamp(2.5rem, 6vw, 4.5rem); color: var(--color-encre);"
          >
            Des RDV dans<br />votre agenda.
          </h2>
          <p class="mt-6 text-(--color-encre)/65 text-(--text-body-lg) max-w-2xl mx-auto">
            Chaque réponse positive est qualifiée puis transformée en rendez-vous posé dans votre
            agenda, avec le contexte complet. Reporting mensuel avec les vrais chiffres.
          </p>
        </div>
      </StorySection>
    </StoryScroll>

    <!-- ============ 9. CALCULATEUR ROI COLD EMAIL ============ -->
    <RoiCalculator />

    <!-- ============ CONSTELLATION OUTILS ============ -->
    <ToolsConstellation />

    <!-- ============ INTERVIEWS CLIENTS ============ -->
    <ClientInterviews />

    <!-- ============ FAQ ============ -->
    <FaqSection />

    <!-- ============ CTA FINAL ============ -->
    <FinalCta />
  </main>

  <Footer slot="footer" />
</BaseLayout>
