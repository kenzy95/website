---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Container from '@components/ui/Container.astro';
import ArrowButton from '@components/ui/ArrowButton.astro';
import HighlightMarker from '@components/ui/HighlightMarker.astro';
import LogoMarquee from '@components/LogoMarquee.astro';
import PartnerWilco from '@components/PartnerWilco.astro';
import GuaranteeCards from '@components/GuaranteeCards.astro';
import LeadGenSection from '@components/LeadGenSection.astro';
import ContainerScroll from '@components/animations/ContainerScroll.astro';
import MailboxDashboard from '@components/MailboxDashboard.astro';
import { localBusinessSchema, faqSchema } from '@lib/schema';

/**
 * Home Agence Simple v3 - reprise dynamique Framer + charte v2.
 * Architecture funnel commercial inspiree du site actuel :
 * Hero -> ContainerScroll dashboard mail -> Logos clients (marquee)
 * Suite (PR 2-4) : cards garanties, 4 piliers, What We Do, calculateur, processus, valeurs, interviews, FAQ.
 */

const title = 'Agence prospection B2B Paris - rendez-vous garantis';
const description =
  "Agence Simple génère des rendez-vous B2B qualifiés. Forfait 2 000 € par mois, sans engagement. Si on ne tient pas le minimum sur 3 mois, on continue gratuitement.";

const faq = [
  { question: 'Comment vous calculez le minimum vital ?', answer: 'On regarde votre taux de conversion en clientèle et combien de clients il vous faut pour rentabiliser. On en déduit ensemble un seuil chiffré.' },
  { question: 'Et si je n\'atteins pas le minimum ?', answer: 'On continue gratuitement jusqu\'à l\'atteindre. Pas de petites lignes, pas de remboursement compliqué.' },
];

const schemas = [localBusinessSchema(), faqSchema(faq)];
---

<BaseLayout
  title={title}
  description={description}
  schemas={schemas}
  bodyClass="!bg-[#0F1B3F]"
>
  <Header slot="header" variant="dark" />

  <main class="bg-[#0F1B3F] text-[#FAF7F2] min-h-screen overflow-x-hidden">
    <!-- ============ HERO ============ -->
    <section class="relative pt-32 pb-12 sm:pt-40 sm:pb-20">
      <!-- Glows decoratifs -->
      <div aria-hidden="true" class="glow-orange w-[32rem] h-[32rem] -top-32 -right-32 opacity-40"></div>
      <div aria-hidden="true" class="glow-violet w-[36rem] h-[36rem] top-32 -left-40 opacity-50"></div>
      <div aria-hidden="true" class="glow-bleu w-[24rem] h-[24rem] top-1/2 left-1/2 -translate-x-1/2 opacity-30"></div>

      <Container size="wide" class="relative text-center">
        <h1
          class="leading-(--leading-tight) tracking-tight max-w-5xl mx-auto"
          style="font-family: var(--font-sans); font-weight: 700; font-size: var(--text-h1-hero); color: var(--color-creme);"
        >
          Payez
          <HighlightMarker>seulement</HighlightMarker>
          quand vous avez<br />
          un
          <span style="font-family: var(--font-display); font-style: italic; font-weight: 600; color: var(--color-bleu);">RDV qualifié</span>.
        </h1>

        <p class="mt-8 text-(--color-creme)/75 max-w-2xl mx-auto text-(--text-body-lg) leading-(--leading-relaxed)">
          Une équipe complète de prospection qui prend tout en charge. On vous livre des rendez-vous qualifiés. Vous décidez s'ils sont bons.
        </p>

        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <ArrowButton href="/contact" variant="bleu" size="lg">Prendre RDV</ArrowButton>
          <ArrowButton href="#comment-ca-marche" variant="ghost-dark" size="lg" withArrow={false}>
            En savoir plus
          </ArrowButton>
        </div>
      </Container>
    </section>

    <!-- ============ CONTAINER SCROLL : DASHBOARD MAIL ============ -->
    <section class="relative flex flex-col overflow-hidden">
      <ContainerScroll>
        <MailboxDashboard />
      </ContainerScroll>
    </section>

    <!-- ============ LOGOS CLIENTS (MARQUEE) ============ -->
    <LogoMarquee />

    <!-- ============ PARTENAIRE WILCO ============ -->
    <PartnerWilco />

    <!-- ============ 2 CARDS BICOLORES GARANTIES ============ -->
    <GuaranteeCards />

    <!-- ============ SECTION "RDV QUALIFIES" + 2 CARDS INFRA/OPTIM ============ -->
    <LeadGenSection />

    <!-- TODO PR3 : What We Do + ScrollExpansion + 5 cards prise en charge + Processus -->
    <!-- TODO PR4 : Calculateur + Valeurs + Interviews + Constellation outils + FAQ + CTA final -->

    <div class="py-32 text-center">
      <p class="text-(--color-creme)/40 text-sm italic">
        (Sections suivantes en construction - PR 3 et 4)
      </p>
    </div>
  </main>

  <Footer slot="footer" />
</BaseLayout>
