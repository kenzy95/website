---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import CtaBlock from '@components/CtaBlock.astro';
import { COMPARISONS } from '@lib/content-data';

export function getStaticPaths() {
  return COMPARISONS.map((c) => ({
    params: { slug: c.slug },
    props: { comparison: c },
  }));
}

const { comparison } = Astro.props;

const breadcrumb = [
  { name: 'Comparatifs', href: '/comparatifs' },
  { name: comparison.title.split(' :')[0] },
];
---

<PageLayout
  title={comparison.title}
  description={comparison.metaDescription}
  breadcrumb={breadcrumb}
>
  <Section spacing="lg">
    <Container size="default">
      <p class="text-(--text-small) text-(--color-bleu) font-semibold uppercase tracking-wider">
        Comparatif
      </p>
      <h1 class="mt-4 text-(--text-h1) font-bold leading-(--leading-tight)">{comparison.title}</h1>
      <p class="mt-6 text-(--text-body) text-(--color-gris) max-w-2xl">{comparison.description}</p>
    </Container>
  </Section>

  <Section spacing="md">
    <Container size="default">
      <!-- TODO Théo : comparatif structuré en tableaux HTML (LLM-friendly).
           Lignes : coût, vitesse, scalabilité, qualité, risque, ROI, recommandation finale.
           Schema FAQPage si bloc FAQ. -->
      <p class="text-(--text-body) text-(--color-gris)">Comparatif détaillé en cours de rédaction.</p>
    </Container>
  </Section>

  <CtaBlock title="Le bon choix dépend de votre situation" description="20 minutes en visio pour décortiquer la vôtre." />
</PageLayout>
