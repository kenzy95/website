---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Container from '@components/ui/Container.astro';
import GlassButton from '@components/ui/GlassButton.astro';
import ArrowButton from '@components/ui/ArrowButton.astro';
import HighlightMarker from '@components/ui/HighlightMarker.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import VideoFacade from '@components/VideoFacade.astro';
import { SERVICES } from '@lib/content-data';
import { serviceSchema, faqSchema, videoObjectSchema } from '@lib/schema';
import { SITE } from '@lib/site';

/**
 * Page dediee prospection-b2b : copy long-form valide (Sacha/Theo).
 * Design aligne charte v2 : hero encre + glows, corps creme arrondi (pattern
 * ServiceTakeover), methode en cards numerotees, resultats en stat cards,
 * CTA final en bande encre. Texte du copy verbatim.
 * Schemas : Service + FAQPage + VideoObject x3 ; BreadcrumbList via Breadcrumb.
 */

const service = SERVICES.find((s) => s.slug === 'prospection-b2b')!;
const url = `${SITE.url}/services/prospection-b2b`;

const metaTitle = 'Agence de prospection B2B avec garantie de RDV qualifiés';
const metaDescription =
  'Agence de prospection B2B à Paris. RDV qualifiés via cold email et LinkedIn. Forfait mensuel transparent, garantie minimum vital, sans engagement.';

const breadcrumb = [
  { name: 'Services', href: '/services' },
  { name: 'Prospection B2B' },
];

const toc = [
  { label: 'Notre promesse', href: '#promesse' },
  { label: "Pour qui c'est fait", href: '#pour-qui' },
  { label: 'Comment on procède', href: '#methode' },
  { label: 'Ce qui est inclus', href: '#inclus' },
  { label: "Ce qui n'est pas inclus", href: '#pas-inclus' },
  { label: 'Combien ça coûte', href: '#cout' },
  { label: 'Résultats clients', href: '#resultats' },
  { label: 'Pourquoi Agence Simple', href: '#pourquoi' },
];

const etapes = [
  {
    titre: 'Cadrage de la cible et du positionnement',
    periode: 'Semaine 1',
    texte:
      "Nous démarrons par un atelier de cadrage : qui sont vos meilleurs clients actuels, pourquoi ils ont signé, quels signaux rendent un prospect mûr. De votre côté, vous fournissez votre connaissance du marché, vos références clients et vos objections récurrentes. Le livrable est un document stratégique qui fixe les segments visés, les angles de message et les critères d'exclusion. Vous le validez avant que le moindre message parte.",
  },
  {
    titre: "Construction des séquences et de l'infrastructure",
    periode: 'Semaine 2',
    texte:
      "Nous construisons les listes de prospects (Sales Navigator, enrichissement de données, freelances de recherche vérifiés), rédigeons les séquences de messages, et montons l'infrastructure d'envoi : domaines secondaires dédiés, boîtes mail, montée en réputation progressive. Vous relisez et validez chaque séquence. Livrable : des campagnes prêtes à partir, avec des messages que vous avez approuvés mot par mot.",
  },
  {
    titre: 'Lancement, itération, ajustement',
    periode: 'Semaines 3 à 6',
    texte:
      "Les envois démarrent progressivement pour protéger la délivrabilité. Chaque semaine, nous comparons les angles testés, coupons ce qui ne répond pas et doublons sur ce qui fonctionne. Les premières réponses arrivent en général en semaine 2 ou 3, les premiers RDV en semaine 3 ou 4. Livrable : un point hebdomadaire avec les chiffres réels et les arbitrages proposés.",
  },
  {
    titre: 'Régime de croisière et reporting',
    periode: 'Mois 2 et suivants',
    texte:
      "Une fois les angles gagnants identifiés, la machine tourne : nouvelles listes chaque mois, itérations sur les segments, et un reporting mensuel qui montre les envois, les réponses, les RDV pris et le statut de l'engagement contractuel. Pas de tableau de bord décoratif : les mêmes chiffres que ceux que nous regardons en interne.",
  },
];

const videos = [
  {
    client: 'Komon',
    videoId: '-GaYHXJR-Hc',
    name: 'Témoignage client Komon x Agence Simple',
    description:
      'Komon raconte sa collaboration avec Agence Simple en prospection B2B, sans script imposé.',
    uploadDate: '2026-07-03',
  },
  {
    client: 'Daisy app',
    videoId: 'fepN_sOkUAo',
    name: 'Témoignage client Daisy app x Agence Simple',
    description:
      'Daisy app raconte sa collaboration avec Agence Simple en prospection B2B, sans script imposé.',
    uploadDate: '2026-07-03',
  },
  {
    client: 'Les Épaulettes',
    videoId: 'h7vkCT5aDhY',
    name: 'Témoignage client Les Épaulettes x Agence Simple',
    description:
      'Alison, de Les Épaulettes, raconte sa collaboration avec Agence Simple en prospection B2B, sans script imposé.',
    uploadDate: '2026-02-25',
  },
];

const faqItems = [
  {
    question: 'Combien coûte une agence de prospection B2B ?',
    answer:
      "Le budget dépend du volume visé et de la complexité de la cible. Chez Agence Simple, le format est un forfait mensuel transparent qui couvre le sourcing, le copywriting, l'infrastructure d'envoi et la qualification des réponses, avec les outils refacturés au coût réel sans marge. Vous recevez un devis précis après un premier échange sur votre cible. Le détail est sur la page nos tarifs de prospection B2B.",
  },
  {
    question: 'Combien de RDV qualifiés pouvez-vous générer par mois ?',
    answer:
      "Entre 8 et 25 RDV qualifiés par mois selon la cible, le panier moyen et le canal utilisé. Nous fixons un engagement précis dans le contrat, la garantie minimum vital : s'il n'est pas tenu sur 3 mois, nous prolongeons gratuitement la mission jusqu'à le tenir.",
  },
  {
    question: 'À partir de quand voit-on les premiers résultats ?',
    answer:
      'Les premières réponses arrivent en semaine 2 ou 3 après le lancement. Les premiers RDV qualifiés sont pris en semaine 3 ou 4. Le régime de croisière se stabilise à partir du deuxième mois.',
  },
  {
    question: "Qui définit ce qu'est un RDV qualifié ?",
    answer:
      "Vous, et vous seul. Chaque RDV vous est remis avec le profil de l'interlocuteur, son contexte et la conversation d'origine. Si vous marquez le RDV comme non qualifié, il sort du décompte de l'engagement. Cette règle est écrite dans le contrat.",
  },
  {
    question: 'Suis-je engagé sur la durée ?',
    answer:
      "Non. Le forfait est mensuel, résiliable avec un mois de préavis. La garantie minimum vital reste active tant que le contrat court : si vous résiliez avant que l'engagement soit tenu, la mission s'arrête simplement, sans pénalité de part ni d'autre.",
  },
  {
    question: 'Utilisez-vous mes propres domaines email ?',
    answer:
      "Non. Nous prospectons depuis des domaines secondaires dédiés (par exemple un équivalent en « hello-votremarque.com »), jamais depuis votre domaine principal. Sa réputation d'envoi reste ainsi intacte pour vos emails du quotidien. Vous gardez la propriété des domaines secondaires créés pour la mission.",
  },
  {
    question: 'Prenez-vous en charge les rendez-vous ou juste le premier contact ?',
    answer:
      "Nous prenons le RDV et le posons dans votre agenda avec tout le contexte. La vente reste chez vous : c'est vous qui présentez, qualifiez en profondeur et signez. C'est un choix, pas une limite : personne ne connaît votre produit et votre marché mieux que vous.",
  },
  {
    question: 'Pouvez-vous refuser un client ?',
    answer:
      "Oui. Nous refusons quand la cible n'est pas identifiable en base ou trop étroite pour la prospection sortante, quand le panier moyen est trop faible pour rentabiliser la démarche, quand le produit n'a pas encore de traction démontrée, ou quand le client attend des résultats en moins de 15 jours. Nous préférons un non clair à un contrat qui va mal se passer.",
  },
];

const schemas = [
  serviceSchema({
    name: service.title,
    description: service.description,
    url,
    serviceType: service.serviceType,
  }),
  faqSchema(faqItems.map((f) => ({ question: f.question, answer: f.answer }))),
  ...videos.map((v) =>
    videoObjectSchema({
      name: v.name,
      description: v.description,
      embedUrl: `https://www.youtube-nocookie.com/embed/${v.videoId}`,
      thumbnailUrl: `https://i.ytimg.com/vi/${v.videoId}/hqdefault.jpg`,
      uploadDate: v.uploadDate,
    })
  ),
];
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  schemas={schemas}
  bodyClass="!bg-[#0F1B3F]"
>
  <Header slot="header" variant="dark" />

  <div class="page bg-[#0F1B3F]">
    <!-- ============ HERO ENCRE + GLOWS ============ -->
    <section class="hero relative overflow-hidden pt-10 pb-20 sm:pb-24">
      <div aria-hidden="true" class="glow-bleu w-[30rem] h-[30rem] -top-24 -right-16 opacity-50"></div>
      <div aria-hidden="true" class="glow-violet w-[34rem] h-[34rem] top-64 -left-32 opacity-45"></div>
      <div aria-hidden="true" class="glow-orange w-[20rem] h-[20rem] top-10 left-1/3 opacity-30"></div>

      <Container size="default" class="relative z-10">
        <div class="hero__crumb">
          <Breadcrumb items={breadcrumb} />
        </div>

        <p class="eyebrow mt-10">Service · Prospection B2B</p>
        <h1 class="hero__h1">
          Agence de prospection B2B : des
          <span class="accent-display">RDV qualifiés</span>
          chaque mois, avec une
          <HighlightMarker>garantie chiffrée</HighlightMarker>
        </h1>
        <p class="hero__lead">
          Agence Simple est une agence de prospection B2B basée à Paris. Notre métier tient en une
          phrase : remplir l'agenda de votre équipe commerciale avec des rendez-vous qualifiés,
          obtenus par cold email et par LinkedIn. Pas de volume de messages facturé au poids, pas de
          promesse du type « 100 RDV en 30 jours ». À la place : un engagement chiffré de RDV, écrit
          dans le contrat, et une garantie qui nous oblige à le tenir.
        </p>
        <p class="hero__sub">
          Cette page décrit exactement ce que nous faisons, pour qui, comment, ce qui est inclus dans
          le forfait, et ce qui ne l'est pas. Si à la fin vous pensez que la prospection sortante
          n'est pas faite pour vous, vous aurez au moins gagné une grille de lecture pour évaluer
          n'importe quel prestataire.
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-4">
          <GlassButton href="#prendre-rendez-vous" size="lg" withArrow ariaLabel="Réserver un diagnostic gratuit">
            Réserver un diagnostic gratuit
          </GlassButton>
          <ArrowButton href="#methode" variant="ghost-dark" size="lg" withArrow={false}>
            Voir la méthode
          </ArrowButton>
        </div>

        <!-- Sommaire ancré (reco mobile) -->
        <nav class="toc" aria-label="Sommaire">
          <p class="toc__title">Sur cette page</p>
          <ol class="toc__list">
            {toc.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ol>
        </nav>
      </Container>
    </section>

    <!-- ============ CORPS CREME (pattern ServiceTakeover : arrondi qui ressort du dark) ============ -->
    <article class="body-creme">
      <Container size="default">
        <div class="prose-col">
          <!-- Notre promesse -->
          <h2 id="promesse">Notre promesse : un nombre de RDV qualifiés par mois, pas un volume de messages</h2>
          <p>
            Un RDV qualifié, dans notre contrat, c'est un échange de 30 minutes minimum, en visio ou
            par téléphone, avec un interlocuteur qui correspond au profil client défini ensemble et qui
            a exprimé un intérêt explicite pour votre offre. Un clic sur un lien n'est pas un RDV. Une
            réponse polie non plus.
          </p>
          <p>
            C'est sur ce nombre de RDV qualifiés B2B que nous nous engageons, pas sur un volume
            d'emails envoyés. La nuance change tout : une agence payée pour envoyer des messages a
            intérêt à envoyer beaucoup. Une agence engagée sur des RDV a intérêt à viser juste.
          </p>
          <div class="callout">
            <p>
              Cet engagement s'appelle chez nous la garantie minimum vital. Concrètement : avant le
              lancement, nous fixons ensemble un nombre de RDV qualifiés à livrer chaque mois, calibré
              sur votre cible, votre panier moyen et votre cycle de vente. Si cet engagement n'est pas
              tenu sur une période de 3 mois, nous prolongeons la mission gratuitement, à nos frais,
              jusqu'à l'atteindre. Pas de geste commercial à négocier, pas de clause en petits caractères
              : la prolongation est automatique et écrite dans le contrat.
            </p>
          </div>
          <p>
            Dernier verrou, le plus important : vous êtes seul juge de la qualification. Si vous estimez
            qu'un RDV livré ne correspond pas au profil convenu, il sort du décompte. Nous ne discutons
            pas votre appréciation. Une garantie de prospection dont le prestataire tient lui-même le
            compteur ne garantit rien.
          </p>
          <p class="inline-cta">
            <a href="#prendre-rendez-vous">Discuter de votre engagement de RDV</a>
          </p>

          <!-- Pour qui -->
          <h2 id="pour-qui">Pour qui c'est fait (et pour qui ce n'est pas fait)</h2>
          <p>
            Externaliser sa prospection commerciale n'a de sens que si l'économie du modèle tient. Nos
            clients partagent trois caractéristiques : ils vendent en B2B, leur panier moyen annuel se
            compte en milliers d'euros, et leur cycle de vente dépasse deux semaines. En dessous, chaque
            RDV coûte plus cher qu'il ne rapporte, et aucune agence honnête ne devrait vous vendre le
            contraire.
          </p>
          <p>
            Les cas typiques que nous traitons : la
            <a href="/secteurs/saas">prospection B2B pour éditeurs SaaS</a> qui veulent un canal
            sortant en complément de l'inbound, les ESN et cabinets de conseil dont le bouche-à-oreille
            plafonne, et la
            <a href="/secteurs/scale-up-post-levee">prospection pour scale-up post-Series A</a> qui
            doivent transformer une levée en pipeline commercial avant la prochaine échéance.
          </p>
          <p>
            Ce n'est pas fait pour : le B2C, l'e-commerce grand public, les offres à petit ticket, et
            les situations d'urgence où il faut des résultats sous 48 heures. La prospection B2B est un
            canal qui se construit sur des semaines, pas un robinet qu'on ouvre.
          </p>
          <p>
            Un point d'honnêteté : si votre panier moyen ne se compte pas en milliers d'euros par
            client, la prospection sortante ne sera probablement pas rentable pour vous. Nous vous le
            dirons au premier appel, et nous vous orienterons vers des canaux mieux adaptés à votre
            modèle.
          </p>

          <!-- Méthode -->
          <h2 id="methode">Comment on procède : la méthode Agence Simple en 4 étapes</h2>
          <p>
            Notre méthode de prospection B2B suit quatre étapes, chacune avec un livrable précis. Le
            détail complet est documenté sur la page
            <a href="/methode">méthode Agence Simple en 4 étapes</a>.
          </p>
        </div>

        <div class="steps">
          {etapes.map((e, i) => (
            <div class="step-card">
              <div class="step-card__head">
                <span class="step-card__num">0{i + 1}</span>
                <span class="step-card__periode">{e.periode}</span>
              </div>
              <h3 class="step-card__title">Étape {i + 1} : {e.titre}</h3>
              <p class="step-card__body">{e.texte}</p>
            </div>
          ))}
        </div>

        <div class="prose-col">
          <!-- Inclus -->
          <h2 id="inclus">Ce qui est inclus dans le forfait mensuel</h2>
          <p>
            Le forfait de prospection B2B couvre la chaîne complète, de la liste au RDV posé dans votre
            agenda :
          </p>
        </div>

        <div class="panel panel--inclus">
          <ul class="feature-list">
            <li>
              Le sourcing des listes de prospects, construit sur mesure pour votre cible à partir de
              Sales Navigator et d'outils d'enrichissement, avec vérification des adresses email avant
              tout envoi.
            </li>
            <li>
              Le copywriting des séquences, sur les deux canaux :
              <a href="/services/cold-email">notre approche du cold email B2B</a> et la
              <a href="/services/linkedin-outreach">prospection LinkedIn avec Sales Navigator</a>.
              Chaque message est relu et validé par vous avant envoi.
            </li>
            <li>
              L'infrastructure d'envoi complète : domaines secondaires dédiés à la prospection, boîtes
              mail, montée en réputation, rotation des envois. Votre domaine principal n'est jamais
              exposé.
            </li>
            <li>
              La qualification des réponses par un humain de l'équipe : chaque réponse positive est lue,
              traitée et transformée en proposition de créneau. Vous recevez le RDV dans votre agenda
              avec le contexte complet de la conversation.
            </li>
            <li>
              Le reporting mensuel avec les vrais chiffres : envois, taux de réponse, RDV livrés, écart
              par rapport à l'engagement.
            </li>
          </ul>
        </div>

        <div class="prose-col">
          <p>
            Et un point de fonctionnement qui nous distingue : vous échangez directement avec l'équipe
            qui opère votre compte. Pas de chef de projet commercial en façade avec la production
            ailleurs, pas de troisième couche entre vous et les personnes qui écrivent vos messages.
          </p>

          <!-- Pas inclus -->
          <h2 id="pas-inclus">Ce qui n'est PAS inclus (la transparence qu'aucune agence n'affiche)</h2>
          <p>
            Toutes les agences listent ce qu'elles font. Presque aucune ne liste ce qu'elle ne fait pas.
            Voici notre périmètre, en négatif :
          </p>
        </div>

        <div class="panel panel--exclus">
          <ul class="feature-list feature-list--neg">
            <li>
              Nous ne tenons pas les rendez-vous commerciaux à votre place. Nous prenons le RDV, vous
              menez la vente. C'est vous qui connaissez votre produit et votre marché, et un RDV mené
              par un intermédiaire se sent immédiatement. Si vous cherchez une équipe qui prend aussi en
              charge la conversation commerciale, regardez notre offre de
              <a href="/services/sdr-externalise">SDR externalisé en marque blanche</a>, qui va un cran
              plus loin sans jamais remplacer votre closing.
            </li>
            <li>
              Nous ne produisons pas de contenu marketing : pas de publicité LinkedIn, pas de SEO, pas
              d'articles de blog. Nous faisons un métier, la prise de RDV B2B en sortant.
            </li>
            <li>
              Nous n'installons pas et ne paramétrons pas votre CRM. Les RDV arrivent dans votre agenda
              et par email avec leur contexte ; l'intégration dans vos outils internes reste chez vous.
            </li>
            <li>
              Nous ne garantissons pas de signatures. Nous contrôlons la qualité du RDV livré, pas votre
              taux de conversion en clients : il dépend de votre offre, de votre prix et de votre
              closing.
            </li>
            <li>
              Nous ne travaillons pas à la commission au succès seul. Un modèle 100 % au résultat pousse
              le prestataire à forcer des RDV limites pour déclencher sa rémunération. Le forfait avec
              garantie protège mieux les deux parties : nous sommes payés pour opérer sérieusement, et
              la garantie nous sanctionne si le résultat ne suit pas.
            </li>
          </ul>
        </div>

        <div class="prose-col">
          <!-- Coût -->
          <h2 id="cout">Combien ça coûte : un forfait mensuel transparent</h2>
          <p>
            Le prix d'une agence de prospection B2B dépend de deux variables : le volume visé et la
            complexité de la cible. Une cible large avec des interlocuteurs faciles à identifier ne
            demande pas le même travail qu'une niche étroite où chaque compte doit être qualifié à la
            main. C'est pourquoi nous ne publions pas de grille unique : vous recevez un devis précis
            après un premier échange sur votre cible, sans engagement. Le détail de la structure du
            forfait est présenté sur la page <a href="/tarifs">nos tarifs de prospection B2B</a>.
          </p>
          <p>Trois principes ne varient jamais, quel que soit le devis :</p>
          <ul class="feature-list feature-list--flat">
            <li>
              Le forfait est mensuel et sans engagement de durée : vous résiliez avec un mois de
              préavis, sans pénalité.
            </li>
            <li>
              Aucune marge cachée sur les outils : les licences (Sales Navigator, plateforme d'envoi)
              sont refacturées au coût réel, factures à l'appui.
            </li>
            <li>
              Le devis inclut tout le périmètre décrit plus haut : pas de « module qualification » ou de
              « pack reporting » vendus en supplément une fois le contrat signé.
            </li>
          </ul>
          <p>
            Pour situer l'alternative : recruter un commercial de prospection en interne, c'est un
            salaire chargé, des outils, du management, environ trois mois de recrutement puis plusieurs
            mois de montée en régime avant les premiers résultats réguliers. Une agence démarre en deux
            semaines et se résilie en un mois si le compte n'y est pas. Les deux modèles se défendent
            selon votre stade : nous avons publié un
            <a href="/comparatifs/sdr-interne-vs-agence-externalisee">comparatif SDR interne vs agence externalisée</a>
            et un outil pour
            <a href="/outils/calculateur-cout-sdr-interne-vs-agence">calculer le coût d'un SDR interne</a>
            qui posent les chiffres des deux options.
          </p>

          <!-- Tableau comparatif qualitatif (visuel, sans chiffres en euros) -->
          <div class="compare" role="table" aria-label="SDR interne vs agence externalisée">
            <div class="compare__row compare__row--head" role="row">
              <span role="columnheader">Critère</span>
              <span role="columnheader">SDR interne</span>
              <span role="columnheader">Agence externalisée</span>
            </div>
            <div class="compare__row" role="row">
              <span role="rowheader">Délai de démarrage</span>
              <span>Trois mois de recrutement puis montée en régime</span>
              <span>Opérationnel en deux semaines</span>
            </div>
            <div class="compare__row" role="row">
              <span role="rowheader">Engagement</span>
              <span>Contrat de travail, sortie longue</span>
              <span>Mensuel, résiliable en un mois de préavis</span>
            </div>
            <div class="compare__row" role="row">
              <span role="rowheader">Management</span>
              <span>À votre charge au quotidien</span>
              <span>Piloté par l'équipe, en direct avec vous</span>
            </div>
            <div class="compare__row" role="row">
              <span role="rowheader">Outils</span>
              <span>À acquérir et paramétrer vous-même</span>
              <span>Inclus, refacturés au coût réel sans marge</span>
            </div>
          </div>

          <!-- Résultats -->
          <h2 id="resultats">Ce que ça donne : résultats de nos clients</h2>
          <p>
            Les chiffres ci-dessous sont validés par les clients concernés avant publication. Pas de
            moyenne invérifiable, pas de « jusqu'à x10 » : des campagnes réelles, datées, avec leur
            contexte.
          </p>
        </div>

        <div class="stats">
          <div class="stat-card">
            <span class="stat-card__num">41</span>
            <span class="stat-card__label">RDV qualifiés en 5 semaines</span>
            <p class="stat-card__body">
              <strong>Happycolis.</strong> Une cible e-commerce et logistique, un angle unique testé
              puis décliné, et un rythme d'itération hebdomadaire. Le détail du dispositif est
              documenté dans le cas client
              <a href="/cas-clients/happycolis">41 RDV en 5 semaines pour Happycolis</a>.
            </p>
          </div>
          <div class="stat-card">
            <span class="stat-card__num">151</span>
            <span class="stat-card__label">RDV qualifiés générés</span>
            <p class="stat-card__body">
              <strong>Invent-App.</strong> Une collaboration dans la durée sur le marché de
              l'événementiel, où le travail de fond sur les segments a compté davantage que le volume
              d'envois. Le déroulé complet est dans le cas client
              <a href="/cas-clients/invent-app">151 RDV qualifiés générés pour Invent-App</a>.
            </p>
          </div>
