---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import CtaBlock from '@components/CtaBlock.astro';
import { SERVICES } from '@lib/content-data';
import { serviceSchema } from '@lib/schema';
import { SITE } from '@lib/site';

export function getStaticPaths() {
  return SERVICES.filter((service) => service.slug !== 'prospection-b2b').map(
    (service) => ({
      params: { slug: service.slug },
      props: { service },
    })
  );
}

const { service } = Astro.props;
const url = `${SITE.url}/services/${service.slug}`;

const breadcrumb = [
  { name: 'Services', href: '/services' },
  { name: service.shortName },
];

const schemas = [
  serviceSchema({
    name: service.title,
    description: service.description,
    url,
    serviceType: service.serviceType,
  }),
];
---

<PageLayout
  title={service.title}
  description={service.metaDescription}
  breadcrumb={breadcrumb}
  schemas={schemas}
>
  <Section spacing="lg">
    <Container size="default">
      <p class="text-(--text-small) text-(--color-bleu) font-semibold uppercase tracking-wider">
        Service · {service.shortName}
      </p>
      <h1 class="mt-4 text-(--text-h1) font-bold leading-(--leading-tight)">
        {service.title}
      </h1>
      <p class="mt-6 text-(--text-body) text-(--color-gris) max-w-2xl">
        {service.description}
      </p>
    </Container>
  </Section>

  <Section spacing="md">
    <Container size="default">
      <!-- TODO Théo : copy détaillé sur la base du brief Sacha
           Sections obligatoires : Pour qui · Comment on procède · Ce qui est inclus · Ce qui n'est pas inclus · Cas client lié · FAQ
           Schema Service déjà injecté.
           Schema FAQPage à ajouter quand bloc FAQ rédigé. -->
      <p class="text-(--text-body) text-(--color-gris)">
        Contenu détaillé en cours de rédaction. Pour discuter de votre besoin, prenez rendez-vous.
      </p>
    </Container>
  </Section>

  <CtaBlock
    title={`Discuter de votre projet de ${service.shortName.toLowerCase()}`}
    description="20 minutes en visio. On vous dit franchement si c'est le bon canal pour vous."
  />
</PageLayout>
