---
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import Card from '@components/ui/Card.astro';
import CtaBlock from '@components/CtaBlock.astro';
import { SERVICES } from '@lib/content-data';

const title = 'Nos services de prospection B2B';
const description =
  "Quatre offres qui couvrent toute la chaîne de la prospection B2B : prospection clé en main, cold email, LinkedIn outreach, SDR externalisé. Forfait mensuel transparent.";

const breadcrumb = [{ name: 'Services' }];
---

<PageLayout title={title} description={description} breadcrumb={breadcrumb}>
  <Section spacing="lg">
    <Container size="default">
      <h1 class="text-(--text-h1) font-bold leading-(--leading-tight)">{title}</h1>
      <p class="mt-6 text-(--text-body) text-(--color-gris) max-w-2xl">{description}</p>
    </Container>
  </Section>

  <Section spacing="md">
    <Container size="wide">
      <ul class="grid gap-6 sm:grid-cols-2">
        {
          SERVICES.map((service) => (
            <li>
              <Card href={`/services/${service.slug}`}>
                <h2 class="text-(--text-h3) font-semibold">{service.shortName}</h2>
                <p class="mt-3 text-(--text-body) text-(--color-gris)">{service.description}</p>
                <span class="mt-4 inline-block text-(--text-small) text-(--color-bleu) underline-offset-4 hover:underline">
                  En savoir plus →
                </span>
              </Card>
            </li>
          ))
        }
      </ul>
    </Container>
  </Section>

  <CtaBlock
    title="Pas sûr de l'offre qui vous correspond ?"
    description="20 minutes en visio pour clarifier votre besoin et estimer le volume de RDV atteignable."
  />
</PageLayout>
