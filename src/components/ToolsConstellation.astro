---
/**
 * Section outils, pattern "animated beam" (ref MagicUI animated-beam, 21st.dev) :
 * 8 outils en 2 colonnes relies au hub central Agence Simple par des courbes,
 * un faisceau lumineux voyage le long de chaque courbe vers le hub.
 * SVG + CSS pur (stroke-dashoffset anime, pathLength normalise a 100),
 * zero JS. Nodes HTML positionnes en % sur le meme repere que le viewBox 800x480.
 */
import LogoWordmark from './ui/LogoWordmark.astro';

type Node = { label: string; logo: string; x: number; y: number; path: string; beam: 'orange' | 'bleu' };

const NODES: Node[] = [
  // Colonne gauche, 6 nodes (beams orange)
  { label: 'Sales Navigator', logo: '/logos/tools/linkedin.svg',  x: 90, y: 45,  path: 'M 128 45 C 250 45, 240 240, 326 240',   beam: 'orange' },
  { label: 'Instantly',       logo: '/logos/tools/instantly.png', x: 70, y: 123, path: 'M 108 123 C 230 123, 230 240, 326 240', beam: 'orange' },
  { label: 'Aimfox',          logo: '/logos/tools/aimfox.svg',    x: 60, y: 201, path: 'M 98 201 C 220 201, 235 240, 326 240',  beam: 'orange' },
  { label: 'Trigify',         logo: '/logos/tools/trigify.svg',   x: 60, y: 279, path: 'M 98 279 C 220 279, 235 240, 326 240',  beam: 'orange' },
  { label: 'Icypeas',         logo: '/logos/tools/icypeas.png',   x: 70, y: 357, path: 'M 108 357 C 230 357, 230 240, 326 240', beam: 'orange' },
  { label: 'Make',            logo: '/logos/tools/make.svg',      x: 90, y: 435, path: 'M 128 435 C 250 435, 240 240, 326 240', beam: 'orange' },
  // Colonne droite, 5 nodes (beams bleu)
  { label: 'Clay',         logo: '/logos/tools/clay.png',       x: 710, y: 60,  path: 'M 672 60 C 550 60, 560 240, 474 240',   beam: 'bleu' },
  { label: 'Lemlist',      logo: '/logos/tools/lemlist.svg',    x: 725, y: 150, path: 'M 687 150 C 570 150, 565 240, 474 240', beam: 'bleu' },
  { label: 'UseBouncer',   logo: '/logos/tools/usebouncer.png', x: 730, y: 240, path: 'M 692 240 C 600 240, 560 240, 474 240', beam: 'bleu' },
  { label: 'Claude',       logo: '/logos/tools/claude.svg',     x: 725, y: 330, path: 'M 687 330 C 570 330, 565 240, 474 240', beam: 'bleu' },
  { label: 'data.gouv.fr', logo: '/logos/tools/datagouv.svg',   x: 710, y: 420, path: 'M 672 420 C 550 420, 560 240, 474 240', beam: 'bleu' },
];

/* Coordonnees viewBox -> % du conteneur (800 x 480) */
const pct = (n: Node) => `left:${(n.x / 800) * 100}%;top:${(n.y / 480) * 100}%`;
---

<section class="tools-section">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-3xl mb-12 text-center mx-auto">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
        Notre stack
      </p>
      <h2
        class="mt-5 text-(--color-creme) leading-(--leading-title)"
        style="font-family: var(--font-sans); font-weight: 700; font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em;"
      >
        ~ 785 € d'outils inclus chaque mois.
      </h2>
      <p class="mt-6 text-(--color-creme)/70 text-(--text-body-lg)">
        On utilise les meilleurs outils du marché et on les inclut dans le forfait. Sans markup, facturés au coût réel.
      </p>
    </div>

    <div class="beam-stage">
      <svg class="beam-svg" viewBox="0 0 800 480" fill="none" preserveAspectRatio="none" aria-hidden="true">
        {NODES.map((n, i) => (
          <>
            <path d={n.path} class="beam-base" />
            <path
              d={n.path}
              class:list={['beam-light', n.beam === 'orange' ? 'beam-light--orange' : 'beam-light--bleu']}
              pathLength="100"
              style={`animation-delay:${i * 0.55}s`}
            />
          </>
        ))}
      </svg>

      {NODES.map((n) => (
        <div class="tool-node" style={pct(n)}>
          <img class="tool-node__logo" src={n.logo} alt={`Logo ${n.label}`} width="40" height="40" loading="lazy" />
          <span class="tool-node__label">{n.label}</span>
        </div>
      ))}

      <!-- Hub central : logo officiel -->
      <div class="tools-core">
        <LogoWordmark size="md" variant="creme" asLink={false} class="tools-core__logo" />
      </div>
    </div>
  </div>
</section>

<style>
  .tools-section {
    padding: 5rem 0 4rem;
  }

  .beam-stage {
    position: relative;
    max-width: 50rem;
    margin: 0 auto;
    aspect-ratio: 800 / 480;
    min-height: 20rem;
  }

  .beam-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .beam-base {
    stroke: rgba(250, 247, 242, 0.1);
    stroke-width: 1.5;
  }

  /* Faisceau : segment de 12 unites sur un cycle de 200 (pause d'un demi-cycle),
     dashoffset decroit -> le segment voyage de l'outil vers le hub */
  .beam-light {
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-dasharray: 12 188;
    stroke-dashoffset: 200;
    animation: beam-travel 3.2s linear infinite;
  }
  .beam-light--orange {
    stroke: var(--color-orange);
    filter: drop-shadow(0 0 6px rgba(244, 123, 63, 0.8));
  }
  .beam-light--bleu {
    stroke: #1e90ff;
    filter: drop-shadow(0 0 6px rgba(30, 144, 255, 0.8));
  }

  @keyframes beam-travel {
    to { stroke-dashoffset: 0; }
  }

  .tool-node {
    position: absolute;
    transform: translate(-50%, -50%);
    width: clamp(2.5rem, 6.5vw, 3.4rem);
    aspect-ratio: 1;
    background: rgba(250, 247, 242, 0.06);
    border: 1px solid rgba(250, 247, 242, 0.14);
    backdrop-filter: blur(8px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-creme);
    z-index: 1;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
  }
  .tool-node__logo {
    width: 56%;
    height: 56%;
    object-fit: contain;
    border-radius: 22%;
  }
  .tool-node__label {
    position: absolute;
    top: calc(100% + 0.4rem);
    left: 50%;
    transform: translateX(-50%);
    font-size: clamp(0.58rem, 1.4vw, 0.72rem);
    color: rgba(250, 247, 242, 0.55);
    white-space: nowrap;
    pointer-events: none;
  }

  .tools-core {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: clamp(6.5rem, 16vw, 9rem);
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #1a2750, #0a132e);
    border: 1px solid rgba(30, 144, 255, 0.25);
    box-shadow:
      0 0 60px rgba(30, 144, 255, 0.25),
      inset 0 0 30px rgba(0, 0, 0, 0.5);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    z-index: 2;
  }
  .tools-core :global(.tools-core__logo) {
    font-size: clamp(1.1rem, 2.6vw, 1.625rem) !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .beam-light { animation: none; opacity: 0; }
  }
</style>
