---
import Container from './ui/Container.astro';
import Button from './ui/Button.astro';

interface Props {
  title: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
  variant?: 'soft' | 'bold';
}

const {
  title,
  description,
  ctaLabel = 'Prendre rendez-vous',
  ctaHref = '/contact',
  variant = 'soft',
} = Astro.props;

const bg = variant === 'bold' ? 'bg-(--color-encre) text-(--color-creme)' : 'bg-(--color-bleu-soft)';
---

<section class={`${bg} my-24 rounded-(--radius-lg) overflow-hidden`}>
  <Container size="default" class="py-16 sm:py-20 text-center">
    <h2 class="text-(--text-h2) font-bold leading-(--leading-tight)">{title}</h2>
    {description && <p class="mt-4 text-(--text-body) opacity-80 max-w-2xl mx-auto">{description}</p>}
    <div class="mt-8">
      <Button href={ctaHref} variant={variant === 'bold' ? 'secondary' : 'primary'} size="lg">
        {ctaLabel}
      </Button>
    </div>
  </Container>
</section>
