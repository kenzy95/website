---
/**
 * Facade video legere : thumbnail YouTube cliquable qui charge l'iframe
 * youtube-nocookie au clic (protege le LCP, aucun iframe au chargement).
 * Vanilla, zero dependance npm.
 */

interface Props {
  videoId: string;
  title: string;
  client: string;
}

const { videoId, title, client } = Astro.props as Props;
const thumbnail = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
const embedSrc = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0`;
---

<figure class="video-facade">
  <button
    type="button"
    class="video-facade__btn"
    data-embed={embedSrc}
    aria-label={`Lire la video : ${title}`}
  >
    <img
      src={thumbnail}
      alt={`Miniature de l'interview ${client}`}
      loading="lazy"
      width="480"
      height="360"
      class="video-facade__thumb"
    />
    <span class="video-facade__play" aria-hidden="true">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
        <path d="M8 5v14l11-7z" />
      </svg>
    </span>
  </button>
  <figcaption class="video-facade__caption">{client}</figcaption>
</figure>

<style>
  .video-facade {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .video-facade__btn {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    padding: 0;
    border: 1px solid rgba(15, 27, 63, 0.08);
    border-radius: var(--radius-md);
    overflow: hidden;
    cursor: pointer;
    background: var(--color-encre);
    box-shadow: var(--shadow-card);
    transition: box-shadow 200ms ease, transform 200ms ease;
  }
  .video-facade__btn:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }
  .video-facade__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .video-facade__play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 4rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-bleu);
    color: #ffffff;
    box-shadow: var(--shadow-glow-bleu);
    transition: transform 200ms ease, background 200ms ease;
  }
  .video-facade__btn:hover .video-facade__play {
    transform: scale(1.08);
  }
  .video-facade__caption {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-encre);
  }
  .video-facade :global(iframe) {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
</style>

<script>
  document.querySelectorAll('.video-facade__btn').forEach((btn) => {
    btn.addEventListener(
      'click',
      () => {
        const embed = btn.getAttribute('data-embed');
        if (!embed) return;
        const iframe = document.createElement('iframe');
        iframe.src = embed;
        iframe.title = btn.getAttribute('aria-label') || 'Video';
        iframe.allow =
          'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
        iframe.setAttribute('allowfullscreen', 'true');
        btn.replaceWith(iframe);
      },
      { once: true }
    );
  });
</script>
