---
/**
 * Hero Gradient Background - adapte du composant Hookable.ai (Framer original)
 *
 * Structure :
 * - 2 clusters d'ellipses (gauche + droit en miroir) flottants au top
 * - Chaque cluster = 4 ellipses (1 orange, 1 violet, 1 rose, 1 bleu) en 2 layers
 *   (blur 200px + blur 100px pour effet "haze" superpose)
 * - Mask vertical pour fade en bas
 *
 * Couleurs adaptees a la charte Agence Simple :
 *   purple  -> #764cdc (violet charte)
 *   magenta -> #FF6FB5 (rose chaud, harmonise charte)
 *   orange  -> #F47B3F (orange charte)
 *   red     -> #1E90FF (bleu charte au lieu de rouge)
 */
---

<div class="hero-grad-bg" aria-hidden="true">
  {/* Left cluster */}
  <div class="hero-grad-bg__abstract hero-grad-bg__abstract--left">
    {/* Sub container 1 (blur 200px) */}
    <div class="hero-grad-bg__sub hero-grad-bg__sub--lg">
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--purple" style="top: 207px; left: 0;"></div>
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--magenta" style="top: 363px; left: 37px;"></div>
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--orange" style="top: 0; left: 213px;"></div>
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--bleu" style="top: 80px; left: 9px;"></div>
    </div>
    {/* Sub container 2 (blur 100px) */}
    <div class="hero-grad-bg__sub hero-grad-bg__sub--sm">
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--purple" style="top: 207px; left: 0;"></div>
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--magenta" style="top: 363px; left: 37px;"></div>
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--orange" style="top: 0; left: 213px;"></div>
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--bleu" style="top: 80px; left: 9px;"></div>
    </div>
  </div>

  {/* Right cluster (rotated 180deg) */}
  <div class="hero-grad-bg__abstract hero-grad-bg__abstract--right">
    <div class="hero-grad-bg__sub hero-grad-bg__sub--lg">
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--purple" style="top: 207px; left: 0;"></div>
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--magenta" style="top: 363px; left: 37px;"></div>
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--orange" style="top: 0; left: 213px;"></div>
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--bleu" style="top: 80px; left: 9px;"></div>
    </div>
    <div class="hero-grad-bg__sub hero-grad-bg__sub--sm hero-grad-bg__sub--rotated">
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--purple" style="top: 207px; left: 0;"></div>
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--magenta" style="top: 363px; left: 37px;"></div>
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--orange" style="top: 0; left: 213px;"></div>
      <div class="hero-grad-bg__ellipse hero-grad-bg__ellipse--bleu" style="top: 80px; left: 9px;"></div>
    </div>
  </div>
</div>

<style>
  .hero-grad-bg {
    position: absolute;
    top: 0;
    left: -120px;
    right: -120px;
    bottom: 0;
    overflow: visible;
    pointer-events: none;
    z-index: 0;
    /* Fade en bas (63% visible puis transparent) */
    -webkit-mask: linear-gradient(#000 63%, #0000 100%);
    mask: linear-gradient(#000 63%, #0000 100%);
  }

  /* Cluster gauche : top-left, 378x571 */
  .hero-grad-bg__abstract {
    position: absolute;
    filter: blur(2px);
    width: 378px;
    height: 571px;
    top: 0;
  }
  .hero-grad-bg__abstract--left {
    left: 0;
  }
  .hero-grad-bg__abstract--right {
    right: 0;
    transform: rotate(180deg);
  }

  /* Sub container, contient les 4 ellipses */
  .hero-grad-bg__sub {
    position: absolute;
    width: 420px;
    height: 571px;
    top: 0;
    left: -42px;
  }
  .hero-grad-bg__sub--rotated {
    transform: rotate(-25deg);
  }

  /* Ellipses : 207x208 base, couleur + blur via classe */
  .hero-grad-bg__ellipse {
    position: absolute;
    width: 207px;
    height: 208px;
    border-radius: 9999px;
  }
  /* Couleurs charte */
  .hero-grad-bg__ellipse--purple { background-color: #764cdc; }
  .hero-grad-bg__ellipse--magenta { background-color: #FF6FB5; }
  .hero-grad-bg__ellipse--orange { background-color: #F47B3F; }
  .hero-grad-bg__ellipse--bleu { background-color: #1E90FF; }

  /* Layer large (blur 200px) sur sub--lg, layer serre (blur 100px) sur sub--sm */
  .hero-grad-bg__sub--lg .hero-grad-bg__ellipse { filter: blur(200px); }
  .hero-grad-bg__sub--sm .hero-grad-bg__ellipse { filter: blur(100px); }

  @media (prefers-reduced-motion: reduce) {
    .hero-grad-bg {
      /* Static, no transitions to disable */
    }
  }
</style>
