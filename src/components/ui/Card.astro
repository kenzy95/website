---
/**
 * Card charte v2 : border-radius 16-24px, ombrage subtil.
 * variant 'creme' = card par defaut sur fond crème (la plupart des cas).
 * variant 'encre' = card maitre fond encre + texte creme (pilier maitre, mantra).
 * variant 'orange' = card chaleur fond orange-soft (manifeste, "ON EST", "FAIRE").
 * variant 'bleu' = card froide fond bleu-soft (contraste, "ON N'EST PAS", "NE PAS FAIRE").
 * variant 'ghost' = sans fond, bordure subtle.
 */
interface Props {
  href?: string;
  as?: 'div' | 'article' | 'a';
  variant?: 'creme' | 'encre' | 'orange' | 'bleu' | 'ghost';
  padded?: boolean;
  class?: string;
}

type Variant = NonNullable<Props['variant']>;

const {
  href,
  as: Tag = href ? 'a' : 'article',
  variant = 'creme',
  padded = true,
  class: className = '',
} = Astro.props as Props;

const variants: Record<Variant, string> = {
  creme: 'bg-(--color-creme-card) shadow-(--shadow-soft) hover:shadow-(--shadow-card-hover)',
  encre: 'bg-(--color-encre) text-(--color-creme) shadow-(--shadow-card) hover:shadow-(--shadow-card-hover)',
  orange: 'bg-(--color-orange-soft) shadow-(--shadow-soft) hover:shadow-(--shadow-card)',
  bleu: 'bg-(--color-bleu-soft) shadow-(--shadow-soft) hover:shadow-(--shadow-card)',
  ghost: 'bg-transparent border border-(--color-gris-light) hover:border-(--color-encre)/30',
};
---

<Tag
  href={href}
  class={`block rounded-(--radius-xl) transition-all duration-200 ${variants[variant]} ${padded ? 'p-6 sm:p-8' : ''} ${className}`}
>
  <slot />
</Tag>
