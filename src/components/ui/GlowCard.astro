---
/**
 * GlowCard - effet spotlight curseur (adapte de 21st.dev/easemize/spotlight-card)
 *
 * Wrapper transparent qui ajoute un border lumineux qui suit le curseur sur la
 * card enfant. Le contenu interne (card existante) reste intact.
 *
 * Implementation vanilla : un seul listener pointermove global qui set --glow-x
 * et --glow-y sur :root. Toutes les cards heritent. Pas de cout React, pas de
 * re-renders inutiles, accessible (touch-action: none coupe sur tactile).
 *
 * Usage :
 *   <GlowCard glowColor="blue"|"orange" radius={28} borderWidth={2}>
 *     <div class="ma-card-existante">...</div>
 *   </GlowCard>
 */
interface Props {
  glowColor?: 'blue' | 'orange' | 'purple' | 'green' | 'red';
  radius?: number;
  borderWidth?: number;
  spotlightSize?: number;
  class?: string;
}

const {
  glowColor = 'blue',
  radius = 22,
  borderWidth = 2,
  spotlightSize = 250,
  class: extraClass = '',
} = Astro.props as Props;

const glowMap = {
  blue: { base: 210, spread: 100 },
  orange: { base: 25, spread: 50 },
  purple: { base: 280, spread: 300 },
  green: { base: 120, spread: 200 },
  red: { base: 0, spread: 200 },
};

const { base, spread } = glowMap[glowColor];

const inlineVars = [
  `--gc-base: ${base}`,
  `--gc-spread: ${spread}`,
  `--gc-radius: ${radius}`,
  `--gc-border: ${borderWidth}`,
  `--gc-size: ${spotlightSize}`,
].join('; ');
---

<div class:list={['glow-card', extraClass]} style={inlineVars} data-glow>
  <slot />
</div>

<style>
  .glow-card {
    position: relative;
    border-radius: calc(var(--gc-radius) * 1px);
    isolation: isolate;
    /* Le wrapper est transparent, la card enfant porte le bg visuel */
  }

  /* Pseudo-elements communs : border qui suit le curseur */
  .glow-card::before,
  .glow-card::after {
    content: '';
    position: absolute;
    inset: calc(var(--gc-border) * -1px);
    border-radius: calc((var(--gc-radius) + var(--gc-border)) * 1px);
    pointer-events: none;
    border: calc(var(--gc-border) * 1px) solid transparent;
    background-attachment: fixed;
    background-size: 100% 100%;
    background-position: 50% 50%;
    background-repeat: no-repeat;
    -webkit-mask:
      linear-gradient(transparent, transparent),
      linear-gradient(white, white);
    -webkit-mask-clip: padding-box, border-box;
    -webkit-mask-composite: source-in;
    mask:
      linear-gradient(transparent, transparent),
      linear-gradient(white, white);
    mask-clip: padding-box, border-box;
    mask-composite: intersect;
    transition: opacity 200ms ease;
    opacity: 0;
  }

  /* Glow colore (matiere) */
  .glow-card::before {
    background-image: radial-gradient(
      calc(var(--gc-size) * 1px) calc(var(--gc-size) * 1px)
        at calc(var(--glow-x, 0) * 1px) calc(var(--glow-y, 0) * 1px),
      hsl(
          calc(var(--gc-base) + (var(--glow-xp, 0) * var(--gc-spread))) 100% 60% /
            0.9
        ),
      transparent 100%
    );
    filter: brightness(1.6);
  }

  /* Coeur lumineux blanc (highlight) */
  .glow-card::after {
    background-image: radial-gradient(
      calc(var(--gc-size) * 0.5px) calc(var(--gc-size) * 0.5px)
        at calc(var(--glow-x, 0) * 1px) calc(var(--glow-y, 0) * 1px),
      hsl(0 0% 100% / 0.85),
      transparent 100%
    );
  }

  /* Activation au hover seulement */
  .glow-card:hover::before,
  .glow-card:hover::after {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .glow-card::before,
    .glow-card::after {
      transition: none;
    }
  }
</style>

<script>
  // Listener global unique : met a jour --glow-x/--glow-y sur :root
  // Astro deduplique automatiquement les <script> hoists, donc un seul listener
  // meme si N cards sont sur la page.
  if (!(window as any).__glowCardAttached) {
    (window as any).__glowCardAttached = true;
    let raf = 0;
    let pendingX = 0;
    let pendingY = 0;
    document.addEventListener(
      'pointermove',
      (e) => {
        pendingX = e.clientX;
        pendingY = e.clientY;
        if (raf) return;
        raf = requestAnimationFrame(() => {
          const root = document.documentElement;
          root.style.setProperty('--glow-x', pendingX.toFixed(0));
          root.style.setProperty('--glow-y', pendingY.toFixed(0));
          root.style.setProperty(
            '--glow-xp',
            (pendingX / window.innerWidth).toFixed(3),
          );
          root.style.setProperty(
            '--glow-yp',
            (pendingY / window.innerHeight).toFixed(3),
          );
          raf = 0;
        });
      },
      { passive: true },
    );
  }
</script>
