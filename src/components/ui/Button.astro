---
/**
 * Bouton Agence Simple v2.
 * variant 'bleu' = CTA principal hero/mantra (bleu vif rare et precieux).
 * variant 'primary' = encre, usage standard.
 * variant 'secondary' = bordure encre transparente, usage low-emphasis.
 * variant 'ghost' = lien souligne sobre.
 */
interface Props {
  href?: string;
  variant?: 'bleu' | 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  external?: boolean;
  class?: string;
  ariaLabel?: string;
}

type Variant = NonNullable<Props['variant']>;
type Size = NonNullable<Props['size']>;

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  external = false,
  class: className = '',
  ariaLabel,
} = Astro.props as Props;

const variants: Record<Variant, string> = {
  bleu: 'bg-(--color-bleu) text-white hover:bg-(--color-encre) focus-visible:bg-(--color-encre)',
  primary: 'bg-(--color-encre) text-(--color-creme) hover:bg-(--color-bleu) focus-visible:bg-(--color-bleu)',
  secondary: 'bg-transparent text-(--color-encre) border border-(--color-encre) hover:bg-(--color-encre) hover:text-(--color-creme)',
  ghost: 'bg-transparent text-(--color-encre) underline underline-offset-4 decoration-(--color-encre)/30 hover:decoration-(--color-bleu) hover:text-(--color-bleu)',
};

const sizes: Record<Size, string> = {
  sm: 'px-4 py-2 text-(length:--text-caption)',
  md: 'px-6 py-3 text-(length:--text-body)',
  lg: 'px-8 py-4 text-(length:--text-body-lg)',
};

const baseClasses = `inline-flex items-center justify-center gap-2 rounded-full font-semibold transition-colors duration-200 ${variants[variant]} ${sizes[size]} ${className}`;
const Tag = href ? 'a' : 'button';
const externalProps = external ? { rel: 'noopener noreferrer', target: '_blank' } : {};
---

<Tag
  class={baseClasses}
  href={href}
  type={!href ? type : undefined}
  aria-label={ariaLabel}
  {...externalProps}
>
  <slot />
</Tag>
