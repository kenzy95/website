---
/**
 * Liquid Glass Button (inspire Apple Tahoe / 21st.dev easemize).
 *
 * Effet : verre frost via backdrop-filter blur + saturate + box-shadow multi-inset
 * (top highlight, bottom shadow, edge glow). Simulation du rendu liquid glass
 * sans le SVG displacement map externe (asset binaire dependence).
 *
 * Astro pur. Marche sur Chrome / Safari / Edge / Firefox. Aspect "verre liquide"
 * convaincant grace aux 9 inset shadows superposees + backdrop blur.
 */

interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  size?: 'sm' | 'md' | 'lg';
  glassColor?: string;
  withArrow?: boolean;
  external?: boolean;
  class?: string;
  ariaLabel?: string;
  id?: string;
}

type Size = NonNullable<Props['size']>;

const {
  href,
  type = 'button',
  size = 'md',
  glassColor = 'rgba(255, 255, 255, 0.08)',
  withArrow = false,
  external = false,
  class: className = '',
  ariaLabel,
  id,
} = Astro.props as Props;

const sizes: Record<Size, string> = {
  sm: 'glass-btn--sm',
  md: 'glass-btn--md',
  lg: 'glass-btn--lg',
};

const Tag = href ? 'a' : 'button';
const externalProps = external ? { rel: 'noopener noreferrer', target: '_blank' } : {};
---

<Tag
  class:list={['glass-btn', sizes[size], className]}
  href={href}
  type={!href ? type : undefined}
  id={id}
  aria-label={ariaLabel}
  style={`--glass-color:${glassColor};`}
  {...externalProps}
>
  <span class="glass-btn__lens" aria-hidden="true"></span>
  <span class="glass-btn__text">
    <slot />
    {
      withArrow && (
        <svg
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="glass-btn__arrow"
          aria-hidden="true"
        >
          <line x1="1" y1="7" x2="13" y2="7" />
          <polyline points="7 1 13 7 7 13" />
        </svg>
      )
    }
  </span>
</Tag>

<style>
  .glass-btn {
    position: relative;
    isolation: isolate;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: -0.005em;
    color: var(--color-creme);
    text-decoration: none;
    border: none;
    background: transparent;
    border-radius: 9999px;
    cursor: pointer;
    transition: transform 300ms cubic-bezier(0.25, 1, 0.5, 1);
    outline: none;
  }
  .glass-btn--sm { padding: 0.625rem 1.25rem; font-size: 0.875rem; }
  .glass-btn--md { padding: 0.875rem 1.625rem; font-size: 1rem; }
  .glass-btn--lg { padding: 1rem 2rem; font-size: 1.0625rem; }

  .glass-btn:focus-visible {
    box-shadow: 0 0 0 3px rgba(30, 144, 255, 0.5);
  }

  @media (hover: hover) {
    .glass-btn:hover:not(:disabled) {
      transform: scale(1.03);
    }
    .glass-btn:hover:not(:disabled) .glass-btn__lens {
      background-color: color-mix(in srgb, var(--glass-color) 100%, white 8%);
    }
  }
  .glass-btn:active:not(:disabled) { transform: scale(0.97); }

  /* LENS : couche vide derriere le texte, capte le backdrop pour effet verre */
  .glass-btn__lens {
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    background-color: var(--glass-color);
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
    box-shadow:
      /* Bordure subtile */
      inset 0 0 0 1px rgba(255, 255, 255, 0.12),
      /* Highlights top : effet "lentille de verre" qui capte la lumiere */
      inset 1.8px 3px 0 -2px rgba(255, 255, 255, 0.5),
      inset -2px -2px 0 -2px rgba(255, 255, 255, 0.4),
      inset -3px -8px 1px -6px rgba(255, 255, 255, 0.3),
      /* Ombres internes : profondeur */
      inset -0.3px -1px 4px 0 rgba(0, 0, 0, 0.15),
      inset -1.5px 2.5px 0 -2px rgba(0, 0, 0, 0.22),
      inset 0 3px 4px -2px rgba(0, 0, 0, 0.22),
      inset 2px -6.5px 1px -4px rgba(0, 0, 0, 0.12),
      /* Ombres externes : flottement */
      0 1px 5px 0 rgba(0, 0, 0, 0.12),
      0 6px 16px 0 rgba(0, 0, 0, 0.14);
    transition: background-color 400ms cubic-bezier(1, 0, 0.4, 1);
  }

  .glass-btn__text {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: inherit;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    user-select: none;
  }

  .glass-btn__arrow {
    transition: transform 300ms cubic-bezier(0.25, 1, 0.5, 1);
  }
  .glass-btn:hover .glass-btn__arrow {
    transform: translateX(2px);
  }
</style>
