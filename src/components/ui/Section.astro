---
type Spacing = 'sm' | 'md' | 'lg' | 'xl';
type Bg = 'creme' | 'encre' | 'bleu-soft' | 'transparent';

interface Props {
  as?: 'section' | 'div' | 'article';
  spacing?: Spacing;
  bg?: Bg;
  id?: string;
  class?: string;
}

const {
  as: Tag = 'section',
  spacing = 'lg',
  bg = 'transparent',
  id,
  class: className = '',
} = Astro.props as Props;

const spacings: Record<Spacing, string> = {
  sm: 'py-12 sm:py-16',
  md: 'py-16 sm:py-20',
  lg: 'py-20 sm:py-28',
  xl: 'py-28 sm:py-36',
};

const backgrounds: Record<Bg, string> = {
  creme: 'bg-(--color-creme)',
  encre: 'bg-(--color-encre) text-(--color-creme)',
  'bleu-soft': 'bg-(--color-bleu-soft)',
  transparent: '',
};
---

<Tag id={id} class={`${spacings[spacing]} ${backgrounds[bg]} ${className}`}>
  <slot />
</Tag>
