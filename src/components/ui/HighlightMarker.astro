---
/**
 * Surligneur "feutre" orange charte v2.
 * Pour les mots-cles strategiques du hero et du manifeste.
 * Anime au scroll (clip-path reveal) une seule fois.
 */
interface Props {
  color?: 'orange' | 'bleu';
  rotate?: number;
  animated?: boolean;
  class?: string;
}
const { color = 'orange', rotate = -1, animated = true, class: className = '' } = Astro.props as Props;
const bg = color === 'orange' ? 'var(--color-orange)' : 'var(--color-bleu)';
---

<span class:list={['relative inline-block', animated && 'highlight-animated', className]}>
  <span class="relative z-10">
    <slot />
  </span>
  <span
    aria-hidden="true"
    class="highlight-stroke absolute inset-x-[-0.08em] bottom-[0.06em] h-[0.42em] rounded-[3px] z-0"
    style={`background:${bg}; opacity:0.42; transform: rotate(${rotate}deg);`}
  ></span>
</span>

<style>
  .highlight-animated .highlight-stroke {
    animation: highlight-reveal 900ms cubic-bezier(0.6, 0.05, 0.2, 1) 200ms both;
    transform-origin: left center;
  }
  @keyframes highlight-reveal {
    0% { clip-path: inset(0 100% 0 0); }
    100% { clip-path: inset(0 0 0 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .highlight-animated .highlight-stroke { animation: none; }
  }
</style>
