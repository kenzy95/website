---
import Container from './ui/Container.astro';
import LogoWordmark from './ui/LogoWordmark.astro';
import { SITE } from '@lib/site';

const year = new Date().getFullYear();

const linkGroups = [
  {
    title: 'Services',
    links: [
      { href: '/services/prospection-b2b', label: 'Prospection B2B' },
      { href: '/services/cold-email', label: 'Cold email' },
      { href: '/services/linkedin-outreach', label: 'LinkedIn outreach' },
      { href: '/services/sdr-externalise', label: 'SDR externalisé' },
    ],
  },
  {
    title: 'Secteurs',
    links: [
      { href: '/secteurs/saas', label: 'SaaS' },
      { href: '/secteurs/esn', label: 'ESN' },
      { href: '/secteurs/cabinet-conseil', label: 'Cabinet conseil' },
      { href: '/secteurs/scale-up-post-levee', label: 'Scale-up' },
      { href: '/secteurs/agences', label: 'Agences' },
    ],
  },
  {
    title: 'Ressources',
    links: [
      { href: '/cas-clients', label: 'Cas clients' },
      { href: '/blog', label: 'Blog' },
      { href: '/outils/calculateur-cout-sdr-interne-vs-agence', label: 'Coût SDR vs agence' },
      { href: '/outils/calculateur-roi-prospection', label: 'ROI prospection' },
      { href: '/comparatifs/sdr-interne-vs-agence-externalisee', label: 'SDR interne vs agence' },
    ],
  },
  {
    title: 'Agence',
    links: [
      { href: '/methode', label: 'Méthode' },
      { href: '/tarifs', label: 'Tarifs' },
      { href: '/a-propos', label: 'À propos' },
      { href: '/contact', label: 'Contact' },
    ],
  },
];
---

<footer class="bg-(--color-encre) text-(--color-creme) mt-32">
  <Container size="wide" class="py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-10">
      <div class="col-span-2 md:col-span-1">
        <LogoWordmark variant="creme" size="md" />
        <p class="mt-4 text-(--text-small) text-(--color-creme)/70 leading-(--leading-normal)">
          Agence de prospection B2B basée à Paris.
        </p>
        <address class="not-italic mt-6 text-(--text-small) text-(--color-creme)/70 leading-relaxed">
          {SITE.contact.address.street}<br />
          {SITE.contact.address.postalCode} {SITE.contact.address.city}<br />
          <a href={`mailto:${SITE.contact.email}`} class="hover:text-(--color-bleu) underline-offset-4 hover:underline">
            {SITE.contact.email}
          </a>
        </address>
      </div>

      {
        linkGroups.map((group) => (
          <nav aria-label={group.title}>
            <h2 class="text-(--text-small) font-semibold uppercase tracking-wider text-(--color-creme)/60">
              {group.title}
            </h2>
            <ul class="mt-4 space-y-2">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-(--text-small) text-(--color-creme)/85 hover:text-(--color-bleu) transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div class="mt-16 pt-8 border-t border-(--color-creme)/10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-(--text-small) text-(--color-creme)/60">
      <p>© {year} {SITE.legalName} - SIRET {SITE.legal.siret}</p>
      <nav class="flex items-center gap-6">
        <a href="/legal/mentions-legales" class="hover:text-(--color-creme)">Mentions légales</a>
        <a href="/legal/politique-confidentialite" class="hover:text-(--color-creme)">Confidentialité</a>
        <a href={SITE.social.linkedinCompany} rel="noopener noreferrer" target="_blank" class="hover:text-(--color-creme)">
          LinkedIn
        </a>
      </nav>
    </div>
  </Container>
</footer>
