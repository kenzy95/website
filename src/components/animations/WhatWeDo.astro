---
/**
 * Section "Ce qu'on fait" - port exact du pattern Webflow qubix-flowdevz.
 *
 * Mecanique inspectee via Chrome MCP :
 * - Conteneur sticky-service-wrapp (sticky, ~743px de haut)
 * - inner-content-service contient :
 *   - .wrapper-content-service (flex: word + spacer + word) - opacity 0->1, translateY 50->0
 *     - .wrapper-text-heading-service "Ce"
 *     - .wrapper-image-change-service (flex, width 0->462px = largeur sphere)
 *     - .wrapper-text-heading-service "qu'on fait"
 *   - .wrapper-circle-service (absolute centered, opacity 0->1, translateZ -847->0)
 * - outer-main-service contient les 3 cards absolute (opacity 0->1, translateY 20->0)
 *
 * Stages au scroll (--progress 0->1) :
 *   0 -> 0.3 : titre apparait + spacer commence a s'ouvrir
 *   0.2 -> 0.55 : sphere apparait depuis la profondeur Z
 *   0.4 -> 0.7 : card 1 'Strategie' (haut-gauche)
 *   0.5 -> 0.8 : card 2 'Sourcing' (haut-droite)
 *   0.6 -> 0.9 : card 3 'Infrastructure' (bas-centre)
 */
---

<section class="wwd-section" data-scroll-section>
  <div class="wwd-sticky">
    <div class="wwd-perspective">
      {/* Inner content : titre + spacer + titre, le spacer grandit pour ecarter les mots */}
      <div class="wwd-inner">
        <div class="wwd-content">
          <div class="wwd-word-wrap">
            <div class="wwd-word">Ce</div>
          </div>
          <div class="wwd-spacer" aria-hidden="true">
            {/* Sphere DANS le spacer -> toujours alignee entre les 2 mots, peu importe leurs largeurs */}
            <div class="wwd-sphere">
              <div class="wwd-sphere__core"></div>
              <div class="wwd-sphere__ring wwd-sphere__ring--a"></div>
              <div class="wwd-sphere__ring wwd-sphere__ring--b"></div>
              <div class="wwd-sphere__halo"></div>
            </div>
          </div>
          <div class="wwd-word-wrap">
            <div class="wwd-word">qu'on fait pour vous</div>
          </div>
        </div>
      </div>

      {/* 8 cards positionnees autour de la sphere - 4 a gauche (amont/data) + 4 a droite (aval/execution) */}
      <div class="wwd-card wwd-card--1">
        <span class="wwd-card__num">01</span>
        <h3 class="wwd-card__title">Stratégie</h3>
        <p class="wwd-card__body">Définition de l'angle, des avantages à mettre en avant et de la cible précise.</p>
      </div>
      <div class="wwd-card wwd-card--2">
        <span class="wwd-card__num">02</span>
        <h3 class="wwd-card__title">Sourcing &amp; enrichissement</h3>
        <p class="wwd-card__body">Listes de prospects qualifiées, emails pros vérifiés, scoring qualité.</p>
      </div>
      <div class="wwd-card wwd-card--3">
        <span class="wwd-card__num">03</span>
        <h3 class="wwd-card__title">Détection de signaux d'intérêt</h3>
        <p class="wwd-card__body">Levées de fonds, recrutements, changements de poste, intent data : on repère les boîtes prêtes à acheter.</p>
      </div>
      <div class="wwd-card wwd-card--4">
        <span class="wwd-card__num">04</span>
        <h3 class="wwd-card__title">Infrastructure</h3>
        <p class="wwd-card__body">Domaines secondaires, SPF/DKIM/DMARC, warmup, monitoring de la deliverability.</p>
      </div>
      <div class="wwd-card wwd-card--5">
        <span class="wwd-card__num">05</span>
        <h3 class="wwd-card__title">Copywriting</h3>
        <p class="wwd-card__body">Cold emails sur-mesure, séquences de relance, A/B tests continus sur les hooks et angles.</p>
      </div>
      <div class="wwd-card wwd-card--6">
        <span class="wwd-card__num">06</span>
        <h3 class="wwd-card__title">Pilotage des campagnes</h3>
        <p class="wwd-card__body">Lancement, monitoring quotidien des stats, ajustements selon les taux d'ouverture et de réponse.</p>
      </div>
      <div class="wwd-card wwd-card--7">
        <span class="wwd-card__num">07</span>
        <h3 class="wwd-card__title">Qualification &amp; RDV</h3>
        <p class="wwd-card__body">On traite les réponses, qualifie les leads, et place les RDV qualifiés directement dans votre agenda.</p>
      </div>
      <div class="wwd-card wwd-card--8">
        <span class="wwd-card__num">08</span>
        <h3 class="wwd-card__title">Reporting &amp; itérations</h3>
        <p class="wwd-card__body">Bilan mensuel chiffré, recommandations d'itération, A/B tests sur le ciblage et le copy.</p>
      </div>

      {/* Phase 3 : le statement efface tout le reste */}
      <div class="wwd-statement">
        <p class="wwd-statement__text">
          Nous vous générons des
          <span class="wwd-statement__marker">RDV qualifiés</span><br />
          <span class="wwd-statement__accent">Vous faites la vente.</span>
        </p>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    function init() {
      var section = document.querySelector('.wwd-section');
      if (!section) return;
      var ticking = false;
      function update() {
        var rect = section.getBoundingClientRect();
        var vh = window.innerHeight;
        var total = vh + rect.height;
        var traveled = vh - rect.top;
        var p = traveled / total;
        if (p < 0) p = 0;
        if (p > 1) p = 1;
        section.style.setProperty('--progress', p.toFixed(4));
      }
      function onScroll() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(function () {
          update();
          ticking = false;
        });
      }
      update();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style>
  .wwd-section {
    --progress: 0;
    /* Choregraphie 3 phases dans la MEME section sticky (Kenzy 2026-07-05) :
       1. titre + sphere apparaissent -> 2. titre disparait, les 8 services defilent
       un par un -> 3. tout disparait, le statement s'affiche. */
    --p-title: clamp(0, calc(var(--progress) * 8), 1);
    --p-title-out: clamp(0, calc((var(--progress) - 0.2) * 12.5), 1);
    --p-sphere: clamp(0, calc((var(--progress) - 0.06) * 8), 1);
    /* 8 cards en sequence stricte (une apres l'autre) */
    --p-c1: clamp(0, calc((var(--progress) - 0.26) * 16.67), 1);
    --p-c2: clamp(0, calc((var(--progress) - 0.305) * 16.67), 1);
    --p-c3: clamp(0, calc((var(--progress) - 0.35) * 16.67), 1);
    --p-c4: clamp(0, calc((var(--progress) - 0.395) * 16.67), 1);
    --p-c5: clamp(0, calc((var(--progress) - 0.44) * 16.67), 1);
    --p-c6: clamp(0, calc((var(--progress) - 0.485) * 16.67), 1);
    --p-c7: clamp(0, calc((var(--progress) - 0.53) * 16.67), 1);
    --p-c8: clamp(0, calc((var(--progress) - 0.575) * 16.67), 1);
    /* Sortie globale (cards + sphere) puis entree du statement */
    --p-out: clamp(0, calc((var(--progress) - 0.66) * 12.5), 1);
    --p-statement: clamp(0, calc((var(--progress) - 0.70) * 10), 1);
    height: 550vh;
    position: relative;
  }
  .wwd-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .wwd-perspective {
    position: relative;
    width: 100%;
    height: 100%;
    max-width: 1280px;
    margin: 0 auto;
    perspective: 1200px;
  }

  /* Inner : contient le titre + sphere absolute */
  .wwd-inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Titre central : opacity 0->1, translateY 50->0 (stage --p-title) */
  .wwd-content {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.5rem, 2vw, 1.5rem); /* espace minimum entre 'Ce' et 'qu'on fait' meme quand spacer=0 */
    opacity: var(--p-title);
    transform: translateY(calc((1 - var(--p-title)) * 50px));
    z-index: 3;
  }
  .wwd-word-wrap {
    flex-shrink: 0;
    /* Phase 2 : les mots du titre s'effacent, la sphere (dans le spacer) reste */
    opacity: calc(1 - var(--p-title-out));
    transform: translateY(calc(var(--p-title-out) * -30px));
  }
  .wwd-word {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(2rem, 5.5vw, 4.5rem); /* reduit pour que 'qu'on fait pour vous' rentre */
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--color-creme);
    white-space: nowrap;
  }

  /* Spacer central : position relative pour ancrer la sphere DANS lui */
  .wwd-spacer {
    flex-shrink: 0;
    position: relative;
    width: calc(var(--p-sphere) * clamp(10rem, 34vw, 34rem));
    height: clamp(10rem, 34vw, 34rem);
    transition: none;
  }

  /* Sphere absolute centred dans le spacer -> alignement parfait entre les 2 mots */
  .wwd-sphere {
    position: absolute;
    top: 50%;
    left: 50%;
    width: clamp(10rem, 34vw, 34rem);
    height: clamp(10rem, 34vw, 34rem);
    transform: translate(-50%, -50%) translateZ(calc((1 - var(--p-sphere)) * -847px));
    transform-style: preserve-3d;
    opacity: calc(var(--p-sphere) * (1 - var(--p-out)));
    pointer-events: none;
  }

  /* Core : bleu charte vif avec highlight clair en haut-gauche pour effet 3D */
  .wwd-sphere__core {
    position: absolute;
    inset: 18%;
    border-radius: 50%;
    background: radial-gradient(
      circle at 30% 25%,
      #8acaff 0%,
      #1E90FF 40%,
      #0a4d8f 80%,
      #062a52 100%
    );
    box-shadow:
      inset -30px -20px 70px rgba(6, 42, 82, 0.6),
      inset 20px 15px 50px rgba(138, 202, 255, 0.25),
      0 0 60px rgba(30, 144, 255, 0.35);
  }
  .wwd-sphere__ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid rgba(250, 247, 242, 0.25);
  }
  .wwd-sphere__ring--a {
    transform: rotateZ(35deg) rotateY(70deg);
    border-top-color: rgba(250, 247, 242, 0.7);
    border-left-color: rgba(250, 247, 242, 0.5);
  }
  .wwd-sphere__ring--b {
    transform: rotateZ(-35deg) rotateY(70deg);
    border-top-color: rgba(30, 144, 255, 0.85);
    border-right-color: rgba(30, 144, 255, 0.6);
  }
  /* Halo plus large et plus marque : effet 'glow' bleu charte autour de la sphere */
  .wwd-sphere__halo {
    position: absolute;
    inset: -20%;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(30, 144, 255, 0.35) 0%,
      rgba(30, 144, 255, 0.12) 40%,
      transparent 65%
    );
    filter: blur(8px);
  }

  /* Cards absolute autour : opacity 0->1, translateY 20->0 - 4 a gauche + 4 a droite */
  .wwd-card {
    position: absolute;
    max-width: 18rem;
    color: var(--color-creme);
    font-family: var(--font-sans);
    z-index: 1;
  }
  .wwd-card__num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-bleu);
    display: block;
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
  }
  /* Titre des cards : plus gros + couleur bleue charte pour mise en valeur */
  .wwd-card__title {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-bleu);
    letter-spacing: -0.015em;
    margin-bottom: 0.6rem;
    line-height: 1.15;
  }
  .wwd-card__body {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: rgba(250, 247, 242, 0.7);
    max-width: 18rem;
  }

  /* Colonne gauche : cards 1-4 espacees verticalement */
  .wwd-card--1 {
    top: 3%; left: 2%;
    opacity: calc(var(--p-c1) * (1 - var(--p-out)));
    transform: translateY(calc((1 - var(--p-c1)) * 20px));
  }
  .wwd-card--2 {
    top: 27%; left: 2%;
    opacity: calc(var(--p-c3) * (1 - var(--p-out)));
    transform: translateY(calc((1 - var(--p-c3)) * 20px));
  }
  .wwd-card--3 {
    top: 51%; left: 2%;
    opacity: calc(var(--p-c5) * (1 - var(--p-out)));
    transform: translateY(calc((1 - var(--p-c5)) * 20px));
  }
  .wwd-card--4 {
    top: 75%; left: 2%;
    opacity: calc(var(--p-c7) * (1 - var(--p-out)));
    transform: translateY(calc((1 - var(--p-c7)) * 20px));
  }

  /* Colonne droite : cards 5-8 espacees verticalement, alignees a droite */
  .wwd-card--5 {
    top: 3%; right: 2%;
    text-align: right;
    opacity: calc(var(--p-c2) * (1 - var(--p-out)));
    transform: translateY(calc((1 - var(--p-c2)) * 20px));
  }
  .wwd-card--6 {
    top: 27%; right: 2%;
    text-align: right;
    opacity: calc(var(--p-c4) * (1 - var(--p-out)));
    transform: translateY(calc((1 - var(--p-c4)) * 20px));
  }
  .wwd-card--7 {
    top: 51%; right: 2%;
    text-align: right;
    opacity: calc(var(--p-c6) * (1 - var(--p-out)));
    transform: translateY(calc((1 - var(--p-c6)) * 20px));
  }
  .wwd-card--8 {
    top: 75%; right: 2%;
    text-align: right;
    opacity: calc(var(--p-c8) * (1 - var(--p-out)));
    transform: translateY(calc((1 - var(--p-c8)) * 20px));
  }

  @media (max-width: 1024px) {
    .wwd-card { max-width: 14rem; }
    .wwd-card__title { font-size: 1.125rem; }
    .wwd-card__body { font-size: 0.8125rem; }
    .wwd-card__num { font-size: 0.875rem; }
  }
  /* Phase 3 : statement plein cadre */
  .wwd-statement {
    position: absolute;
    inset: 0;
    z-index: 6;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 1.5rem;
    opacity: var(--p-statement);
    transform: translateY(calc((1 - var(--p-statement)) * 40px));
    pointer-events: none;
  }
  .wwd-statement__text {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(2.2rem, 5.5vw, 4.8rem);
    line-height: 1.12;
    letter-spacing: -0.035em;
    color: var(--color-creme);
    max-width: 70rem;
  }
  .wwd-statement__marker {
    position: relative;
    display: inline-block;
  }
  .wwd-statement__marker::before {
    content: '';
    position: absolute;
    inset: 0.55em -0.08em 0.02em;
    background: var(--color-orange);
    opacity: 0.95;
    border-radius: 3px;
    transform: rotate(-1deg);
    z-index: -1;
  }
  .wwd-statement__accent {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    color: var(--color-bleu);
  }

  /* Mobile : on cache les cards (a refaire en grid stack si besoin) */
  @media (max-width: 768px) {
    .wwd-card { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wwd-section {
      --p-title: 1;
      --p-sphere: 1;
      --p-row1: 1;
      --p-row2: 1;
      --p-row3: 1;
      --p-row4: 1;
    }
  }
</style>
