---
/**
 * Section "Ce qu'on fait" - port exact du pattern Webflow qubix-flowdevz.
 *
 * Mecanique inspectee via Chrome MCP :
 * - Conteneur sticky-service-wrapp (sticky, ~743px de haut)
 * - inner-content-service contient :
 *   - .wrapper-content-service (flex: word + spacer + word) - opacity 0->1, translateY 50->0
 *     - .wrapper-text-heading-service "Ce"
 *     - .wrapper-image-change-service (flex, width 0->462px = largeur sphere)
 *     - .wrapper-text-heading-service "qu'on fait"
 *   - .wrapper-circle-service (absolute centered, opacity 0->1, translateZ -847->0)
 * - outer-main-service contient les 3 cards absolute (opacity 0->1, translateY 20->0)
 *
 * Stages au scroll (--progress 0->1) :
 *   0 -> 0.3 : titre apparait + spacer commence a s'ouvrir
 *   0.2 -> 0.55 : sphere apparait depuis la profondeur Z
 *   0.4 -> 0.7 : card 1 'Strategie' (haut-gauche)
 *   0.5 -> 0.8 : card 2 'Sourcing' (haut-droite)
 *   0.6 -> 0.9 : card 3 'Infrastructure' (bas-centre)
 */
---

<section class="wwd-section" data-scroll-section>
  <div class="wwd-sticky">
    <div class="wwd-perspective">
      {/* Inner content : titre + spacer + titre, le spacer grandit pour ecarter les mots */}
      <div class="wwd-inner">
        <div class="wwd-content">
          <div class="wwd-word-wrap">
            <div class="wwd-word">Ce</div>
          </div>
          <div class="wwd-spacer" aria-hidden="true">
            {/* Sphere DANS le spacer -> toujours alignee entre les 2 mots, peu importe leurs largeurs */}
            <div class="wwd-sphere">
              <div class="wwd-sphere__core"></div>
              <div class="wwd-sphere__ring wwd-sphere__ring--a"></div>
              <div class="wwd-sphere__ring wwd-sphere__ring--b"></div>
              <div class="wwd-sphere__halo"></div>
            </div>
          </div>
          <div class="wwd-word-wrap">
            <div class="wwd-word">qu'on fait pour vous</div>
          </div>
        </div>
      </div>

      {/* 3 cards absolute autour de la sphere */}
      <div class="wwd-card wwd-card--1">
        <span class="wwd-card__num">01</span>
        <h3 class="wwd-card__title">Stratégie</h3>
        <p class="wwd-card__body">On définit avec vous l'angle, les avantages à mettre en avant et la cible précise.</p>
      </div>
      <div class="wwd-card wwd-card--2">
        <span class="wwd-card__num">02</span>
        <h3 class="wwd-card__title">Sourcing &amp; enrichissement</h3>
        <p class="wwd-card__body">Listes de prospects qualifiées, emails pros vérifiés, scoring qualité.</p>
      </div>
      <div class="wwd-card wwd-card--3">
        <span class="wwd-card__num">03</span>
        <h3 class="wwd-card__title">Infrastructure</h3>
        <p class="wwd-card__body">Domaines secondaires, SPF/DKIM/DMARC, warmup, monitoring deliverability.</p>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    function init() {
      var section = document.querySelector('.wwd-section');
      if (!section) return;
      var ticking = false;
      function update() {
        var rect = section.getBoundingClientRect();
        var vh = window.innerHeight;
        var total = vh + rect.height;
        var traveled = vh - rect.top;
        var p = traveled / total;
        if (p < 0) p = 0;
        if (p > 1) p = 1;
        section.style.setProperty('--progress', p.toFixed(4));
      }
      function onScroll() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(function () {
          update();
          ticking = false;
        });
      }
      update();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style>
  .wwd-section {
    --progress: 0;
    /* Stages : tous calcules a partir de --progress, clampes [0,1] */
    --p-title: clamp(0, calc(var(--progress) * 3.33), 1);
    --p-sphere: clamp(0, calc((var(--progress) - 0.2) * 2.857), 1);
    --p-c1: clamp(0, calc((var(--progress) - 0.4) * 3.33), 1);
    --p-c2: clamp(0, calc((var(--progress) - 0.5) * 3.33), 1);
    --p-c3: clamp(0, calc((var(--progress) - 0.6) * 3.33), 1);
    height: 300vh;
    position: relative;
  }
  .wwd-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .wwd-perspective {
    position: relative;
    width: 100%;
    height: 100%;
    max-width: 1280px;
    margin: 0 auto;
    perspective: 1200px;
  }

  /* Inner : contient le titre + sphere absolute */
  .wwd-inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Titre central : opacity 0->1, translateY 50->0 (stage --p-title) */
  .wwd-content {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.5rem, 2vw, 1.5rem); /* espace minimum entre 'Ce' et 'qu'on fait' meme quand spacer=0 */
    opacity: var(--p-title);
    transform: translateY(calc((1 - var(--p-title)) * 50px));
    z-index: 3;
  }
  .wwd-word-wrap {
    flex-shrink: 0;
  }
  .wwd-word {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(2rem, 5.5vw, 4.5rem); /* reduit pour que 'qu'on fait pour vous' rentre */
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--color-creme);
    white-space: nowrap;
  }

  /* Spacer central : position relative pour ancrer la sphere DANS lui */
  .wwd-spacer {
    flex-shrink: 0;
    position: relative;
    width: calc(var(--p-sphere) * clamp(8rem, 28vw, 28rem));
    height: clamp(8rem, 28vw, 28rem);
    transition: none;
  }

  /* Sphere absolute centred dans le spacer -> alignement parfait entre les 2 mots */
  .wwd-sphere {
    position: absolute;
    top: 50%;
    left: 50%;
    width: clamp(8rem, 28vw, 28rem);
    height: clamp(8rem, 28vw, 28rem);
    transform: translate(-50%, -50%) translateZ(calc((1 - var(--p-sphere)) * -847px));
    transform-style: preserve-3d;
    opacity: var(--p-sphere);
    pointer-events: none;
  }

  .wwd-sphere__core {
    position: absolute;
    inset: 18%;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 25%, #2a3b6a 0%, #0a132e 55%, #060c1f 100%);
    box-shadow:
      inset 0 0 60px rgba(0, 0, 0, 0.8),
      inset -20px -10px 50px rgba(0, 0, 0, 0.4);
  }
  .wwd-sphere__ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px solid rgba(250, 247, 242, 0.18);
  }
  .wwd-sphere__ring--a {
    transform: rotateZ(35deg) rotateY(70deg);
    border-top-color: rgba(250, 247, 242, 0.45);
    border-left-color: rgba(250, 247, 242, 0.35);
  }
  .wwd-sphere__ring--b {
    transform: rotateZ(-35deg) rotateY(70deg);
    border-top-color: rgba(30, 144, 255, 0.5);
    border-right-color: rgba(30, 144, 255, 0.35);
  }
  .wwd-sphere__halo {
    position: absolute;
    inset: -10%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(30, 144, 255, 0.18) 0%, transparent 55%);
  }

  /* Cards absolute autour : opacity 0->1, translateY 20->0 */
  .wwd-card {
    position: absolute;
    max-width: 21rem;
    color: var(--color-creme);
    font-family: var(--font-sans);
    z-index: 1;
  }
  .wwd-card__num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--color-bleu);
    display: block;
    margin-bottom: 0.4rem;
  }
  .wwd-card__title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-creme);
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
  }
  .wwd-card__body {
    font-size: 0.875rem;
    line-height: 1.55;
    color: rgba(250, 247, 242, 0.55);
    max-width: 18rem;
  }

  /* Card 1 : top-left (position equivalente au qubix : top 30px / left 0) */
  .wwd-card--1 {
    top: 8%;
    left: 4%;
    opacity: var(--p-c1);
    transform: translateY(calc((1 - var(--p-c1)) * 20px));
  }
  /* Card 2 : top-right (position equivalente : top 0 / right 0) */
  .wwd-card--2 {
    top: 14%;
    right: 4%;
    text-align: right;
    opacity: var(--p-c2);
    transform: translateY(calc((1 - var(--p-c2)) * 20px));
  }
  /* Card 3 : bottom-center (position equivalente : bottom 50 / centered) */
  .wwd-card--3 {
    bottom: 10%;
    left: 50%;
    text-align: center;
    opacity: var(--p-c3);
    transform: translate(-50%, calc((1 - var(--p-c3)) * 20px));
  }

  @media (max-width: 768px) {
    .wwd-card { max-width: 14rem; }
    .wwd-card__title { font-size: 1rem; }
    .wwd-card__body { font-size: 0.8125rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wwd-section {
      --p-title: 1;
      --p-sphere: 1;
      --p-c1: 1;
      --p-c2: 1;
      --p-c3: 1;
    }
  }
</style>
