---
/**
 * Story Scroll - empilement vertical de "stories" en card-stack scroll.
 *
 * Pattern : container vertical, chaque StorySection enfant est sticky top:0
 * height:100vh. La 1re reste pinnee pendant que la 2e arrive par-dessus,
 * etc. L'inner de chaque section pivote depuis 30deg -> 0deg au passage.
 *
 * Implementation : scroll listener vanilla qui update CSS var --rotate
 * sur l'inner de chaque section enfant. Zero GSAP, zero React, zero ScrollTrigger.
 */

interface Props {
  ariaLabel?: string;
  class?: string;
}

const { ariaLabel = 'Story scroll', class: className = '' } = Astro.props as Props;
---

<div class:list={['story-scroll', className]} aria-label={ariaLabel} data-story-scroll>
  <slot />
</div>

<script is:inline>
  (function () {
    function init() {
      var roots = document.querySelectorAll('[data-story-scroll]');
      if (!roots.length) return;
      var ticking = false;

      function update() {
        roots.forEach(function (root) {
          var sections = root.querySelectorAll('[data-story-section]');
          var vh = window.innerHeight;
          sections.forEach(function (section, i) {
            // Z-index incremental (scoping CSS Astro casse :nth-child cross-component)
            section.style.zIndex = String(i + 1);
            var inner = section.querySelector('.story-section__inner');
            if (!inner) return;
            if (i === 0) {
              inner.style.setProperty('--rotate', '0deg');
              return;
            }
            var rect = section.getBoundingClientRect();
            // Pattern GSAP : rotation 30deg quand top=bottom-viewport (entree)
            //                rotation 0deg quand top=25% du viewport
            var startY = vh;       // rect.top = vh → debut animation (rotation 30)
            var endY = vh * 0.25;  // rect.top = vh*0.25 → fin animation (rotation 0)
            var range = startY - endY;
            var traveled = startY - rect.top;
            var p = traveled / range;
            if (p < 0) p = 0;
            if (p > 1) p = 1;
            var rotate = 30 * (1 - p);
            inner.style.setProperty('--rotate', rotate.toFixed(2) + 'deg');
          });
        });
      }

      function onScroll() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(function () {
          update();
          ticking = false;
        });
      }

      update();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style>
  .story-scroll {
    position: relative;
    width: 100%;
    /* PAS d'overflow hidden : casserait le sticky des sections enfants */
  }
  /* Z-index incrementiel pour empiler les sections successives */
  .story-scroll > [data-story-section]:nth-child(1) { z-index: 1; }
  .story-scroll > [data-story-section]:nth-child(2) { z-index: 2; }
  .story-scroll > [data-story-section]:nth-child(3) { z-index: 3; }
  .story-scroll > [data-story-section]:nth-child(4) { z-index: 4; }
  .story-scroll > [data-story-section]:nth-child(5) { z-index: 5; }
  .story-scroll > [data-story-section]:nth-child(6) { z-index: 6; }
</style>
