---
/**
 * Container Scroll Animation - reproduction exacte de l'effet Aceternity UI.
 * Le container se redresse progressivement en 3D, synchronise au scroll.
 *
 * Implementation : scroll listener vanilla + CSS variable --progress (0->1)
 * + transform calc(). Zero framer-motion, zero React, marche partout.
 *
 * Section 200vh -> sticky 100vh -> card animee selon position de la section
 * dans le viewport. Identique a la demo Aceternity.
 */
---

<section class="acc-scroll" data-scroll-section>
  <div class="acc-scroll__sticky">
    <div class="acc-scroll__perspective">
      <div class="acc-scroll__card">
        <div class="acc-scroll__inner">
          <slot />
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    function init() {
      var sections = document.querySelectorAll('[data-scroll-section]');
      if (!sections.length) return;
      var ticking = false;

      function update() {
        sections.forEach(function (section) {
          var rect = section.getBoundingClientRect();
          var vh = window.innerHeight;
          // Progress 0 quand top.section touche bottom.viewport (entree)
          // Progress 1 quand bottom.section touche top.viewport (sortie)
          var total = vh + rect.height;
          var traveled = vh - rect.top;
          var p = traveled / total;
          if (p < 0) p = 0;
          if (p > 1) p = 1;
          section.style.setProperty('--progress', p.toFixed(4));
        });
      }

      function onScroll() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(function () {
          update();
          ticking = false;
        });
      }

      update();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style>
  .acc-scroll {
    /* Hauteur 200vh : 1 vh d'animation, le sticky se decolle ensuite */
    height: 200vh;
    position: relative;
    padding: 0 0.5rem;
    --progress: 0;
  }
  @media (min-width: 768px) {
    .acc-scroll { padding: 0 2rem; }
  }

  .acc-scroll__sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .acc-scroll__perspective {
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
    perspective: 1200px;
  }

  .acc-scroll__card {
    max-width: 72rem;
    margin: 0 auto;
    height: 28rem;
    width: 100%;
    border: 4px solid #1a2750;
    background: #0F1B3F;
    border-radius: 30px;
    padding: 0.5rem;
    box-shadow:
      0 9px 20px rgba(0, 0, 0, 0.35),
      0 37px 37px rgba(0, 0, 0, 0.3),
      0 84px 50px rgba(0, 0, 0, 0.2),
      0 149px 60px rgba(0, 0, 0, 0.08);
    transform-style: preserve-3d;
    will-change: transform;
    /* Transform pilote par --progress (0 = etat initial, 1 = etat final) */
    --rotate: calc((1 - var(--progress)) * 22deg);
    --scale: calc(0.9 + var(--progress) * 0.15);
    --ty: calc((1 - var(--progress)) * 60px);
    transform: rotateX(var(--rotate)) scale(var(--scale)) translateY(var(--ty));
  }
  @media (min-width: 768px) {
    .acc-scroll__card {
      height: 36rem;
      padding: 0.75rem;
    }
  }

  .acc-scroll__inner {
    height: 100%;
    width: 100%;
    overflow: hidden;
    border-radius: 20px;
    background: #FAF7F2;
  }

  @media (prefers-reduced-motion: reduce) {
    .acc-scroll__card {
      transform: rotateX(0deg) scale(1) translateY(0);
    }
  }
</style>
