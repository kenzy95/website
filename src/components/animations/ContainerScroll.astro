---
/**
 * Container Scroll Animation - reproduction PIXEL-PERFECT de la demo Aceternity UI.
 * Structure HTML/CSS et transforms identiques au code original framer-motion :
 *   - Container h-[60rem] md:h-[80rem] flex center, padding p-2 md:p-20
 *   - Inner py-10 md:py-40, perspective 1000px
 *   - Header translateY [0, -100]
 *   - Card rotateX [20, 0], scale [1.05, 1] (desktop) / [0.7, 0.9] (mobile)
 *
 * Implementation : scroll listener vanilla + CSS variable --progress (0->1)
 * Equivalent fonctionnel et visuel a useScroll/useTransform de framer-motion.
 * Pas de React, pas de framer-motion : marche 100% du temps.
 */

interface Props {
  titleComponent?: string;
}
const { titleComponent } = Astro.props as Props;
---

<div class="acc-container" data-acc-scroll>
  <div class="acc-inner">
    {titleComponent && (
      <div class="acc-header">
        <Fragment set:html={titleComponent} />
      </div>
    )}
    <div class="acc-card">
      <div class="acc-card__inner">
        <slot />
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    function init() {
      var sections = document.querySelectorAll('[data-acc-scroll]');
      if (!sections.length) return;
      var ticking = false;

      function update() {
        sections.forEach(function (s) {
          var rect = s.getBoundingClientRect();
          var vh = window.innerHeight;
          // useScroll defaut : 0 quand top.target = bottom.viewport
          //                    1 quand bottom.target = top.viewport
          var total = vh + rect.height;
          var traveled = vh - rect.top;
          var p = traveled / total;
          if (p < 0) p = 0;
          if (p > 1) p = 1;
          s.style.setProperty('--progress', p.toFixed(4));
          // anim-progress : boost x2.5, clamped [0, 1]. Anim termine a progress 0.4.
          var ap = p * 2.5;
          if (ap > 1) ap = 1;
          s.style.setProperty('--anim-progress', ap.toFixed(4));
        });
      }

      function onScroll() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(function () {
          update();
          ticking = false;
        });
      }

      update();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style>
  /* Container : hauteur compacte. L'anim termine vite (--anim-progress = progress * 2.5 clamped) */
  .acc-container {
    height: 45rem;
    display: flex;
    align-items: flex-start; /* card colle en haut, pas centre */
    justify-content: center;
    position: relative;
    padding: 0.5rem;
    padding-top: 1rem;
    --progress: 0;
    --anim-progress: 0;
  }
  @media (min-width: 768px) {
    .acc-container {
      height: 55rem;
      padding: 1rem 5rem 5rem;
    }
  }

  /* Inner : padding reduit, perspective preservee */
  .acc-inner {
    padding: 0;
    width: 100%;
    position: relative;
    perspective: 1000px;
  }
  @media (min-width: 768px) {
    .acc-inner { padding: 1rem 0 0; }
  }

  /* Header : translateY [0, -100] selon scrollYProgress */
  .acc-header {
    max-width: 64rem;
    margin: 0 auto;
    text-align: center;
    transform: translateY(calc(var(--progress) * -100px));
  }

  /* Card : -mt-12, h-[30rem] md:h-[40rem], rotateX [20, 0], scale [1.05, 1] */
  .acc-card {
    max-width: 64rem;
    margin: 0 auto;
    margin-top: -3rem;
    height: 30rem;
    width: 100%;
    border: 4px solid #1a2750;
    background: #0F1B3F;
    border-radius: 30px;
    padding: 0.5rem;
    box-shadow:
      0 9px 20px rgba(0, 0, 0, 0.3),
      0 37px 37px rgba(0, 0, 0, 0.26),
      0 84px 50px rgba(0, 0, 0, 0.15),
      0 149px 60px rgba(0, 0, 0, 0.04);
    transform-style: preserve-3d;
    will-change: transform;
    /* rotateX (35 -> 0) + scale (1.05 -> 1) sur desktop : utilise --anim-progress (boost x2.5, clamped) pour rabattre plus vite */
    transform:
      rotateX(calc((1 - var(--anim-progress)) * 35deg))
      scale(calc(1.05 - var(--anim-progress) * 0.05));
  }
  @media (min-width: 768px) {
    .acc-card {
      height: 40rem;
      padding: 1.5rem;
    }
  }
  /* Mobile : scale [0.7, 0.9] (Aceternity) - meme boost --anim-progress */
  @media (max-width: 768px) {
    .acc-card {
      transform:
        rotateX(calc((1 - var(--anim-progress)) * 35deg))
        scale(calc(0.7 + var(--anim-progress) * 0.2));
    }
  }

  .acc-card__inner {
    height: 100%;
    width: 100%;
    overflow: hidden;
    border-radius: 16px;
    background: #FAF7F2;
  }
  @media (min-width: 768px) {
    .acc-card__inner { border-radius: 20px; padding: 1rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .acc-card {
      transform: rotateX(0deg) scale(1) !important;
    }
    .acc-header {
      transform: translateY(-50px) !important;
    }
  }
</style>
