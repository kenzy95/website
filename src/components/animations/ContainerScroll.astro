---
/**
 * Container Scroll - reveal 3D via IntersectionObserver + CSS transitions.
 * Approche zero-echec : marche dans tous les browsers et tous les contextes
 * (HMR, devtools ouvertes, env restrictifs).
 * L'element se redresse en 3D quand il entre dans le viewport.
 */
---

<div class="container-scroll-wrapper" style="perspective: 1400px;">
  <div class="container-scroll-card" data-card-reveal>
    <div class="container-scroll-inner">
      <slot />
    </div>
  </div>
</div>

<script is:inline>
  // is:inline pour garantir l'execution immediate, sans bundle Astro.
  (function () {
    function reveal() {
      var cards = document.querySelectorAll('[data-card-reveal]');
      if (!cards.length) return;
      // Check immediat : si la card est deja visible ou passee au mount
      // (cas reload mid-page), on revele direct sans attendre l'observer.
      cards.forEach(function (c) {
        var r = c.getBoundingClientRect();
        var vh = window.innerHeight;
        if (r.top < vh * 0.85 && r.bottom > 0) {
          c.classList.add('in-view');
        } else if (r.top < 0) {
          // Card deja passee au-dessus
          c.classList.add('in-view');
        }
      });
      if (!('IntersectionObserver' in window)) {
        cards.forEach(function (c) { c.classList.add('in-view'); });
        return;
      }
      var obs = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('in-view');
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
      );
      cards.forEach(function (c) {
        if (!c.classList.contains('in-view')) obs.observe(c);
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', reveal);
    } else {
      reveal();
    }
  })();
</script>

<style>
  .container-scroll-wrapper {
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
    padding: 4rem 0.5rem;
  }
  @media (min-width: 768px) {
    .container-scroll-wrapper { padding: 6rem 2rem; }
  }

  .container-scroll-card {
    max-width: 72rem;
    margin: 0 auto;
    height: 28rem;
    width: 100%;
    border: 4px solid #1a2750;
    background: #0F1B3F;
    border-radius: 30px;
    padding: 0.5rem;
    box-shadow:
      0 9px 20px rgba(0, 0, 0, 0.35),
      0 37px 37px rgba(0, 0, 0, 0.3),
      0 84px 50px rgba(0, 0, 0, 0.2),
      0 149px 60px rgba(0, 0, 0, 0.08);
    transform-style: preserve-3d;
    /* Etat initial : incline + descendu + transparent */
    transform: rotateX(28deg) scale(0.88) translateY(60px);
    opacity: 0;
    transition:
      transform 1.4s cubic-bezier(0.22, 0.8, 0.22, 1),
      opacity 0.9s cubic-bezier(0.22, 0.8, 0.22, 1);
    will-change: transform, opacity;
  }
  @media (min-width: 768px) {
    .container-scroll-card {
      height: 36rem;
      padding: 0.75rem;
    }
  }

  .container-scroll-card.in-view {
    transform: rotateX(0deg) scale(1) translateY(0);
    opacity: 1;
  }

  .container-scroll-inner {
    height: 100%;
    width: 100%;
    overflow: hidden;
    border-radius: 20px;
    background: #FAF7F2;
  }

  @media (prefers-reduced-motion: reduce) {
    .container-scroll-card {
      transition: opacity 0.3s linear;
      transform: rotateX(0deg) scale(1) translateY(0);
    }
  }
</style>
