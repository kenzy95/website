---
/**
 * Container Scroll Animation - CSS pur via animation-timeline: view().
 * Zero JS, performance native, marche meme sans React.
 * Le container se redresse en 3D selon sa position dans le viewport.
 *
 * Support : Chrome 115+, Edge 115+, Safari 26+, Opera 101+.
 * Fallback Firefox : etat final (plat) directement (graceful degradation).
 */
---

<section class="container-scroll-section">
  <div class="container-scroll-spacer">
    <div class="container-scroll-wrapper" style="perspective: 1200px;">
      <div class="container-scroll-card">
        <div class="container-scroll-inner">
          <slot />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .container-scroll-section {
    height: 220vh;
    position: relative;
    padding: 0 0.5rem;
  }
  @media (min-width: 768px) {
    .container-scroll-section {
      padding: 0 2rem;
    }
  }

  .container-scroll-spacer {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
  }

  .container-scroll-wrapper {
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
    view-timeline-name: --card-view;
    view-timeline-axis: block;
  }

  .container-scroll-card {
    max-width: 72rem;
    margin: 0 auto;
    height: 28rem;
    width: 100%;
    border: 4px solid #1a2750;
    background: #0F1B3F;
    border-radius: 30px;
    padding: 0.5rem;
    box-shadow:
      0 9px 20px rgba(0, 0, 0, 0.35),
      0 37px 37px rgba(0, 0, 0, 0.3),
      0 84px 50px rgba(0, 0, 0, 0.2),
      0 149px 60px rgba(0, 0, 0, 0.08);
    transform-style: preserve-3d;
    will-change: transform;
    /* Etat final (fallback Firefox / no support) */
    transform: rotateX(0deg) scale(1);
  }
  @media (min-width: 768px) {
    .container-scroll-card {
      height: 36rem;
      padding: 0.75rem;
    }
  }

  .container-scroll-inner {
    height: 100%;
    width: 100%;
    overflow: hidden;
    border-radius: 20px;
    background: #FAF7F2;
  }

  /* Animation scroll-driven native - Chrome/Edge/Safari recents */
  @supports (animation-timeline: scroll()) {
    .container-scroll-card {
      animation: card-rise linear both;
      animation-timeline: scroll(root block);
      animation-range: 200px 1400px;
    }
    @keyframes card-rise {
      from {
        transform: rotateX(22deg) scale(0.92) translateY(40px);
      }
      to {
        transform: rotateX(0deg) scale(1) translateY(0);
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .container-scroll-card {
      animation: none !important;
      transform: rotateX(0deg) scale(1) !important;
    }
  }
</style>
