---
/**
 * Story Section - enfant de StoryScroll.
 *
 * Section sticky top:0 height:100vh. La 1re est pinnee pendant que la 2e
 * arrive par-dessus. L'inner pivote depuis 30deg -> 0deg via CSS var
 * --rotate pilotee par le scroll listener du parent StoryScroll.
 */

interface Props {
  bg?: 'creme' | 'encre' | 'orange-soft' | 'bleu-soft' | 'custom';
  customBg?: string;
  ariaLabel?: string;
  class?: string;
}

type Bg = NonNullable<Props['bg']>;

const {
  bg = 'creme',
  customBg,
  ariaLabel,
  class: className = '',
} = Astro.props as Props;

const bgClasses: Record<Bg, string> = {
  creme: 'story-section--creme',
  encre: 'story-section--encre',
  'orange-soft': 'story-section--orange',
  'bleu-soft': 'story-section--bleu',
  custom: '',
};
---

<section
  data-story-section
  aria-label={ariaLabel}
  class:list={['story-section', bgClasses[bg], className]}
  style={customBg ? `background:${customBg}` : undefined}
>
  <div class="story-section__inner">
    <slot />
  </div>
</section>

<style>
  /* Pattern card-stack : sticky top:0 + height fixe. La section reste
     epinglee pendant que la suivante arrive par-dessus (z-index plus haut). */
  .story-section {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    display: flex;
    overflow: hidden;
  }

  .story-section__inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 4rem 1.5rem;
    transform-origin: bottom left;
    transform: rotate(var(--rotate, 0deg));
    will-change: transform;
    background: inherit;
  }
  @media (min-width: 768px) {
    .story-section__inner { padding: 5rem 4vw; }
  }

  /* Background variants */
  .story-section--creme { background: var(--color-creme); color: var(--color-encre); }
  .story-section--encre { background: var(--color-encre); color: var(--color-creme); }
  .story-section--orange { background: var(--color-orange-soft); color: var(--color-encre); }
  .story-section--bleu { background: var(--color-bleu-soft); color: var(--color-encre); }

  /* Ombre sur la section qui arrive par-dessus (effet "decollement" du deck) */
  .story-section + .story-section {
    box-shadow: 0 -30px 60px -30px rgba(0, 0, 0, 0.3);
  }
  /* La 1re section ne pivote pas */
  .story-section:first-child .story-section__inner { transform: none; }

  @media (prefers-reduced-motion: reduce) {
    .story-section__inner { transform: none !important; }
  }
</style>
