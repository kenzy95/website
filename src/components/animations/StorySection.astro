---
/**
 * Story Section - enfant de StoryScroll.
 *
 * Pattern repris a l'identique du code GSAP original (boudjadjasamira/story-scroll) :
 * - section : relative min-h-screen w-full overflow-hidden (sticky pour empilement)
 * - inner : flex min-h-screen w-full flex-col justify-between gap-6
 *           px-[4vw] pt-[clamp(2rem,8vw,4vw)] pb-[4vw] + transform-origin bottom-left
 *
 * La rotation 30deg -> 0deg est pilotee par CSS var --rotate via le scroll
 * listener du parent StoryScroll.
 */

interface Props {
  bg?: 'creme' | 'encre' | 'orange-soft' | 'bleu-soft' | 'custom';
  customBg?: string;
  textColor?: string;
  ariaLabel?: string;
  class?: string;
}

type Bg = NonNullable<Props['bg']>;

const {
  bg = 'creme',
  customBg,
  textColor,
  ariaLabel,
  class: className = '',
} = Astro.props as Props;

const bgClasses: Record<Bg, string> = {
  creme: 'story-section--creme',
  encre: 'story-section--encre',
  'orange-soft': 'story-section--orange',
  'bleu-soft': 'story-section--bleu',
  custom: '',
};

const customStyle = [
  customBg ? `background:${customBg}` : '',
  textColor ? `color:${textColor}` : '',
].filter(Boolean).join(';');
---

<section
  data-story-section
  aria-label={ariaLabel}
  class:list={['story-section', bgClasses[bg], className]}
  style={customStyle || undefined}
>
  <div class="story-section__inner">
    <slot />
  </div>
</section>

<style>
  /* Pattern card-stack : sticky top:0 + min-h-screen + overflow hidden
     (identique au pattern GSAP source). */
  .story-section {
    position: sticky;
    top: 0;
    min-height: 100vh;
    width: 100%;
    overflow: hidden;
  }

  .story-section__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 100vh;
    width: 100%;
    padding: clamp(2rem, 8vw, 4vw) 4vw 4vw 4vw;
    transform-origin: bottom left;
    transform: rotate(var(--rotate, 0deg));
    will-change: transform;
    background: inherit;
  }

  /* Backgrounds variants */
  .story-section--creme { background: var(--color-creme); color: var(--color-encre); }
  .story-section--encre { background: var(--color-encre); color: var(--color-creme); }
  .story-section--orange { background: var(--color-orange-soft); color: var(--color-encre); }
  .story-section--bleu { background: var(--color-bleu-soft); color: var(--color-encre); }

  /* La 1re section ne pivote pas */
  .story-section:first-child .story-section__inner { transform: none; }

  @media (prefers-reduced-motion: reduce) {
    .story-section__inner { transform: none !important; }
  }
</style>
