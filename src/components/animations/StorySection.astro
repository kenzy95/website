---
/**
 * Story Section - enfant de StoryScroll.
 *
 * Layout : section sticky 100vh sur fond transparent (laisse voir le dark
 * de la page derriere), une card centree avec max-width et marges donne
 * l'effet "card flottante qui pivote" plutot que pleine viewport.
 *
 * La rotation 30deg -> 0deg est sur la card (pas l'inner) via CSS var
 * --rotate pilotee par le scroll listener du parent StoryScroll.
 */

interface Props {
  bg?: 'creme' | 'encre' | 'orange-soft' | 'bleu-soft' | 'custom';
  customBg?: string;
  textColor?: string;
  ariaLabel?: string;
  class?: string;
}

type Bg = NonNullable<Props['bg']>;

const {
  bg = 'creme',
  customBg,
  textColor,
  ariaLabel,
  class: className = '',
} = Astro.props as Props;

const bgClasses: Record<Bg, string> = {
  creme: 'story-section--creme',
  encre: 'story-section--encre',
  'orange-soft': 'story-section--orange',
  'bleu-soft': 'story-section--bleu',
  custom: '',
};

const customStyle = [
  customBg ? `--card-bg:${customBg}` : '',
  textColor ? `color:${textColor}` : '',
].filter(Boolean).join(';');
---

<section
  data-story-section
  aria-label={ariaLabel}
  class:list={['story-section', bgClasses[bg], className]}
  style={customStyle || undefined}
>
  <div class="story-section__card">
    <div class="story-section__inner">
      <slot />
    </div>
  </div>
</section>

<style>
  /* Section : pleine largeur sticky, fond transparent (laisse voir le dark) */
  .story-section {
    position: sticky;
    top: 0;
    min-height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    background: transparent;
  }
  @media (min-width: 768px) {
    .story-section { padding: 3rem 4vw; }
  }

  /* Card centree avec max-width + box-shadow + rotation
     = effet 'card flottante qui pivote' (pas pleine viewport) */
  .story-section__card {
    position: relative;
    width: 100%;
    max-width: 80rem;
    min-height: calc(100vh - 4rem);
    border-radius: 28px;
    overflow: hidden;
    background: var(--card-bg, var(--color-creme));
    color: inherit;
    box-shadow:
      0 10px 30px -10px rgba(0, 0, 0, 0.25),
      0 30px 80px -30px rgba(0, 0, 0, 0.35);
    transform-origin: bottom left;
    transform: rotate(var(--rotate, 0deg));
    will-change: transform;
  }
  @media (min-width: 768px) {
    .story-section__card {
      min-height: calc(100vh - 6rem);
      border-radius: 36px;
    }
  }

  .story-section__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: inherit;
    width: 100%;
    padding: clamp(2rem, 6vw, 4rem) clamp(1.5rem, 5vw, 4rem) clamp(2rem, 5vw, 4rem);
  }

  /* Backgrounds variants via --card-bg */
  .story-section--creme { --card-bg: var(--color-creme); color: var(--color-encre); }
  .story-section--encre { --card-bg: var(--color-encre); color: var(--color-creme); }
  .story-section--orange { --card-bg: var(--color-orange-soft); color: var(--color-encre); }
  .story-section--bleu { --card-bg: var(--color-bleu-soft); color: var(--color-encre); }

  /* La 1re card ne pivote pas */
  .story-section:first-child .story-section__card { transform: none; }

  @media (prefers-reduced-motion: reduce) {
    .story-section__card { transform: none !important; }
  }
</style>
