---
import Container from './ui/Container.astro';
import LogoWordmark from './ui/LogoWordmark.astro';
import ArrowButton from './ui/ArrowButton.astro';

/**
 * Header charte v2 - reprise de la structure Framer :
 * logo + nav pill centree + CTA "Prendre RDV" a droite.
 * Variant dark (home) ou light (autres pages) selon route.
 * Mobile (< md) : la pill est cachee, un bouton burger ouvre un panneau
 * sous le header avec les memes liens (JS inline, zero dependance).
 */
interface Props {
  variant?: 'dark' | 'light';
}
const { variant = 'light' } = Astro.props as Props;

const navItems = [
  { href: '/', label: 'Accueil' },
  { href: '/cas-clients', label: 'Cas clients' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
const isDark = variant === 'dark';
---

<header
  class:list={[
    'fixed top-0 left-0 right-0 z-40 transition-colors duration-300',
    isDark
      ? 'bg-[#0F1B3F]/70 backdrop-blur-xl border-b border-white/5'
      : 'bg-[#FAF7F2]/85 backdrop-blur-xl border-b border-[#0F1B3F]/8',
  ]}
>
  <Container size="wide" class="flex items-center justify-between gap-3 h-16 sm:h-20">
    <LogoWordmark size="md" variant={isDark ? 'creme' : 'encre'} />

    <!-- Nav pill centree (desktop) -->
    <nav
      aria-label="Navigation principale"
      class:list={[
        'hidden md:flex items-center gap-1 px-1.5 py-1.5 rounded-full backdrop-blur-md',
        isDark ? 'bg-white/5 border border-white/10' : 'bg-[#0F1B3F]/5 border border-[#0F1B3F]/8',
      ]}
    >
      {
        navItems.map((item) => {
          const active = item.href === '/'
            ? currentPath === '/'
            : currentPath.startsWith(item.href);
          return (
            <a
              href={item.href}
              class:list={[
                'px-4 py-2 text-xs font-semibold uppercase tracking-wider rounded-full transition-colors',
                active
                  ? isDark
                    ? 'bg-[#1E90FF]/15 text-[#1E90FF]'
                    : 'bg-[#0F1B3F] text-[#FAF7F2]'
                  : isDark
                    ? 'text-[#FAF7F2]/80 hover:text-[#FAF7F2]'
                    : 'text-[#0F1B3F]/75 hover:text-[#0F1B3F]',
              ]}
              aria-current={active ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-2">
      <ArrowButton href="/contact" variant="bleu" size="sm">Prendre RDV</ArrowButton>

      <!-- Burger (mobile) -->
      <button
        type="button"
        id="mobile-nav-toggle"
        class:list={[
          'md:hidden inline-flex flex-col items-center justify-center gap-[5px] w-10 h-10 rounded-full border',
          isDark ? 'border-white/15' : 'border-[#0F1B3F]/15',
        ]}
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Ouvrir le menu"
      >
        <span class:list={['burger-line', isDark ? 'bg-[#FAF7F2]' : 'bg-[#0F1B3F]']}></span>
        <span class:list={['burger-line', isDark ? 'bg-[#FAF7F2]' : 'bg-[#0F1B3F]']}></span>
        <span class:list={['burger-line', isDark ? 'bg-[#FAF7F2]' : 'bg-[#0F1B3F]']}></span>
      </button>
    </div>
  </Container>

  <!-- Panneau mobile -->
  <nav
    id="mobile-nav"
    aria-label="Navigation mobile"
    hidden
    class:list={[
      'md:hidden border-t',
      isDark ? 'bg-[#0F1B3F]/95 border-white/10' : 'bg-[#FAF7F2]/98 border-[#0F1B3F]/10',
    ]}
  >
    <ul class="px-6 py-4 flex flex-col gap-1">
      {
        navItems.map((item) => {
          const active = item.href === '/'
            ? currentPath === '/'
            : currentPath.startsWith(item.href);
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  'block px-4 py-3 rounded-2xl text-sm font-semibold uppercase tracking-wider transition-colors',
                  active
                    ? isDark
                      ? 'bg-[#1E90FF]/15 text-[#1E90FF]'
                      : 'bg-[#0F1B3F] text-[#FAF7F2]'
                    : isDark
                      ? 'text-[#FAF7F2]/85'
                      : 'text-[#0F1B3F]/80',
                ]}
                aria-current={active ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>

<style>
  .burger-line {
    display: block;
    width: 1.1rem;
    height: 2px;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  #mobile-nav-toggle[aria-expanded='true'] .burger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  #mobile-nav-toggle[aria-expanded='true'] .burger-line:nth-child(2) {
    opacity: 0;
  }
  #mobile-nav-toggle[aria-expanded='true'] .burger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>

<script>
  const toggle = document.getElementById('mobile-nav-toggle');
  const panel = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.setAttribute('aria-label', open ? 'Ouvrir le menu' : 'Fermer le menu');
    if (panel) panel.hidden = open;
  });
</script>
