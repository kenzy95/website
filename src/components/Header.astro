---
import Container from './ui/Container.astro';
import LogoWordmark from './ui/LogoWordmark.astro';
import Button from './ui/Button.astro';

/**
 * Header charte v2 : Logo Simple. + Navigation simple.
 * "Accueil · Comment ca marche · Temoignages · Contact"
 */
const navItems = [
  { href: '/#comment-ca-marche', label: 'Comment ça marche' },
  { href: '/#preuves', label: 'Témoignages' },
  { href: '/cas-clients', label: 'Cas clients' },
  { href: '/tarifs', label: 'Tarifs' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 bg-(--color-creme)/90 backdrop-blur-md border-b border-(--color-encre)/8">
  <Container size="wide" class="flex items-center justify-between h-16 sm:h-20">
    <LogoWordmark size="md" />

    <nav aria-label="Navigation principale" class="hidden md:flex items-center gap-8">
      {
        navItems.map((item) => {
          const active = currentPath === item.href || (item.href.startsWith('/') && !item.href.startsWith('/#') && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class:list={[
                'text-(--text-caption) font-medium transition-colors',
                active ? 'text-(--color-bleu)' : 'text-(--color-encre) hover:text-(--color-bleu)',
              ]}
              aria-current={active ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <Button href="/contact" variant="bleu" size="sm">Réserver un appel</Button>
  </Container>
</header>
