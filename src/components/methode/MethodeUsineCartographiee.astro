---
// MethodeUsineCartographiee.astro
// Direction D4 — fusion D1 (usine) + D3 (carte)
// Section sticky 400vh, --progress scroll-driven, SVG carte + compteurs animés
---

<section class="methode-usine" aria-label="Notre méthode en 4 étapes">
  <div class="sticky-wrap">
    <div class="bg-topo" aria-hidden="true">
      <svg viewBox="0 0 1200 750" preserveAspectRatio="xMidYMid slice">
        <!-- Courbes de niveau topographiques décoratives -->
        <path d="M -50 120 Q 200 80, 450 140 T 950 130 T 1300 150" />
        <path d="M -50 200 Q 220 160, 470 220 T 970 210 T 1300 230" />
        <path d="M -50 290 Q 240 240, 490 300 T 990 290 T 1300 320" />
        <path d="M -50 380 Q 260 330, 510 390 T 1010 380 T 1300 410" />
        <path d="M -50 470 Q 280 420, 530 480 T 1030 470 T 1300 500" />
        <path d="M -50 560 Q 300 510, 550 570 T 1050 560 T 1300 590" />
        <path d="M -50 650 Q 320 600, 570 660 T 1070 650 T 1300 680" />
      </svg>
    </div>

    <div class="container">
      <header class="header">
        <span class="eyebrow">MÉTHODE</span>
        <h2 class="title">
          On <em class="em-bleu">fabrique</em> des RDV.<br />
          On suit la <em class="em-orange">carte</em>.
        </h2>
        <p class="subtitle">
          12 847 prospects entrent. 47 RDV sortent. Voici le territoire entre les deux.
        </p>
      </header>

      <!-- Carte-usine principale -->
      <div class="map" data-map>
        <svg
          class="map-svg"
          viewBox="0 0 1200 750"
          preserveAspectRatio="xMidYMid meet"
          aria-hidden="true"
        >
          <defs>
            <!-- Gradient bleu vers orange pour le convoyeur -->
            <linearGradient id="conveyor-grad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#1E90FF" />
              <stop offset="60%" stop-color="#1E90FF" />
              <stop offset="100%" stop-color="#F47B3F" />
            </linearGradient>

            <!-- Glow pour étoile sortie -->
            <filter id="glow-orange" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="6" result="blur" />
              <feMerge>
                <feMergeNode in="blur" />
                <feMergeNode in="SourceGraphic" />
              </feMerge>
            </filter>

            <!-- Pattern dash pour conveyor belt -->
            <pattern id="belt-dots" x="0" y="0" width="20" height="6" patternUnits="userSpaceOnUse">
              <circle cx="10" cy="3" r="1.6" fill="#FAF7F2" opacity="0.6" />
            </pattern>
          </defs>

          <!-- Zones polygonales (territoire) -->
          <!-- ENTRÉE en haut centre -->
          <polygon
            class="zone zone-entry"
            points="540,40 720,40 740,110 720,140 540,140 520,110"
          />

          <!-- Zone 01 CADRAGE haut gauche -->
          <polygon
            class="zone zone-01"
            data-zone="01"
            points="80,200 320,180 360,260 340,360 120,380 60,300"
          />

          <!-- Zone 02 BUILD haut droite -->
          <polygon
            class="zone zone-02"
            data-zone="02"
            points="820,180 1120,200 1140,300 1100,380 880,360 840,260"
          />

          <!-- Zone 03 LANCEMENT bas droite -->
          <polygon
            class="zone zone-03"
            data-zone="03"
            points="780,460 1080,440 1120,540 1080,640 820,660 760,560"
          />

          <!-- Zone 04 ITÉRATION centre bas (boucle) -->
          <polygon
            class="zone zone-04"
            data-zone="04"
            points="380,500 620,480 660,580 620,680 400,700 340,600"
          />

          <!-- Zone SORTIE bas léger droite -->
          <polygon
            class="zone zone-out"
            points="120,560 280,540 320,620 260,710 140,710 80,640"
          />

          <!-- Convoyeur (chemin tracé) -->
          <path
            class="conveyor-path"
            d="M 630 140
               L 540 175
               L 220 250
               L 220 310
               L 540 305
               L 880 280
               L 960 380
               L 920 470
               L 880 560
               L 700 580
               L 500 590
               L 350 630
               L 280 660
               L 200 660"
            fill="none"
            stroke="url(#conveyor-grad)"
            stroke-width="5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />

          <!-- Boucle de retour itération vers lancement (apparait progress > 0.8) -->
          <path
            class="loop-back"
            d="M 480 510
               C 580 420, 780 400, 880 460"
            fill="none"
            stroke="#F47B3F"
            stroke-width="3"
            stroke-linecap="round"
            stroke-dasharray="6 6"
          />

          <!-- Étoile de sortie avec glow -->
          <g class="exit-star" transform="translate(200, 635)">
            <polygon
              points="0,-22 6,-7 22,-7 9,3 14,18 0,9 -14,18 -9,3 -22,-7 -6,-7"
              fill="#F47B3F"
              filter="url(#glow-orange)"
            />
          </g>

          <!-- Petits points (leads) animés sur le convoyeur -->
          <path
            class="lead-dots"
            d="M 630 140
               L 540 175
               L 220 250
               L 220 310
               L 540 305
               L 880 280
               L 960 380
               L 920 470
               L 880 560
               L 700 580
               L 500 590
               L 350 630
               L 280 660
               L 200 660"
            fill="none"
            stroke="#FAF7F2"
            stroke-width="3"
            stroke-linecap="round"
            stroke-dasharray="2 18"
            opacity="0.7"
          />
        </svg>

        <!-- Overlays HTML positionnés en absolu -->
        <div class="label label-entry" style="left: 50%; top: 6%;">
          <div class="entry-arrow">↓</div>
          <div class="entry-text">
            <span class="counter" data-counter="entry" data-target="12847">0</span>
            <span class="counter-label">prospects</span>
          </div>
        </div>

        <div class="station station-01" style="left: 9%; top: 27%;">
          <div class="station-num">01</div>
          <div class="station-title">CADRAGE</div>
          <div class="station-keywords">ICP · angles · offre</div>
          <div class="station-output">
            → <span class="counter" data-counter="01" data-target="4200">0</span> ciblés
          </div>
        </div>

        <div class="station station-02" style="left: 73%; top: 27%;">
          <div class="station-num">02</div>
          <div class="station-title">BUILD</div>
          <div class="station-keywords">scrape · enrich · copy</div>
          <div class="station-output">
            → <span class="counter" data-counter="02" data-target="8">0</span> boîtes
          </div>
        </div>

        <div class="station station-03" style="left: 71%; top: 65%;">
          <div class="station-num">03</div>
          <div class="station-title">LANCEMENT</div>
          <div class="station-keywords">warmup · push · suivi</div>
          <div class="station-output">
            → <span class="counter" data-counter="03" data-target="12847">0</span> messages
          </div>
        </div>

        <div class="station station-04" style="left: 38%; top: 75%;">
          <div class="station-num">04</div>
          <div class="station-title">ITÉRATION</div>
          <div class="station-keywords">analyse · A/B · ajuste</div>
          <div class="station-output">boucle continue</div>
        </div>

        <div class="label label-exit" style="left: 14%; top: 80%;">
          <div class="exit-text">
            <span class="counter" data-counter="exit" data-target="47">0</span>
            <span class="counter-label">RDV qualifiés</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Compteurs animés via @property */
  @property --c-entry {
    syntax: "<integer>";
    inherits: false;
    initial-value: 0;
  }
  @property --c-01 {
    syntax: "<integer>";
    inherits: false;
    initial-value: 0;
  }
  @property --c-02 {
    syntax: "<integer>";
    inherits: false;
    initial-value: 0;
  }
  @property --c-03 {
    syntax: "<integer>";
    inherits: false;
    initial-value: 0;
  }
  @property --c-exit {
    syntax: "<integer>";
    inherits: false;
    initial-value: 0;
  }

  .methode-usine {
    --progress: 0;
    position: relative;
    background: var(--color-encre);
    color: var(--color-creme);
    min-height: 400vh;
  }

  .sticky-wrap {
    position: sticky;
    top: 0;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 4rem 0;
  }

  /* Pattern topographique en fond */
  .bg-topo {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.05;
  }
  .bg-topo svg {
    width: 100%;
    height: 100%;
  }
  .bg-topo path {
    fill: none;
    stroke: var(--color-creme);
    stroke-width: 1;
  }

  .container {
    position: relative;
    width: 100%;
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    z-index: 1;
  }

  /* Header de section */
  .header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .eyebrow {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--color-orange);
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    line-height: 1.1;
    margin: 0 0 1rem;
    color: var(--color-creme);
  }
  .title .em-bleu {
    font-style: italic;
    color: var(--color-bleu);
    font-weight: 500;
  }
  .title .em-orange {
    font-style: italic;
    color: var(--color-orange);
    font-weight: 500;
  }
  .subtitle {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-gris-soft);
    max-width: 38rem;
    margin: 0 auto;
  }

  /* Carte conteneur */
  .map {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    max-width: 64rem;
    margin: 0 auto;
  }
  .map-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* Zones polygonales */
  .zone {
    fill: transparent;
    stroke: var(--color-creme);
    stroke-opacity: 0.3;
    stroke-width: 1.2;
    stroke-dasharray: 3 4;
    transition: fill 0.6s ease, stroke-opacity 0.6s ease;
  }
  .zone-entry {
    fill: rgba(30, 144, 255, 0.15);
    stroke-opacity: 0.5;
  }
  .zone-out {
    fill: rgba(244, 123, 63, 0.12);
    stroke: var(--color-orange);
    stroke-opacity: 0.4;
  }

  /* États progression — zone franchie (bleu) puis active (orange) */
  .methode-usine[data-progress-15="true"] .zone-entry {
    fill: rgba(30, 144, 255, 0.35);
    stroke-opacity: 0.7;
  }
  .methode-usine[data-progress-30="true"] .zone-01 {
    fill: rgba(30, 144, 255, 0.25);
    stroke-opacity: 0.6;
  }
  .methode-usine[data-progress-50="true"] .zone-02 {
    fill: rgba(30, 144, 255, 0.25);
    stroke-opacity: 0.6;
  }
  .methode-usine[data-progress-65="true"] .zone-03 {
    fill: rgba(30, 144, 255, 0.25);
    stroke-opacity: 0.6;
  }
  .methode-usine[data-progress-80="true"] .zone-04 {
    fill: rgba(244, 123, 63, 0.35);
    stroke: var(--color-orange);
    stroke-opacity: 0.7;
  }
  .methode-usine[data-progress-92="true"] .zone-out {
    fill: rgba(244, 123, 63, 0.5);
    stroke-opacity: 1;
  }

  /* Convoyeur tracé via stroke-dashoffset */
  .conveyor-path {
    stroke-dasharray: 2400;
    stroke-dashoffset: calc(2400 - var(--progress) * 2400);
    transition: stroke-dashoffset 0.08s linear;
  }

  /* Boucle de retour itération, visible à partir de progress 0.8 */
  .loop-back {
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .methode-usine[data-progress-80="true"] .loop-back {
    opacity: 0.8;
    animation: dash-loop 2s linear infinite;
  }
  @keyframes dash-loop {
    to {
      stroke-dashoffset: -24;
    }
  }

  /* Étoile sortie pulse à progress 0.92 */
  .exit-star {
    opacity: 0.4;
    transform-origin: 200px 635px;
    transition: opacity 0.5s ease;
  }
  .methode-usine[data-progress-92="true"] .exit-star {
    opacity: 1;
    animation: pulse-star 1.6s ease-in-out infinite;
  }
  @keyframes pulse-star {
    0%, 100% {
      transform: translate(200px, 635px) scale(1);
    }
    50% {
      transform: translate(200px, 635px) scale(1.15);
    }
  }

  /* Petits points qui défilent en continu — effet conveyor belt */
  .lead-dots {
    animation: belt-flow 3.5s linear infinite;
  }
  @keyframes belt-flow {
    to {
      stroke-dashoffset: -20;
    }
  }

  /* Labels et stations en overlay HTML */
  .label,
  .station {
    position: absolute;
    transform: translate(-50%, -50%);
    text-align: center;
    pointer-events: none;
    z-index: 2;
  }

  .label-entry {
    color: var(--color-creme);
  }
  .entry-arrow {
    font-size: 1.5rem;
    color: var(--color-bleu);
    margin-bottom: 0.2rem;
  }
  .entry-text {
    background: rgba(15, 27, 63, 0.7);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(30, 144, 255, 0.4);
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
  }
  .label-exit .exit-text {
    background: rgba(244, 123, 63, 0.15);
    backdrop-filter: blur(4px);
    border: 1px solid var(--color-orange);
    padding: 0.6rem 1rem;
    border-radius: 6px;
  }
  .counter {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    color: var(--color-creme);
    line-height: 1;
  }
  .label-exit .counter {
    color: var(--color-orange);
    font-size: 2rem;
  }
  .counter-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gris-soft);
    margin-top: 0.25rem;
  }

  /* Stations méthode */
  .station {
    width: 12rem;
  }
  .station-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 2.75rem;
    color: var(--color-bleu);
    line-height: 1;
    margin-bottom: 0.2rem;
  }
  .station-04 .station-num {
    color: var(--color-orange);
  }
  .station-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    color: var(--color-creme);
    margin-bottom: 0.3rem;
  }
  .station-keywords {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-gris-soft);
    margin-bottom: 0.5rem;
  }
  .station-output {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-bleu);
    font-weight: 500;
    background: rgba(15, 27, 63, 0.6);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    display: inline-block;
  }
  .station-04 .station-output {
    color: var(--color-orange);
  }

  /* Responsive mobile — carte verticale */
  @media (max-width: 1023px) {
    .sticky-wrap {
      padding: 3rem 0;
    }
    .bg-topo {
      display: none;
    }
    .map {
      aspect-ratio: 10 / 16;
      max-width: 24rem;
    }
    /* Repositionnement vertical des stations */
    .label-entry {
      left: 50% !important;
      top: 4% !important;
    }
    .station-01 {
      left: 50% !important;
      top: 20% !important;
    }
    .station-02 {
      left: 50% !important;
      top: 38% !important;
    }
    .station-03 {
      left: 50% !important;
      top: 56% !important;
    }
    .station-04 {
      left: 50% !important;
      top: 74% !important;
    }
    .label-exit {
      left: 50% !important;
      top: 92% !important;
    }
    .station {
      width: 14rem;
    }
    /* Convoyeur vertical simplifié — on cache le path complexe sur mobile */
    .map-svg .zone,
    .map-svg .conveyor-path,
    .map-svg .lead-dots,
    .map-svg .loop-back {
      display: none;
    }
    .map-svg .exit-star {
      display: none;
    }
    /* Ligne verticale crème comme convoyeur mobile */
    .map::before {
      content: "";
      position: absolute;
      left: 50%;
      top: 8%;
      bottom: 8%;
      width: 3px;
      background: linear-gradient(
        to bottom,
        var(--color-bleu) 0%,
        var(--color-bleu) 60%,
        var(--color-orange) 100%
      );
      transform: translateX(-50%);
      opacity: calc(0.3 + var(--progress) * 0.7);
    }
  }

  /* Préférence motion réduite */
  @media (prefers-reduced-motion: reduce) {
    .lead-dots,
    .exit-star,
    .loop-back {
      animation: none !important;
    }
    .conveyor-path {
      stroke-dashoffset: 0 !important;
      transition: none !important;
    }
    .methode-usine .zone-entry,
    .methode-usine .zone-01,
    .methode-usine .zone-02,
    .methode-usine .zone-03,
    .methode-usine .zone-04,
    .methode-usine .zone-out {
      fill: rgba(30, 144, 255, 0.25);
      stroke-opacity: 0.6;
    }
    .methode-usine .zone-04 {
      fill: rgba(244, 123, 63, 0.3);
    }
    .methode-usine .exit-star {
      opacity: 1;
    }
    .counter {
      /* affichage état final via fallback JS */
    }
  }
</style>

<script>
  // Pattern --progress scroll-driven, calqué sur ContainerScroll.astro
  function initMethodeUsine() {
    const section = document.querySelector<HTMLElement>(".methode-usine");
    if (!section) return;

    const counters = section.querySelectorAll<HTMLElement>(".counter");
    const counterState = new Map<HTMLElement, number>();
    counters.forEach((el) => counterState.set(el, 0));

    // Seuils d'activation pour chaque compteur
    const thresholds: Record<string, number> = {
      entry: 0.15,
      "01": 0.3,
      "02": 0.5,
      "03": 0.65,
      exit: 0.92,
    };

    // Préférence motion réduite : afficher état final immédiatement
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduceMotion) {
      section.style.setProperty("--progress", "1");
      ["15", "30", "50", "65", "80", "92"].forEach((p) =>
        section.setAttribute(`data-progress-${p}`, "true")
      );
      counters.forEach((el) => {
        const target = parseInt(el.dataset.target || "0", 10);
        el.textContent = formatNumber(target);
      });
      return;
    }

    function formatNumber(n: number): string {
      // Espace insécable pour les milliers
      return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, " ");
    }

    function update() {
      if (!section) return;
      const rect = section.getBoundingClientRect();
      const vh = window.innerHeight;
      const total = section.offsetHeight - vh;
      const scrolled = Math.max(0, -rect.top);
      const progress = total > 0 ? Math.min(1, Math.max(0, scrolled / total)) : 0;

      section.style.setProperty("--progress", progress.toFixed(4));

      // Active les data-progress-XX pour piloter les transitions CSS
      const flags = [
        { p: 0.15, key: "15" },
        { p: 0.3, key: "30" },
        { p: 0.5, key: "50" },
        { p: 0.65, key: "65" },
        { p: 0.8, key: "80" },
        { p: 0.92, key: "92" },
      ];
      flags.forEach(({ p, key }) => {
        if (progress >= p) {
          section.setAttribute(`data-progress-${key}`, "true");
        } else {
          section.removeAttribute(`data-progress-${key}`);
        }
      });

      // Compteurs : interpolation linéaire entre seuil et seuil + 0.1
      counters.forEach((el) => {
        const key = el.dataset.counter || "";
        const target = parseInt(el.dataset.target || "0", 10);
        const t = thresholds[key] ?? 0;
        const window = 0.1;
        let ratio = 0;
        if (progress >= t) {
          ratio = Math.min(1, (progress - t) / window);
        }
        const current = Math.floor(target * ratio);
        if (counterState.get(el) !== current) {
          counterState.set(el, current);
          el.textContent = formatNumber(current);
        }
      });
    }

    let ticking = false;
    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          update();
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    update();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initMethodeUsine);
  } else {
    initMethodeUsine();
  }
</script>
