---
/**
 * Mini-navigation pour comparer les 4 directions Methodologie en preview.
 * Affichee en haut de chaque page /methode-1 a /methode-4.
 */

interface Props {
  current: 1 | 2 | 3 | 4;
}
const { current } = Astro.props as Props;

const links = [
  { n: 1, slug: '/methode-1', label: "D1 — L'Usine à RDV" },
  { n: 2, slug: '/methode-2', label: 'D2 — Le Signal' },
  { n: 3, slug: '/methode-3', label: 'D3 — Le Terrain de Chasse' },
  { n: 4, slug: '/methode-4', label: 'D4 — Usine Cartographiée' },
];
---

<nav class="preview-nav">
  <div class="preview-nav__inner">
    <span class="preview-nav__eyebrow">Preview — Méthodologie · Direction {current}/4</span>
    <ul class="preview-nav__list">
      {
        links.map((l) => (
          <li>
            <a
              href={l.slug}
              class={`preview-nav__link ${l.n === current ? 'is-active' : ''}`}
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  .preview-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-encre);
    border-bottom: 1px solid rgba(250, 247, 242, 0.08);
    backdrop-filter: blur(8px);
  }
  .preview-nav__inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  @media (min-width: 768px) {
    .preview-nav__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
    }
  }
  .preview-nav__eyebrow {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: rgba(250, 247, 242, 0.55);
    font-weight: 600;
  }
  .preview-nav__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .preview-nav__link {
    display: inline-block;
    padding: 0.4rem 0.85rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: rgba(250, 247, 242, 0.7);
    background: rgba(250, 247, 242, 0.06);
    border-radius: 999px;
    text-decoration: none;
    transition: all 0.18s ease;
  }
  .preview-nav__link:hover {
    color: var(--color-creme);
    background: rgba(250, 247, 242, 0.12);
  }
  .preview-nav__link.is-active {
    color: var(--color-encre);
    background: var(--color-bleu);
  }
</style>
