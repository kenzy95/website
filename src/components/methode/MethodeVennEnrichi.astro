---
// MethodeVennEnrichi.astro
// Direction B v3 : Venn V1 (validé Kenzy) + chips signaux + lignes pointillées fines.
// Repart de zéro depuis MethodeVenn.astro. Pas d'orbite outils, pas de monitors, pas de cards RDV.
// Ajouts : 7 chips signal au-dessus + pointillés fins vers cercle cible + hover étendu aux circles + bandeau stats.
---

<section class="methode-venn" aria-labelledby="venn-title">
  <div class="venn-container">

    <!-- Header -->
    <header class="venn-header">
      <p class="eyebrow">MÉTHODE — ALIMENTÉE EN SIGNAUX 24/7</p>
      <h2 id="venn-title" class="venn-title">
        <em class="accent-orange">Trois</em> forces. Une seule <em class="accent-bleu">équation</em>.
      </h2>
      <p class="venn-subtitle">
        Un RDV qualifié, par définition, vit à l'intersection. Et l'intersection, on la nourrit en continu.
      </p>
    </header>

    <!-- Stage : chips + Venn + bandeau -->
    <div class="venn-stage">

      <!-- Colonne gauche : chips signaux + SVG Venn -->
      <div class="venn-svg-wrapper" id="venn-wrapper">

        <!-- Rangée 7 chips signal avec contenu riche -->
        <div class="signals-row" role="list" aria-label="Signaux captés en continu">
          <div class="signal-chip" role="listitem" data-target="ciblage" data-chip="1" style="--delay: 0s;">
            <span class="signal-chip__tag">LEVÉE</span>
            <span class="signal-chip__label">Série A 8M€</span>
            <span class="signal-chip__meta">Aujourd'hui</span>
          </div>
          <div class="signal-chip" role="listitem" data-target="ciblage" data-chip="2" style="--delay: 0.7s;">
            <span class="signal-chip__tag">RECRUTEMENT</span>
            <span class="signal-chip__label">Head of Sales</span>
            <span class="signal-chip__meta">Il y a 2 j</span>
          </div>
          <div class="signal-chip" role="listitem" data-target="copy" data-chip="3" style="--delay: 1.4s;">
            <span class="signal-chip__tag">POST</span>
            <span class="signal-chip__label">CEO annonce expansion EU</span>
            <span class="signal-chip__meta">Cette semaine</span>
          </div>
          <div class="signal-chip" role="listitem" data-target="ciblage" data-chip="4" style="--delay: 2.1s;">
            <span class="signal-chip__tag">PRODUIT</span>
            <span class="signal-chip__label">Sortie v2 API</span>
            <span class="signal-chip__meta">Hier</span>
          </div>
          <div class="signal-chip" role="listitem" data-target="copy" data-chip="5" style="--delay: 2.8s;">
            <span class="signal-chip__tag">CHANGEMENT</span>
            <span class="signal-chip__label">Nouveau CRO</span>
            <span class="signal-chip__meta">Il y a 4 j</span>
          </div>
          <div class="signal-chip" role="listitem" data-target="ciblage" data-chip="6" style="--delay: 3.5s;">
            <span class="signal-chip__tag">CROISSANCE</span>
            <span class="signal-chip__label">+30 effectifs / 6 mois</span>
            <span class="signal-chip__meta">Tendance</span>
          </div>
          <div class="signal-chip" role="listitem" data-target="copy" data-chip="7" style="--delay: 4.2s;">
            <span class="signal-chip__tag">SIGNAL FAIBLE</span>
            <span class="signal-chip__label">Refonte site B2B</span>
            <span class="signal-chip__meta">Cette semaine</span>
          </div>
        </div>

        <!-- SVG overlay des pointillés chips → cercles (recalculé en JS au mount + resize) -->
        <svg class="signals-wires" id="signals-wires" aria-hidden="true" preserveAspectRatio="none"></svg>

        <!-- SVG Venn -->
        <svg
          class="venn-svg"
          viewBox="0 0 640 640"
          role="img"
          aria-labelledby="venn-svg-title venn-svg-desc"
        >
          <title id="venn-svg-title">Diagramme de Venn : Ciblage, Copy, Infra</title>
          <desc id="venn-svg-desc">
            Trois cercles colorés se recouvrent. L'intersection centrale représente les RDV qualifiés.
          </desc>

          <g class="venn-circles">
            <!-- Cercle Ciblage : bleu -->
            <g class="venn-circle" data-pilier="ciblage">
              <circle
                cx="240"
                cy="220"
                r="180"
                fill="var(--color-bleu)"
                opacity="0.6"
                class="circle-shape"
                data-hover-pilier="ciblage"
              />
              <g transform="translate(170, 180)" class="icon-radar">
                <circle cx="20" cy="20" r="18" fill="none" stroke="var(--color-creme)" stroke-width="1.2" opacity="0.6"/>
                <circle cx="20" cy="20" r="12" fill="none" stroke="var(--color-creme)" stroke-width="1.2" opacity="0.7"/>
                <circle cx="20" cy="20" r="5" fill="var(--color-creme)" opacity="0.85"/>
                <line x1="20" y1="20" x2="38" y2="20" stroke="var(--color-creme)" stroke-width="1.4" class="radar-sweep" style="transform-origin: 20px 20px;"/>
              </g>
            </g>

            <!-- Cercle Copy : orange charte (vif) -->
            <g class="venn-circle" data-pilier="copy">
              <circle
                cx="400"
                cy="220"
                r="180"
                fill="var(--color-orange)"
                opacity="0.72"
                class="circle-shape"
                data-hover-pilier="copy"
              />
              <g transform="translate(450, 180)" class="icon-plume">
                <path
                  d="M 5 35 Q 15 5, 35 5 Q 35 25, 15 35 Z"
                  fill="var(--color-creme)"
                  opacity="0.9"
                />
                <line x1="5" y1="35" x2="0" y2="42" stroke="var(--color-creme)" stroke-width="1.4"/>
              </g>
            </g>

            <!-- Cercle Infra : crème -->
            <g class="venn-circle" data-pilier="infra">
              <circle
                cx="320"
                cy="380"
                r="180"
                fill="var(--color-creme)"
                opacity="0.45"
                class="circle-shape"
                data-hover-pilier="infra"
              />
              <g transform="translate(300, 480)" class="icon-bouclier">
                <path
                  d="M 20 2 L 38 8 L 38 22 Q 38 35, 20 42 Q 2 35, 2 22 L 2 8 Z"
                  fill="var(--color-encre)"
                  opacity="0.85"
                />
                <path
                  d="M 12 22 L 18 28 L 28 16"
                  fill="none"
                  stroke="var(--color-creme)"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </g>
            </g>
          </g>

          <!-- Centre RDV qualifiés -->
          <g class="venn-center" aria-hidden="true">
            <text x="320" y="305" text-anchor="middle" class="center-text">RDV</text>
            <text x="320" y="335" text-anchor="middle" class="center-text-sub">qualifiés</text>
          </g>
        </svg>

        <!-- Labels piliers : boutons flottants -->
        <button
          type="button"
          class="venn-label venn-label-ciblage"
          data-pilier="ciblage"
          aria-label="Pilier Ciblage : signaux fins"
        >
          <span class="label-num">01</span>
          <span class="label-titre">CIBLAGE</span>
          <span class="label-sous">Signaux fins</span>
        </button>

        <button
          type="button"
          class="venn-label venn-label-copy"
          data-pilier="copy"
          aria-label="Pilier Copy : contexte naturel"
        >
          <span class="label-num">02</span>
          <span class="label-titre">COPY</span>
          <span class="label-sous">Contexte naturel</span>
        </button>

        <button
          type="button"
          class="venn-label venn-label-infra"
          data-pilier="infra"
          aria-label="Pilier Infra : délivrabilité"
        >
          <span class="label-num">03</span>
          <span class="label-titre">INFRA</span>
          <span class="label-sous">Délivrabilité</span>
        </button>
      </div>

      <!-- Colonne droite : bandeau explicatif -->
      <aside class="venn-bandeau" aria-live="polite">

        <!-- Bandeau par défaut : enrichi avec stats -->
        <div class="bandeau-pane bandeau-default is-active" data-pane="default">
          <p class="bandeau-default-text">
            Quand les trois forces s'alignent, vous tombez dans l'intersection.
            Un RDV qualifié, c'est exactement ça : la rencontre de trois conditions.
          </p>
          <ul class="bandeau-stats" aria-label="Le système en chiffres">
            <li>
              <span class="stat-num">~12 000</span>
              <span class="stat-lbl">Signaux scannés / sem.</span>
            </li>
            <li>
              <span class="stat-num">340</span>
              <span class="stat-lbl">Boîtes monitorées</span>
            </li>
            <li>
              <span class="stat-num">~85</span>
              <span class="stat-lbl">RDV livrés / mois</span>
            </li>
          </ul>
        </div>

        <!-- Bandeau Ciblage -->
        <div class="bandeau-pane bandeau-ciblage" data-pane="ciblage">
          <p class="bandeau-num">01 / CIBLAGE</p>
          <h3 class="bandeau-titre">Signaux fins</h3>
          <p class="bandeau-desc">
            On part de signaux d'achat précis : levée de fonds, ouverture de poste sales, sortie produit.
          </p>
          <ul class="bandeau-bullets">
            <li>Sales Navigator + signaux web scrapés</li>
            <li>Vérification email continue</li>
            <li>Critères d'exclusion stricts</li>
          </ul>
          <p class="bandeau-exemple">
            <strong>Exemple :</strong> SaaS B2B levée &gt; 5M€ + recrutement Head of Sales = signal expansion commerciale.
          </p>
          <button type="button" class="bandeau-disable" data-disable="ciblage">Désactiver ce pilier ›</button>
        </div>

        <!-- Bandeau Copy -->
        <div class="bandeau-pane bandeau-copy" data-pane="copy">
          <p class="bandeau-num">02 / COPY</p>
          <h3 class="bandeau-titre">Contexte naturel</h3>
          <p class="bandeau-desc">
            Phrase d'ouverture qui prouve qu'on a fait nos devoirs.
          </p>
          <ul class="bandeau-bullets">
            <li>Référence à un signal précis (levée, post, recrutement)</li>
            <li>Vouvoiement court, ton humain</li>
            <li>Zéro jargon outbound, zéro promesse creuse</li>
          </ul>
          <p class="bandeau-exemple">
            <strong>Exemple :</strong> "Vu votre annonce HoS, j'ai noté que vous avez levé chez ..."
          </p>
          <button type="button" class="bandeau-disable" data-disable="copy">Désactiver ce pilier ›</button>
        </div>

        <!-- Bandeau Infra -->
        <div class="bandeau-pane bandeau-infra" data-pane="infra">
          <p class="bandeau-num">03 / INFRA</p>
          <h3 class="bandeau-titre">Délivrabilité</h3>
          <p class="bandeau-desc">
            Le message arrive dans l'inbox, pas dans les promotions.
          </p>
          <ul class="bandeau-bullets">
            <li>Domaines secondaires dédiés par client</li>
            <li>Warmup progressif 4 à 6 semaines</li>
            <li>Volumes raisonnables 30 à 50 envois par boîte par jour</li>
            <li>Monitoring deliverability continu</li>
          </ul>
          <button type="button" class="bandeau-disable" data-disable="infra">Désactiver ce pilier ›</button>
        </div>

        <!-- Bandeau erreur -->
        <div class="bandeau-pane bandeau-erreur" data-pane="erreur">
          <p class="erreur-num">PILIER DÉSACTIVÉ</p>
          <p class="erreur-text">
            Sans <span class="erreur-pilier-nom">[Pilier]</span>, pas d'intersection.<br />
            Pas de RDV.
          </p>
          <button type="button" class="bandeau-reactiver">‹ Réactiver le pilier</button>
        </div>
      </aside>
    </div>

    <!-- Footer -->
    <footer class="venn-footer">
      <p class="venn-conclusion">
        <em>C'est notre métier. Aligner les trois forces. Tous les jours.</em>
      </p>
    </footer>
  </div>
</section>

<style>
  .methode-venn {
    background: var(--color-encre);
    color: var(--color-creme);
    min-height: 100vh;
    padding: 5rem 2rem 4rem;
    display: flex;
    align-items: center;
  }

  .venn-container {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Header */
  .venn-header {
    text-align: center;
    max-width: 820px;
    margin: 0 auto;
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-orange);
    margin: 0 0 1.25rem;
    font-weight: 600;
  }

  .venn-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 500;
    line-height: 1.15;
    margin: 0 0 1rem;
    color: var(--color-creme);
  }
  .venn-title .accent-orange { color: var(--color-orange); font-style: italic; font-weight: 400; }
  .venn-title .accent-bleu   { color: var(--color-bleu);   font-style: italic; font-weight: 400; }

  .venn-subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.125rem;
    color: var(--color-gris-soft);
    margin: 0;
  }

  /* Stage */
  .venn-stage {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  /* Wrapper : chips + SVG. Position relative pour superposer wires + labels. */
  .venn-svg-wrapper {
    position: relative;
    width: 100%;
    max-width: 680px;
    margin: 0 auto;
  }

  /* Rangée chips signal : 7 chips alignées sur une ligne */
  .signals-row {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 0.5rem;
    margin-top: -2.5rem;
    margin-bottom: 1.75rem;
    padding: 0;
  }

  /* Chip carte compacte avec 3 lignes (tag / label / meta) */
  .signal-chip {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    font-family: var(--font-sans);
    color: var(--color-creme);
    background: rgba(15, 27, 63, 0.5);
    border: 1px solid var(--color-gris);
    padding: 0.4rem 0.6rem;
    border-radius: 8px;
    backdrop-filter: blur(4px);
    min-width: 0;
    text-align: left;
    overflow: hidden;
    animation: chip-float 4s ease-in-out infinite;
    animation-delay: var(--delay, 0s);
  }
  .signal-chip__tag {
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    font-weight: 700;
    color: var(--color-gris-soft);
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .signal-chip__label {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-creme);
    line-height: 1.2;
  }
  .signal-chip__meta {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.68rem;
    color: var(--color-gris-soft);
    opacity: 0.85;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .signal-chip[data-target="ciblage"] {
    border-color: rgba(99, 165, 217, 0.45);
  }
  .signal-chip[data-target="ciblage"] .signal-chip__tag {
    color: var(--color-bleu);
  }
  .signal-chip[data-target="copy"] {
    border-color: rgba(244, 123, 63, 0.5);
  }
  .signal-chip[data-target="copy"] .signal-chip__tag {
    color: var(--color-orange);
  }

  @keyframes chip-float {
    0%, 100% { transform: translateY(0); opacity: 0.92; }
    50%      { transform: translateY(-4px); opacity: 1; }
  }

  /* Overlay SVG des pointillés chip → cercle */
  .signals-wires {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
    overflow: visible;
  }
  .signals-wires path {
    fill: none;
    stroke: var(--color-creme);
    stroke-width: 1.2;
    stroke-dasharray: 4 5;
    stroke-linecap: round;
    opacity: 0.32;
    animation: dash-flow 6s linear infinite;
  }
  .signals-wires path[data-target="copy"] {
    stroke: var(--color-orange);
    opacity: 0.38;
  }
  .signals-wires path[data-target="ciblage"] {
    stroke: var(--color-bleu);
    opacity: 0.4;
  }
  @keyframes dash-flow {
    from { stroke-dashoffset: 0; }
    to   { stroke-dashoffset: -36; }
  }

  /* SVG Venn : carré, aspect ratio 1:1 */
  .venn-svg {
    position: relative;
    z-index: 2;
    width: 100%;
    aspect-ratio: 1 / 1;
    display: block;
  }

  /* Cercles : animation respiration */
  .venn-circles { mix-blend-mode: screen; }

  .venn-circle {
    transition: opacity 0.4s ease;
    transform-box: fill-box;
    transform-origin: center;
  }

  .venn-circle[data-pilier="ciblage"] { animation: breath-ciblage 8s ease-in-out infinite alternate; }
  .venn-circle[data-pilier="copy"]    { animation: breath-copy 8s ease-in-out infinite alternate; animation-delay: -2.5s; }
  .venn-circle[data-pilier="infra"]   { animation: breath-infra 8s ease-in-out infinite alternate; animation-delay: -5s; }

  @keyframes breath-ciblage {
    0%   { transform: translate(0, 0); }
    50%  { transform: translate(-6px, -4px); }
    100% { transform: translate(4px, 3px); }
  }
  @keyframes breath-copy {
    0%   { transform: translate(0, 0); }
    50%  { transform: translate(6px, -3px); }
    100% { transform: translate(-4px, 4px); }
  }
  @keyframes breath-infra {
    0%   { transform: translate(0, 0); }
    50%  { transform: translate(-3px, 6px); }
    100% { transform: translate(3px, -4px); }
  }

  /* Capture du hover directement sur la zone peinte des cercles */
  .circle-shape {
    pointer-events: visiblePainted;
    cursor: pointer;
    transition: opacity 0.3s ease, filter 0.3s ease;
  }

  /* État hover : cercle illuminé + autres atténués */
  .venn-svg.hover-ciblage .venn-circle[data-pilier="ciblage"] .circle-shape {
    opacity: 0.88;
    filter: drop-shadow(0 0 18px var(--color-bleu));
  }
  .venn-svg.hover-ciblage .venn-circle[data-pilier="copy"] .circle-shape,
  .venn-svg.hover-ciblage .venn-circle[data-pilier="infra"] .circle-shape {
    opacity: 0.3;
  }

  .venn-svg.hover-copy .venn-circle[data-pilier="copy"] .circle-shape {
    opacity: 0.92;
    filter: drop-shadow(0 0 22px var(--color-orange));
  }
  .venn-svg.hover-copy .venn-circle[data-pilier="ciblage"] .circle-shape,
  .venn-svg.hover-copy .venn-circle[data-pilier="infra"] .circle-shape {
    opacity: 0.3;
  }

  .venn-svg.hover-infra .venn-circle[data-pilier="infra"] .circle-shape {
    opacity: 0.78;
    filter: drop-shadow(0 0 18px var(--color-creme));
  }
  .venn-svg.hover-infra .venn-circle[data-pilier="ciblage"] .circle-shape,
  .venn-svg.hover-infra .venn-circle[data-pilier="copy"] .circle-shape {
    opacity: 0.3;
  }

  /* État désactivé */
  .venn-svg .venn-circle.is-disabled .circle-shape {
    transform: scale(0);
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
    transition: transform 0.6s ease-in, opacity 0.6s ease-in;
  }
  .venn-svg .venn-circle.is-disabled .icon-radar,
  .venn-svg .venn-circle.is-disabled .icon-plume,
  .venn-svg .venn-circle.is-disabled .icon-bouclier {
    opacity: 0;
    transition: opacity 0.4s ease-in;
  }

  /* Centre RDV qualifiés */
  .venn-center { pointer-events: none; }
  .center-text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 2rem;
    fill: var(--color-encre);
    animation: pulse-center 3s ease-in-out infinite;
    transform-origin: 320px 305px;
  }
  .center-text-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.4rem;
    fill: var(--color-encre);
    animation: pulse-center 3s ease-in-out infinite;
    transform-origin: 320px 335px;
  }
  @keyframes pulse-center {
    0%, 100% { transform: scale(1); opacity: 0.95; }
    50%      { transform: scale(1.08); opacity: 1; }
  }
  .venn-svg.center-disabled .venn-center {
    opacity: 0;
    transition: opacity 0.5s ease-in;
  }

  /* Radar */
  .radar-sweep { animation: radar-rotate 4s linear infinite; }
  @keyframes radar-rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

  /* Labels piliers */
  .venn-label {
    position: absolute;
    background: transparent;
    border: 1px solid var(--color-gris);
    color: var(--color-creme);
    padding: 0.6rem 1rem;
    font-family: var(--font-sans);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    transition: all 0.3s ease;
    backdrop-filter: blur(4px);
    z-index: 4;
  }

  .venn-label:hover,
  .venn-label.is-hovered {
    border-color: var(--color-creme);
    background: rgba(15, 27, 63, 0.7);
    transform: translateY(-2px);
  }

  .label-num   { font-size: 0.7rem;  letter-spacing: 0.2em;  color: var(--color-gris-soft); }
  .label-titre { font-size: 0.9rem;  letter-spacing: 0.18em; font-weight: 700; }
  .label-sous  { font-size: 0.75rem; color: var(--color-gris-soft); font-style: italic; }

  /* Positions labels (offset vertical pour laisser place aux chips) */
  .venn-label-ciblage { top: 18%; left: 2%; }
  .venn-label-copy    { top: 18%; right: 2%; }
  .venn-label-infra {
    bottom: 3%;
    left: 50%;
    transform: translateX(-50%);
  }
  .venn-label-infra:hover,
  .venn-label-infra.is-hovered {
    transform: translateX(-50%) translateY(-2px);
  }

  /* Bandeau latéral */
  .venn-bandeau {
    position: relative;
    min-height: 420px;
    padding: 2rem;
    border-left: 1px solid var(--color-gris);
  }

  .bandeau-pane {
    position: absolute;
    inset: 2rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }
  .bandeau-pane.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .bandeau-default-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.2rem;
    line-height: 1.5;
    color: var(--color-creme);
    margin: 0 0 1.5rem;
  }

  .bandeau-stats {
    list-style: none;
    padding: 1.25rem 0 0;
    margin: 0;
    border-top: 1px solid var(--color-gris);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .bandeau-stats li {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .stat-num {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--color-orange);
    line-height: 1;
  }
  .stat-lbl {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-gris-soft);
  }

  .bandeau-num {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    color: var(--color-orange);
    margin: 0 0 0.5rem;
    font-weight: 600;
  }
  .bandeau-titre {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 500;
    margin: 0 0 1rem;
    color: var(--color-creme);
  }
  .bandeau-desc {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-creme);
    margin: 0 0 1rem;
  }
  .bandeau-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
  }
  .bandeau-bullets li {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-gris-soft);
    padding: 0.3rem 0 0.3rem 1rem;
    position: relative;
  }
  .bandeau-bullets li::before {
    content: "›";
    position: absolute;
    left: 0;
    color: var(--color-orange);
  }
  .bandeau-exemple {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-gris-soft);
    border-left: 2px solid var(--color-gris);
    padding-left: 0.75rem;
    margin: 0 0 1.5rem;
    line-height: 1.5;
  }

  .bandeau-disable,
  .bandeau-reactiver {
    background: transparent;
    border: 1px solid var(--color-gris);
    color: var(--color-creme);
    padding: 0.6rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.25s ease;
  }
  .bandeau-disable:hover,
  .bandeau-reactiver:hover {
    border-color: var(--color-orange);
    color: var(--color-orange);
  }

  /* Bandeau erreur */
  .erreur-num {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    color: var(--color-orange);
    margin: 0 0 1rem;
    font-weight: 600;
  }
  .erreur-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.4rem;
    line-height: 1.4;
    color: var(--color-creme);
    margin: 0 0 1.5rem;
  }
  .erreur-pilier-nom {
    color: var(--color-orange);
    font-weight: 500;
  }

  /* Footer */
  .venn-footer {
    text-align: center;
    margin-top: 2rem;
  }
  .venn-conclusion {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    color: var(--color-creme);
    margin: 0;
    font-weight: 400;
  }
  .venn-conclusion em { font-style: italic; }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .venn-circle,
    .center-text,
    .center-text-sub,
    .radar-sweep,
    .signal-chip,
    .signals-wires path {
      animation: none !important;
    }
  }

  /* Tablet */
  @media (max-width: 1023px) {
    .venn-stage {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .venn-bandeau {
      border-left: none;
      border-top: 1px solid var(--color-gris);
      min-height: 320px;
    }
    .bandeau-stats {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1.25rem 2rem;
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .methode-venn { padding: 3rem 1.25rem; }
    .venn-svg-wrapper { max-width: 380px; }
    /* Mobile : repli 7 chips en grille 2 colonnes pour rester lisible */
    .signals-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.4rem;
    }
    .signal-chip {
      padding: 0.4rem 0.55rem;
    }
    .signal-chip__label { font-size: 0.72rem; }
    .venn-label   { padding: 0.4rem 0.7rem; }
    .label-titre  { font-size: 0.75rem; }
    .label-sous   { font-size: 0.65rem; }
    .label-num    { font-size: 0.6rem; }
    .venn-label-ciblage { top: 22%; }
    .venn-label-copy    { top: 22%; }
    .bandeau-pane { inset: 1.25rem; }
    .venn-bandeau { padding: 1.25rem; }
    .bandeau-stats { flex-direction: column; gap: 0.75rem; }
  }
</style>

<script is:inline>
  // Interactions Venn enrichi : hover (labels + cercles SVG) + click disable + lignes pointillées chips→cercles
  (function () {
    const root = document.querySelector(".methode-venn");
    if (!root) return;

    const svg = root.querySelector(".venn-svg");
    const labels = root.querySelectorAll(".venn-label");
    const panes = root.querySelectorAll(".bandeau-pane");
    const circles = root.querySelectorAll(".venn-circle");
    const circleShapes = root.querySelectorAll(".circle-shape[data-hover-pilier]");
    const disableButtons = root.querySelectorAll(".bandeau-disable");
    const reactiverBtn = root.querySelector(".bandeau-reactiver");
    const erreurNom = root.querySelector(".erreur-pilier-nom");

    const wrapper = root.querySelector("#venn-wrapper");
    const wiresSvg = root.querySelector("#signals-wires");
    const chips = root.querySelectorAll(".signal-chip");

    if (!svg || !wrapper || !wiresSvg) return;

    const disabled = { ciblage: false, copy: false, infra: false };
    const pilierLabels = { ciblage: "Ciblage", copy: "Copy", infra: "Infra" };

    function clearHoverClasses() {
      svg.classList.remove("hover-ciblage", "hover-copy", "hover-infra");
      labels.forEach((l) => l.classList.remove("is-hovered"));
    }

    function showPane(name) {
      panes.forEach((p) => p.classList.remove("is-active"));
      const target = root.querySelector('.bandeau-pane[data-pane="' + name + '"]');
      if (target) target.classList.add("is-active");
    }

    function setHover(pilier) {
      if (disabled[pilier]) return;
      clearHoverClasses();
      svg.classList.add("hover-" + pilier);
      const lbl = root.querySelector('.venn-label[data-pilier="' + pilier + '"]');
      if (lbl) lbl.classList.add("is-hovered");
      showPane(pilier);
    }

    function clearHover() {
      clearHoverClasses();
      const anyDisabled = disabled.ciblage || disabled.copy || disabled.infra;
      if (!anyDisabled) {
        showPane("default");
      } else {
        const off = Object.keys(disabled).find((k) => disabled[k]);
        if (off) updateErreurPane(off);
      }
    }

    function updateErreurPane(pilier) {
      if (erreurNom) erreurNom.textContent = pilierLabels[pilier];
      showPane("erreur");
    }

    function disablePilier(pilier) {
      disabled[pilier] = true;
      const circle = root.querySelector('.venn-circle[data-pilier="' + pilier + '"]');
      if (circle) circle.classList.add("is-disabled");
      svg.classList.add("center-disabled");
      const lbl = root.querySelector('.venn-label[data-pilier="' + pilier + '"]');
      if (lbl) lbl.style.opacity = "0.35";
      updateErreurPane(pilier);
    }

    function reactivateAll() {
      Object.keys(disabled).forEach((k) => (disabled[k] = false));
      circles.forEach((c) => c.classList.remove("is-disabled"));
      svg.classList.remove("center-disabled");
      labels.forEach((l) => (l.style.opacity = ""));
      showPane("default");
    }

    // Listeners labels HTML
    labels.forEach((label) => {
      const pilier = label.getAttribute("data-pilier");
      label.addEventListener("mouseenter", () => setHover(pilier));
      label.addEventListener("focus", () => setHover(pilier));
      label.addEventListener("mouseleave", clearHover);
      label.addEventListener("blur", clearHover);
    });

    // Listeners cercles SVG (hover étendu)
    circleShapes.forEach((shape) => {
      const pilier = shape.getAttribute("data-hover-pilier");
      shape.addEventListener("mouseenter", () => setHover(pilier));
      shape.addEventListener("mouseleave", clearHover);
    });

    // Disable / reactiver
    disableButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const pilier = btn.getAttribute("data-disable");
        if (pilier) disablePilier(pilier);
      });
    });
    if (reactiverBtn) reactiverBtn.addEventListener("click", reactivateAll);

    // ===========================================================
    // Pointillés chips → cercles : recalcul au mount + resize
    // ===========================================================
    // Points d'ancrage sur les cercles (en coords viewBox 0..640) :
    //   ciblage : haut du cercle bleu (240, 40)
    //   copy    : haut du cercle orange (400, 40)
    // On convertit ces coords en pixels du wrapper via getBoundingClientRect.

    const TARGET_POINTS_VB = {
      ciblage: { x: 240, y: 50 },
      copy:    { x: 400, y: 50 },
    };

    function viewBoxToWrapperPx(vbx, vby) {
      const svgRect = svg.getBoundingClientRect();
      const wrapRect = wrapper.getBoundingClientRect();
      // viewBox 640 → svgRect.width
      const px = svgRect.left - wrapRect.left + (vbx / 640) * svgRect.width;
      const py = svgRect.top - wrapRect.top + (vby / 640) * svgRect.height;
      return { x: px, y: py };
    }

    function buildWires() {
      const wrapRect = wrapper.getBoundingClientRect();
      const W = wrapRect.width;
      const H = wrapRect.height;
      if (W === 0 || H === 0) return;

      wiresSvg.setAttribute("viewBox", "0 0 " + W + " " + H);

      // Vide
      while (wiresSvg.firstChild) wiresSvg.removeChild(wiresSvg.firstChild);

      chips.forEach((chip) => {
        const target = chip.getAttribute("data-target");
        const tgtVb = TARGET_POINTS_VB[target];
        if (!tgtVb) return;

        const chipRect = chip.getBoundingClientRect();
        const startX = chipRect.left - wrapRect.left + chipRect.width / 2;
        const startY = chipRect.bottom - wrapRect.top;

        const end = viewBoxToWrapperPx(tgtVb.x, tgtVb.y);

        // Courbe douce vers la cible
        const c1x = startX;
        const c1y = startY + (end.y - startY) * 0.45;
        const c2x = end.x;
        const c2y = startY + (end.y - startY) * 0.65;

        const d = "M " + startX + " " + startY +
                  " C " + c1x + " " + c1y +
                  ", " + c2x + " " + c2y +
                  ", " + end.x + " " + end.y;

        // Fix Astro scope : les paths crees dynamiquement n'heritent pas du CSS scope.
        // On applique les styles directement en attributs SVG sinon fill = black par defaut.
        const stroke = target === "copy" ? "var(--color-orange)" : "var(--color-bleu)";
        const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
        path.setAttribute("d", d);
        path.setAttribute("data-target", target);
        path.setAttribute("fill", "none");
        path.setAttribute("stroke", stroke);
        path.setAttribute("stroke-width", "1.4");
        path.setAttribute("stroke-dasharray", "4 5");
        path.setAttribute("stroke-linecap", "round");
        path.setAttribute("opacity", "0.55");
        path.style.animation = "dash-flow 6s linear infinite";
        wiresSvg.appendChild(path);
      });
    }

    // Build initial + resize
    if (typeof window !== "undefined") {
      // Attendre layout stable
      requestAnimationFrame(() => buildWires());
      window.addEventListener("resize", () => {
        requestAnimationFrame(() => buildWires());
      });
      // Re-build après chargement des fonts (chips peuvent reflow)
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(() => buildWires());
      }
    }
  })();
</script>
