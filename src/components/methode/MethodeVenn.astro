---
// MethodeVenn.astro
// Diagramme de Venn animé "3 forces, 1 équation" pour la section Méthode.
// Direction B : Venn à 3 cercles (Ciblage / Copy / Infra), intersection = RDV qualifiés.
// Vanilla JS pour les interactions hover + désactivation pilier.
---

<section class="methode-venn" aria-labelledby="venn-title">
  <div class="venn-container">

    <!-- Bloc supérieur : eyebrow + titre + sous-titre -->
    <header class="venn-header">
      <p class="eyebrow">MÉTHODE</p>
      <h2 id="venn-title" class="venn-title">
        <em class="accent-orange">Trois</em> forces. Une seule <em class="accent-bleu">équation</em>.
      </h2>
      <p class="venn-subtitle">
        Un RDV qualifié, par définition, vit à l'intersection.
      </p>
    </header>

    <!-- Bloc central : Venn + bandeau latéral -->
    <div class="venn-stage">

      <!-- Colonne gauche : SVG Venn -->
      <div class="venn-svg-wrapper">
        <svg
          class="venn-svg"
          viewBox="0 0 640 640"
          role="img"
          aria-labelledby="venn-svg-title venn-svg-desc"
        >
          <title id="venn-svg-title">Diagramme de Venn : Ciblage, Copy, Infra</title>
          <desc id="venn-svg-desc">
            Trois cercles colorés se recouvrent. L'intersection centrale représente les RDV qualifiés.
          </desc>

          <!-- Groupe Venn : 3 cercles en mode "lighten" pour additivité visuelle -->
          <g class="venn-circles">
            <!-- Cercle Ciblage : bleu, haut gauche -->
            <g class="venn-circle" data-pilier="ciblage">
              <circle
                cx="240"
                cy="220"
                r="180"
                fill="var(--color-bleu)"
                opacity="0.6"
                class="circle-shape"
              />
              <!-- Icône radar -->
              <g transform="translate(170, 180)" class="icon-radar">
                <circle cx="20" cy="20" r="18" fill="none" stroke="var(--color-creme)" stroke-width="1.2" opacity="0.6"/>
                <circle cx="20" cy="20" r="12" fill="none" stroke="var(--color-creme)" stroke-width="1.2" opacity="0.7"/>
                <circle cx="20" cy="20" r="5" fill="var(--color-creme)" opacity="0.85"/>
                <line x1="20" y1="20" x2="38" y2="20" stroke="var(--color-creme)" stroke-width="1.4" class="radar-sweep" style="transform-origin: 20px 20px;"/>
              </g>
            </g>

            <!-- Cercle Copy : orange, haut droite -->
            <g class="venn-circle" data-pilier="copy">
              <circle
                cx="400"
                cy="220"
                r="180"
                fill="var(--color-orange)"
                opacity="0.6"
                class="circle-shape"
              />
              <!-- Icône plume -->
              <g transform="translate(450, 180)" class="icon-plume">
                <path
                  d="M 5 35 Q 15 5, 35 5 Q 35 25, 15 35 Z"
                  fill="var(--color-creme)"
                  opacity="0.85"
                />
                <line x1="5" y1="35" x2="0" y2="42" stroke="var(--color-creme)" stroke-width="1.4"/>
              </g>
            </g>

            <!-- Cercle Infra : crème, bas centre -->
            <g class="venn-circle" data-pilier="infra">
              <circle
                cx="320"
                cy="380"
                r="180"
                fill="var(--color-creme)"
                opacity="0.45"
                class="circle-shape"
              />
              <!-- Icône bouclier -->
              <g transform="translate(300, 480)" class="icon-bouclier">
                <path
                  d="M 20 2 L 38 8 L 38 22 Q 38 35, 20 42 Q 2 35, 2 22 L 2 8 Z"
                  fill="var(--color-encre)"
                  opacity="0.85"
                />
                <path
                  d="M 12 22 L 18 28 L 28 16"
                  fill="none"
                  stroke="var(--color-creme)"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </g>
            </g>
          </g>

          <!-- Texte central intersection : RDV qualifiés -->
          <g class="venn-center" aria-hidden="true">
            <text
              x="320"
              y="305"
              text-anchor="middle"
              class="center-text"
            >RDV</text>
            <text
              x="320"
              y="335"
              text-anchor="middle"
              class="center-text-sub"
            >qualifiés</text>
          </g>
        </svg>

        <!-- Labels flottants au-dessus du SVG (HTML, positionnés en absolute) -->
        <button
          type="button"
          class="venn-label venn-label-ciblage"
          data-pilier="ciblage"
          aria-label="Pilier Ciblage : signaux fins"
        >
          <span class="label-num">01</span>
          <span class="label-titre">CIBLAGE</span>
          <span class="label-sous">Signaux fins</span>
        </button>

        <button
          type="button"
          class="venn-label venn-label-copy"
          data-pilier="copy"
          aria-label="Pilier Copy : contexte naturel"
        >
          <span class="label-num">02</span>
          <span class="label-titre">COPY</span>
          <span class="label-sous">Contexte naturel</span>
        </button>

        <button
          type="button"
          class="venn-label venn-label-infra"
          data-pilier="infra"
          aria-label="Pilier Infra : délivrabilité"
        >
          <span class="label-num">03</span>
          <span class="label-titre">INFRA</span>
          <span class="label-sous">Délivrabilité</span>
        </button>
      </div>

      <!-- Colonne droite : bandeau explicatif -->
      <aside class="venn-bandeau" aria-live="polite">

        <!-- Bandeau par défaut -->
        <div class="bandeau-pane bandeau-default is-active" data-pane="default">
          <p class="bandeau-default-text">
            Quand les trois forces s'alignent, vous tombez dans l'intersection.
            Un RDV qualifié, c'est exactement ça : la rencontre de trois conditions.
          </p>
        </div>

        <!-- Bandeau Ciblage -->
        <div class="bandeau-pane bandeau-ciblage" data-pane="ciblage">
          <p class="bandeau-num">01 / CIBLAGE</p>
          <h3 class="bandeau-titre">Signaux fins</h3>
          <p class="bandeau-desc">
            On part de signaux d'achat précis : levée de fonds, ouverture de poste sales, sortie produit.
          </p>
          <ul class="bandeau-bullets">
            <li>Sales Navigator + signaux web scrapés</li>
            <li>Vérification email continue</li>
            <li>Critères d'exclusion stricts</li>
          </ul>
          <p class="bandeau-exemple">
            <strong>Exemple :</strong> SaaS B2B levée &gt; 5M€ + recrutement Head of Sales = signal expansion commerciale.
          </p>
          <button
            type="button"
            class="bandeau-disable"
            data-disable="ciblage"
          >Désactiver ce pilier ›</button>
        </div>

        <!-- Bandeau Copy -->
        <div class="bandeau-pane bandeau-copy" data-pane="copy">
          <p class="bandeau-num">02 / COPY</p>
          <h3 class="bandeau-titre">Contexte naturel</h3>
          <p class="bandeau-desc">
            Phrase d'ouverture qui prouve qu'on a fait nos devoirs.
          </p>
          <ul class="bandeau-bullets">
            <li>Référence à un signal précis (levée, post, recrutement)</li>
            <li>Vouvoiement court, ton humain</li>
            <li>Zéro jargon outbound, zéro promesse creuse</li>
          </ul>
          <p class="bandeau-exemple">
            <strong>Exemple :</strong> "Vu votre annonce HoS, j'ai noté que vous avez levé chez ..."
          </p>
          <button
            type="button"
            class="bandeau-disable"
            data-disable="copy"
          >Désactiver ce pilier ›</button>
        </div>

        <!-- Bandeau Infra -->
        <div class="bandeau-pane bandeau-infra" data-pane="infra">
          <p class="bandeau-num">03 / INFRA</p>
          <h3 class="bandeau-titre">Délivrabilité</h3>
          <p class="bandeau-desc">
            Le message arrive dans l'inbox, pas dans les promotions.
          </p>
          <ul class="bandeau-bullets">
            <li>Domaines secondaires dédiés par client</li>
            <li>Warmup progressif 4 à 6 semaines</li>
            <li>Volumes raisonnables 30 à 50 envois par boîte par jour</li>
            <li>Monitoring deliverability continu</li>
          </ul>
          <button
            type="button"
            class="bandeau-disable"
            data-disable="infra"
          >Désactiver ce pilier ›</button>
        </div>

        <!-- Bandeau erreur (pilier désactivé) -->
        <div class="bandeau-pane bandeau-erreur" data-pane="erreur">
          <p class="erreur-num">PILIER DÉSACTIVÉ</p>
          <p class="erreur-text">
            Sans <span class="erreur-pilier-nom">[Pilier]</span>, pas d'intersection.<br />
            Pas de RDV.
          </p>
          <button
            type="button"
            class="bandeau-reactiver"
          >‹ Réactiver le pilier</button>
        </div>
      </aside>
    </div>

    <!-- Bloc inférieur : conclusion -->
    <footer class="venn-footer">
      <p class="venn-conclusion">
        <em>C'est notre métier. Aligner les trois forces. Tous les jours.</em>
      </p>
    </footer>
  </div>
</section>

<style>
  .methode-venn {
    background: var(--color-encre);
    color: var(--color-creme);
    min-height: 100vh;
    padding: 5rem 2rem 4rem;
    display: flex;
    align-items: center;
  }

  .venn-container {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Header */
  .venn-header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-orange);
    margin: 0 0 1.25rem;
    font-weight: 600;
  }

  .venn-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 500;
    line-height: 1.15;
    margin: 0 0 1rem;
    color: var(--color-creme);
  }

  .venn-title .accent-orange {
    color: var(--color-orange);
    font-style: italic;
    font-weight: 400;
  }

  .venn-title .accent-bleu {
    color: var(--color-bleu);
    font-style: italic;
    font-weight: 400;
  }

  .venn-subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.125rem;
    color: var(--color-gris-soft);
    margin: 0;
  }

  /* Stage = Venn + bandeau */
  .venn-stage {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  /* Wrapper SVG : position relative pour les labels flottants */
  .venn-svg-wrapper {
    position: relative;
    width: 100%;
    max-width: 640px;
    margin: 0 auto;
    aspect-ratio: 1 / 1;
  }

  .venn-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Cercles : animation respiration */
  .venn-circles {
    mix-blend-mode: screen;
  }

  .venn-circle {
    transition: opacity 0.4s ease;
    transform-box: fill-box;
    transform-origin: center;
  }

  .venn-circle[data-pilier="ciblage"] {
    animation: breath-ciblage 8s ease-in-out infinite alternate;
  }
  .venn-circle[data-pilier="copy"] {
    animation: breath-copy 8s ease-in-out infinite alternate;
    animation-delay: -2.5s;
  }
  .venn-circle[data-pilier="infra"] {
    animation: breath-infra 8s ease-in-out infinite alternate;
    animation-delay: -5s;
  }

  @keyframes breath-ciblage {
    0%   { transform: translate(0, 0); }
    50%  { transform: translate(-6px, -4px); }
    100% { transform: translate(4px, 3px); }
  }
  @keyframes breath-copy {
    0%   { transform: translate(0, 0); }
    50%  { transform: translate(6px, -3px); }
    100% { transform: translate(-4px, 4px); }
  }
  @keyframes breath-infra {
    0%   { transform: translate(0, 0); }
    50%  { transform: translate(-3px, 6px); }
    100% { transform: translate(3px, -4px); }
  }

  /* État hover : cercle illuminé + autres atténués */
  .venn-svg.hover-ciblage .venn-circle[data-pilier="ciblage"] .circle-shape {
    opacity: 0.85;
    filter: drop-shadow(0 0 18px var(--color-bleu));
  }
  .venn-svg.hover-ciblage .venn-circle[data-pilier="copy"] .circle-shape,
  .venn-svg.hover-ciblage .venn-circle[data-pilier="infra"] .circle-shape {
    opacity: 0.3;
  }

  .venn-svg.hover-copy .venn-circle[data-pilier="copy"] .circle-shape {
    opacity: 0.85;
    filter: drop-shadow(0 0 18px var(--color-orange));
  }
  .venn-svg.hover-copy .venn-circle[data-pilier="ciblage"] .circle-shape,
  .venn-svg.hover-copy .venn-circle[data-pilier="infra"] .circle-shape {
    opacity: 0.3;
  }

  .venn-svg.hover-infra .venn-circle[data-pilier="infra"] .circle-shape {
    opacity: 0.75;
    filter: drop-shadow(0 0 18px var(--color-creme));
  }
  .venn-svg.hover-infra .venn-circle[data-pilier="ciblage"] .circle-shape,
  .venn-svg.hover-infra .venn-circle[data-pilier="copy"] .circle-shape {
    opacity: 0.3;
  }

  /* État désactivé : le cercle disparaît */
  .venn-svg .venn-circle.is-disabled .circle-shape {
    transform: scale(0);
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
    transition: transform 0.6s ease-in, opacity 0.6s ease-in;
  }
  .venn-svg .venn-circle.is-disabled .icon-radar,
  .venn-svg .venn-circle.is-disabled .icon-plume,
  .venn-svg .venn-circle.is-disabled .icon-bouclier {
    opacity: 0;
    transition: opacity 0.4s ease-in;
  }

  /* Centre RDV qualifiés */
  .venn-center {
    pointer-events: none;
  }
  .center-text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 2rem;
    fill: var(--color-encre);
    animation: pulse-center 3s ease-in-out infinite;
    transform-origin: 320px 305px;
  }
  .center-text-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.4rem;
    fill: var(--color-encre);
    animation: pulse-center 3s ease-in-out infinite;
    transform-origin: 320px 335px;
  }

  @keyframes pulse-center {
    0%, 100% { transform: scale(1); opacity: 0.95; }
    50%      { transform: scale(1.08); opacity: 1; }
  }

  .venn-svg.center-disabled .venn-center {
    opacity: 0;
    transition: opacity 0.5s ease-in;
  }

  /* Radar sweep */
  .radar-sweep {
    animation: radar-rotate 4s linear infinite;
  }
  @keyframes radar-rotate {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Labels piliers : boutons flottants */
  .venn-label {
    position: absolute;
    background: transparent;
    border: 1px solid var(--color-gris);
    color: var(--color-creme);
    padding: 0.6rem 1rem;
    font-family: var(--font-sans);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    transition: all 0.3s ease;
    backdrop-filter: blur(4px);
  }

  .venn-label:hover,
  .venn-label.is-hovered {
    border-color: var(--color-creme);
    background: rgba(15, 27, 63, 0.7);
    transform: translateY(-2px);
  }

  .label-num {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--color-gris-soft);
  }
  .label-titre {
    font-size: 0.9rem;
    letter-spacing: 0.18em;
    font-weight: 700;
  }
  .label-sous {
    font-size: 0.75rem;
    color: var(--color-gris-soft);
    font-style: italic;
  }

  /* Position des labels (desktop) */
  .venn-label-ciblage {
    top: 5%;
    left: 2%;
  }
  .venn-label-copy {
    top: 5%;
    right: 2%;
  }
  .venn-label-infra {
    bottom: 5%;
    left: 50%;
    transform: translateX(-50%);
  }
  .venn-label-infra:hover,
  .venn-label-infra.is-hovered {
    transform: translateX(-50%) translateY(-2px);
  }

  /* Bandeau latéral */
  .venn-bandeau {
    position: relative;
    min-height: 380px;
    padding: 2rem;
    border-left: 1px solid var(--color-gris);
  }

  .bandeau-pane {
    position: absolute;
    inset: 2rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .bandeau-pane.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .bandeau-default-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.5;
    color: var(--color-creme);
    margin: 0;
  }

  .bandeau-num {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    color: var(--color-orange);
    margin: 0 0 0.5rem;
    font-weight: 600;
  }

  .bandeau-titre {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 500;
    margin: 0 0 1rem;
    color: var(--color-creme);
  }

  .bandeau-desc {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-creme);
    margin: 0 0 1rem;
  }

  .bandeau-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
  }
  .bandeau-bullets li {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-gris-soft);
    padding: 0.3rem 0 0.3rem 1rem;
    position: relative;
  }
  .bandeau-bullets li::before {
    content: "›";
    position: absolute;
    left: 0;
    color: var(--color-orange);
  }

  .bandeau-exemple {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-gris-soft);
    border-left: 2px solid var(--color-gris);
    padding-left: 0.75rem;
    margin: 0 0 1.5rem;
    line-height: 1.5;
  }

  .bandeau-disable,
  .bandeau-reactiver {
    background: transparent;
    border: 1px solid var(--color-gris);
    color: var(--color-creme);
    padding: 0.6rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.25s ease;
  }
  .bandeau-disable:hover,
  .bandeau-reactiver:hover {
    border-color: var(--color-orange);
    color: var(--color-orange);
  }

  /* Bandeau erreur */
  .erreur-num {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    color: var(--color-orange);
    margin: 0 0 1rem;
    font-weight: 600;
  }
  .erreur-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.4rem;
    line-height: 1.4;
    color: var(--color-creme);
    margin: 0 0 1.5rem;
  }
  .erreur-pilier-nom {
    color: var(--color-orange);
    font-weight: 500;
  }

  /* Footer */
  .venn-footer {
    text-align: center;
    margin-top: 2rem;
  }
  .venn-conclusion {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    color: var(--color-creme);
    margin: 0;
    font-weight: 400;
  }
  .venn-conclusion em {
    font-style: italic;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .venn-circle,
    .center-text,
    .center-text-sub,
    .radar-sweep {
      animation: none !important;
    }
  }

  /* Tablet */
  @media (max-width: 1023px) {
    .venn-stage {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .venn-bandeau {
      border-left: none;
      border-top: 1px solid var(--color-gris);
      min-height: 320px;
    }
  }

  /* Mobile : Venn empilé vertical (fallback simple) */
  @media (max-width: 767px) {
    .methode-venn {
      padding: 3rem 1.25rem;
    }
    .venn-svg-wrapper {
      max-width: 360px;
    }
    .venn-label {
      padding: 0.4rem 0.7rem;
    }
    .label-titre {
      font-size: 0.75rem;
    }
    .label-sous {
      font-size: 0.65rem;
    }
    .label-num {
      font-size: 0.6rem;
    }
    .bandeau-pane {
      inset: 1.25rem;
    }
    .venn-bandeau {
      padding: 1.25rem;
    }
  }
</style>

<script is:inline>
  // Interactions Venn : hover label → highlight cercle + bandeau ; click disable → cercle disparait
  (function () {
    const svg = document.querySelector(".methode-venn .venn-svg");
    const labels = document.querySelectorAll(".methode-venn .venn-label");
    const panes = document.querySelectorAll(".methode-venn .bandeau-pane");
    const circles = document.querySelectorAll(".methode-venn .venn-circle");
    const disableButtons = document.querySelectorAll(".methode-venn .bandeau-disable");
    const reactiverBtn = document.querySelector(".methode-venn .bandeau-reactiver");
    const erreurPane = document.querySelector('.methode-venn .bandeau-pane[data-pane="erreur"]');
    const erreurNom = document.querySelector(".methode-venn .erreur-pilier-nom");

    if (!svg) return;

    // État désactivé par pilier
    const disabled = { ciblage: false, copy: false, infra: false };
    let currentHover = null;

    const pilierLabels = {
      ciblage: "Ciblage",
      copy: "Copy",
      infra: "Infra",
    };

    function clearHoverClasses() {
      svg.classList.remove("hover-ciblage", "hover-copy", "hover-infra");
      labels.forEach((l) => l.classList.remove("is-hovered"));
    }

    function showPane(name) {
      panes.forEach((p) => p.classList.remove("is-active"));
      const target = document.querySelector(`.methode-venn .bandeau-pane[data-pane="${name}"]`);
      if (target) target.classList.add("is-active");
    }

    function setHover(pilier) {
      if (disabled[pilier]) return;
      currentHover = pilier;
      clearHoverClasses();
      svg.classList.add("hover-" + pilier);
      const lbl = document.querySelector(`.methode-venn .venn-label[data-pilier="${pilier}"]`);
      if (lbl) lbl.classList.add("is-hovered");
      showPane(pilier);
    }

    function clearHover() {
      currentHover = null;
      clearHoverClasses();
      // Si aucun pilier désactivé, retour au pane default
      const anyDisabled = disabled.ciblage || disabled.copy || disabled.infra;
      if (!anyDisabled) {
        showPane("default");
      } else {
        // Sinon : reste sur le bandeau erreur du pilier désactivé
        const off = Object.keys(disabled).find((k) => disabled[k]);
        if (off) updateErreurPane(off);
      }
    }

    function updateErreurPane(pilier) {
      if (erreurNom) erreurNom.textContent = pilierLabels[pilier];
      showPane("erreur");
    }

    function disablePilier(pilier) {
      disabled[pilier] = true;
      const circle = document.querySelector(`.methode-venn .venn-circle[data-pilier="${pilier}"]`);
      if (circle) circle.classList.add("is-disabled");
      svg.classList.add("center-disabled");
      // Atténue le label désactivé
      const lbl = document.querySelector(`.methode-venn .venn-label[data-pilier="${pilier}"]`);
      if (lbl) lbl.style.opacity = "0.35";
      updateErreurPane(pilier);
    }

    function reactivateAll() {
      Object.keys(disabled).forEach((k) => (disabled[k] = false));
      circles.forEach((c) => c.classList.remove("is-disabled"));
      svg.classList.remove("center-disabled");
      labels.forEach((l) => (l.style.opacity = ""));
      showPane("default");
    }

    // Listeners labels
    labels.forEach((label) => {
      const pilier = label.getAttribute("data-pilier");
      label.addEventListener("mouseenter", () => setHover(pilier));
      label.addEventListener("focus", () => setHover(pilier));
      label.addEventListener("mouseleave", clearHover);
      label.addEventListener("blur", clearHover);
    });

    // Listeners buttons desactiver
    disableButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const pilier = btn.getAttribute("data-disable");
        if (pilier) disablePilier(pilier);
      });
    });

    // Reactiver
    if (reactiverBtn) {
      reactiverBtn.addEventListener("click", reactivateAll);
    }
  })();
</script>
