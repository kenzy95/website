---
/**
 * Nav v2 pour comparer les 3 directions Synergie 3 piliers.
 * Logique : ciblage signaux fins x copy contextuel x infra propre.
 */

interface Props {
  current: 'A' | 'B' | 'C';
}
const { current } = Astro.props as Props;

const links = [
  { id: 'A', slug: '/methode-a', label: "A — L'Équation Vivante" },
  { id: 'B', slug: '/methode-b', label: 'B — Diagramme de Forces' },
  { id: 'C', slug: '/methode-c', label: 'C — Mixing Desk' },
];
---

<nav class="preview-nav-v2">
  <div class="preview-nav-v2__inner">
    <span class="preview-nav-v2__eyebrow">Preview — Synergie 3 piliers · Direction {current}/3</span>
    <ul class="preview-nav-v2__list">
      {
        links.map((l) => (
          <li>
            <a
              href={l.slug}
              class={`preview-nav-v2__link ${l.id === current ? 'is-active' : ''}`}
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  .preview-nav-v2 {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-encre);
    border-bottom: 1px solid rgba(250, 247, 242, 0.08);
    backdrop-filter: blur(8px);
  }
  .preview-nav-v2__inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  @media (min-width: 768px) {
    .preview-nav-v2__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
    }
  }
  .preview-nav-v2__eyebrow {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: rgba(250, 247, 242, 0.55);
    font-weight: 600;
  }
  .preview-nav-v2__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .preview-nav-v2__link {
    display: inline-block;
    padding: 0.4rem 0.85rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: rgba(250, 247, 242, 0.7);
    background: rgba(250, 247, 242, 0.06);
    border-radius: 999px;
    text-decoration: none;
    transition: all 0.18s ease;
  }
  .preview-nav-v2__link:hover {
    color: var(--color-creme);
    background: rgba(250, 247, 242, 0.12);
  }
  .preview-nav-v2__link.is-active {
    color: var(--color-encre);
    background: var(--color-bleu);
  }
</style>
