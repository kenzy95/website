---
// Direction A : L'Équation Vivante
// Démonstration interactive : Ciblage × Copy × Infra = RDV qualifiés
// Toggle des 3 piliers, compteur de taux de réponse simulé qui réagit.
---

<section class="equation-section" aria-labelledby="equation-title">
  <div class="equation-section__inner">
    <header class="equation-section__header">
      <p class="eyebrow">MÉTHODE</p>
      <p class="sub-eyebrow" id="equation-title">La méthode Agence Simple.</p>
    </header>

    <!-- L'équation centrale, vedette de la section -->
    <div class="equation" role="group" aria-label="Équation interactive de la méthode">
      <button
        class="equation__pill is-active"
        data-pilier="ciblage"
        role="switch"
        aria-pressed="true"
        aria-label="Activer ou désactiver le pilier Ciblage"
      >
        <span class="equation__dot" data-color="bleu"></span>
        <span class="equation__word">Ciblage</span>
      </button>
      <span class="equation__op" aria-hidden="true">×</span>
      <button
        class="equation__pill is-active"
        data-pilier="copy"
        role="switch"
        aria-pressed="true"
        aria-label="Activer ou désactiver le pilier Copy"
      >
        <span class="equation__dot" data-color="orange"></span>
        <span class="equation__word">Copy</span>
      </button>
      <span class="equation__op" aria-hidden="true">×</span>
      <button
        class="equation__pill is-active"
        data-pilier="infra"
        role="switch"
        aria-pressed="true"
        aria-label="Activer ou désactiver le pilier Infra"
      >
        <span class="equation__dot" data-color="encre"></span>
        <span class="equation__word">Infra</span>
      </button>
      <span class="equation__op equation__op--equals" aria-hidden="true">=</span>
      <span class="equation__result">
        <span class="equation__word equation__word--italic">RDV qualifiés</span>
      </span>
    </div>

    <!-- Les 3 cartes piliers, chacune avec son switch ON/OFF -->
    <div class="piliers">
      <!-- Pilier 01, Ciblage -->
      <article class="pilier is-active" data-pilier-card="ciblage">
        <header class="pilier__head">
          <span class="pilier__dot" data-color="bleu"></span>
          <span class="pilier__num">01</span>
        </header>
        <h3 class="pilier__title">CIBLAGE</h3>
        <p class="pilier__subtitle">Signaux fins</p>
        <p class="pilier__desc">
          On part de signaux d'achat précis (levée de fonds, ouverture de poste sales, sortie produit). Au bon moment, sur un vrai besoin.
        </p>
        <div class="pilier__switch-row">
          <button
            class="switch is-on"
            data-switch="ciblage"
            role="switch"
            aria-pressed="true"
            aria-label="Activer ou désactiver Ciblage"
          >
            <span class="switch__track">
              <span class="switch__thumb"></span>
            </span>
            <span class="switch__label">Activé</span>
          </button>
        </div>
      </article>

      <!-- Pilier 02, Copy -->
      <article class="pilier is-active" data-pilier-card="copy">
        <header class="pilier__head">
          <span class="pilier__dot" data-color="orange"></span>
          <span class="pilier__num">02</span>
        </header>
        <h3 class="pilier__title">COPY</h3>
        <p class="pilier__subtitle">Contexte naturel</p>
        <p class="pilier__desc">
          Phrase d'ouverture qui prouve qu'on a fait nos devoirs. Vouvoiement court, ton humain, zéro jargon outbound.
        </p>
        <div class="pilier__switch-row">
          <button
            class="switch is-on"
            data-switch="copy"
            role="switch"
            aria-pressed="true"
            aria-label="Activer ou désactiver Copy"
          >
            <span class="switch__track">
              <span class="switch__thumb"></span>
            </span>
            <span class="switch__label">Activé</span>
          </button>
        </div>
      </article>

      <!-- Pilier 03, Infra -->
      <article class="pilier is-active" data-pilier-card="infra">
        <header class="pilier__head">
          <span class="pilier__dot" data-color="encre"></span>
          <span class="pilier__num">03</span>
        </header>
        <h3 class="pilier__title">INFRA</h3>
        <p class="pilier__subtitle">Délivrabilité propre</p>
        <p class="pilier__desc">
          Domaines secondaires dédiés, warmup, monitoring continu. On atterrit dans l'inbox, pas dans les promotions.
        </p>
        <div class="pilier__switch-row">
          <button
            class="switch is-on"
            data-switch="infra"
            role="switch"
            aria-pressed="true"
            aria-label="Activer ou désactiver Infra"
          >
            <span class="switch__track">
              <span class="switch__thumb"></span>
            </span>
            <span class="switch__label">Activé</span>
          </button>
        </div>
      </article>
    </div>

    <!-- Bloc résultat, mis à jour dynamiquement -->
    <div class="result" aria-live="polite">
      <div class="result__label">Taux de réponse simulé</div>
      <div class="result__value" data-result-value>9,4 %</div>
      <p class="result__explanation" data-result-explanation>
        Système complet. Pourcentages réalistes sur nos campagnes 2026.
      </p>
    </div>
  </div>
</section>

<style>
  .equation-section {
    min-height: 100vh;
    background: var(--color-creme);
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 4rem);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    color: var(--color-encre);
  }

  .equation-section__inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 5vw, 4rem);
  }

  .equation-section__header {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-orange);
    margin: 0;
  }

  .sub-eyebrow {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: color-mix(in srgb, var(--color-encre) 60%, transparent);
    margin: 0;
  }

  /* Équation centrale */
  .equation {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: clamp(0.5rem, 1.5vw, 1.25rem);
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    line-height: 1.1;
    text-align: center;
  }

  .equation__pill {
    appearance: none;
    background: transparent;
    border: none;
    padding: 0.25rem 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font: inherit;
    color: var(--color-encre);
    border-radius: 0.5rem;
    transition: opacity 0.4s ease, color 0.4s ease, transform 0.2s ease;
  }

  .equation__pill:hover {
    transform: translateY(-2px);
  }

  .equation__pill:focus-visible {
    outline: 2px solid var(--color-bleu);
    outline-offset: 4px;
  }

  .equation__dot {
    width: 0.7em;
    height: 0.7em;
    border-radius: 50%;
    display: inline-block;
    transition: background 0.4s ease;
  }

  .equation__dot[data-color="bleu"] { background: var(--color-bleu); }
  .equation__dot[data-color="orange"] { background: var(--color-orange); }
  .equation__dot[data-color="encre"] { background: var(--color-encre); }

  .equation__word {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
  }

  .equation__op {
    font-family: var(--font-sans);
    font-weight: 300;
    color: color-mix(in srgb, var(--color-encre) 50%, transparent);
  }

  .equation__op--equals {
    margin: 0 0.25rem;
  }

  .equation__result .equation__word--italic {
    text-decoration: underline;
    text-decoration-color: var(--color-orange);
    text-decoration-thickness: 4px;
    text-underline-offset: 0.15em;
  }

  /* État désactivé sur la pilule équation */
  .equation__pill:not(.is-active) {
    opacity: 0.4;
  }
  .equation__pill:not(.is-active) .equation__word {
    color: var(--color-gris-soft);
    text-decoration: line-through;
    text-decoration-thickness: 3px;
  }
  .equation__pill:not(.is-active) .equation__dot {
    background: var(--color-gris-soft) !important;
  }

  /* Cartes piliers */
  .piliers {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.75rem);
    max-width: 960px;
    margin: 0 auto;
    width: 100%;
  }

  .pilier {
    background: #ffffff;
    border: 1px solid var(--color-gris-light);
    border-radius: 1rem;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 340px;
    transition: opacity 0.4s ease, filter 0.4s ease;
  }

  .pilier:not(.is-active) {
    opacity: 0.35;
    filter: grayscale(0.6);
  }

  .pilier__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .pilier__dot {
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 50%;
    display: inline-block;
  }
  .pilier__dot[data-color="bleu"] { background: var(--color-bleu); }
  .pilier__dot[data-color="orange"] { background: var(--color-orange); }
  .pilier__dot[data-color="encre"] { background: var(--color-encre); }

  .pilier__num {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-gris);
    letter-spacing: 0.05em;
  }

  .pilier__title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.05em;
    margin: 0;
    color: var(--color-encre);
  }

  .pilier__subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--color-orange);
    margin: 0;
  }

  .pilier__desc {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-gris);
    margin: 0;
    flex-grow: 1;
  }

  .pilier__switch-row {
    display: flex;
    align-items: center;
    margin-top: 0.5rem;
  }

  /* Switch ON/OFF */
  .switch {
    appearance: none;
    background: transparent;
    border: none;
    padding: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    cursor: pointer;
    font: inherit;
    color: var(--color-encre);
  }

  .switch:focus-visible {
    outline: 2px solid var(--color-bleu);
    outline-offset: 4px;
    border-radius: 0.5rem;
  }

  .switch__track {
    width: 52px;
    height: 28px;
    border-radius: 999px;
    background: var(--color-gris-light);
    position: relative;
    transition: background 0.3s ease;
    flex-shrink: 0;
  }

  .switch__thumb {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #ffffff;
    box-shadow: 0 1px 3px rgba(15, 27, 63, 0.2);
    transition: left 0.3s ease, background 0.3s ease;
  }

  .switch.is-on .switch__track {
    background: var(--color-encre);
  }

  .switch.is-on .switch__thumb {
    left: 27px;
  }

  .switch__label {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-gris);
  }

  /* Bloc résultat */
  .result {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding-top: 1rem;
  }

  .result__label {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-gris);
  }

  .result__value {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 1;
    color: var(--color-orange);
    font-variant-numeric: tabular-nums;
  }

  .result__explanation {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-gris);
    max-width: 36rem;
    margin: 0;
  }

  /* Responsive tablet */
  @media (max-width: 1023px) {
    .piliers {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .piliers .pilier:nth-child(3) {
      grid-column: 1 / -1;
      max-width: 480px;
      justify-self: center;
    }
  }

  /* Responsive mobile */
  @media (max-width: 767px) {
    .equation {
      font-size: clamp(2rem, 9vw, 3rem);
      gap: 0.4rem;
    }
    .piliers {
      grid-template-columns: 1fr;
    }
    .piliers .pilier:nth-child(3) {
      grid-column: auto;
      max-width: none;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .equation__pill,
    .equation__dot,
    .pilier,
    .switch__thumb,
    .switch__track {
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    const equation = document.querySelector('.equation');
    if (!equation) return;

    // État des 3 piliers
    const state = { ciblage: true, copy: true, infra: true };

    const pills = document.querySelectorAll('.equation__pill');
    const cards = document.querySelectorAll('[data-pilier-card]');
    const switches = document.querySelectorAll('.switch');
    const valueEl = document.querySelector('[data-result-value]');
    const explanationEl = document.querySelector('[data-result-explanation]');

    // Table des résultats selon les combinaisons
    function computeResult() {
      const { ciblage, copy, infra } = state;
      const onCount = [ciblage, copy, infra].filter(Boolean).length;

      if (onCount === 3) {
        return {
          value: 9.4,
          explanation: 'Système complet. Pourcentages réalistes sur nos campagnes 2026.',
        };
      }
      if (onCount === 2) {
        if (!ciblage) {
          return {
            value: 0.3,
            explanation:
              "Vous envoyez à des gens qui n'ont aucun besoin. Vous payez votre infra pour parler dans le vide.",
          };
        }
        if (!copy) {
          return {
            value: 0.8,
            explanation: "Le message ressemble à un template. Supprimé au mot 'opportunité'.",
          };
        }
        if (!infra) {
          return {
            value: 0.0,
            explanation: "Le message n'arrive jamais. Tout en spam ou en promotions.",
          };
        }
      }
      if (onCount === 1) {
        return {
          value: 0.0,
          explanation: 'Le système ne tient pas debout.',
        };
      }
      return {
        value: 0.0,
        explanation: 'Il faut au moins une force pour démarrer. Idéalement les trois.',
      };
    }

    // Formatte en français avec virgule décimale
    function formatValue(n) {
      return n.toLocaleString('fr-FR', {
        minimumFractionDigits: 1,
        maximumFractionDigits: 1,
      }) + ' %';
    }

    // Anime le compteur d'une valeur à l'autre
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let currentValue = 9.4;
    let animFrame = null;

    function animateTo(target) {
      if (animFrame) cancelAnimationFrame(animFrame);

      if (reduceMotion) {
        currentValue = target;
        valueEl.textContent = formatValue(target);
        return;
      }

      const start = currentValue;
      const delta = target - start;
      const duration = 600;
      const t0 = performance.now();

      function step(now) {
        const t = Math.min(1, (now - t0) / duration);
        // ease-out cubic
        const eased = 1 - Math.pow(1 - t, 3);
        const v = start + delta * eased;
        currentValue = v;
        valueEl.textContent = formatValue(v);
        if (t < 1) {
          animFrame = requestAnimationFrame(step);
        } else {
          currentValue = target;
          valueEl.textContent = formatValue(target);
        }
      }

      animFrame = requestAnimationFrame(step);
    }

    // Met à jour visuellement les éléments selon l'état
    function syncDom() {
      pills.forEach((pill) => {
        const key = pill.getAttribute('data-pilier');
        const on = state[key];
        pill.classList.toggle('is-active', on);
        pill.setAttribute('aria-pressed', on ? 'true' : 'false');
      });

      cards.forEach((card) => {
        const key = card.getAttribute('data-pilier-card');
        const on = state[key];
        card.classList.toggle('is-active', on);
      });

      switches.forEach((sw) => {
        const key = sw.getAttribute('data-switch');
        const on = state[key];
        sw.classList.toggle('is-on', on);
        sw.setAttribute('aria-pressed', on ? 'true' : 'false');
        const label = sw.querySelector('.switch__label');
        if (label) label.textContent = on ? 'Activé' : 'Désactivé';
      });

      const { value, explanation } = computeResult();
      animateTo(value);
      if (explanationEl) explanationEl.textContent = explanation;
    }

    // Toggle générique
    function toggle(key) {
      state[key] = !state[key];
      syncDom();
    }

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const key = pill.getAttribute('data-pilier');
        if (key) toggle(key);
      });
    });

    switches.forEach((sw) => {
      sw.addEventListener('click', () => {
        const key = sw.getAttribute('data-switch');
        if (key) toggle(key);
      });
    });
  })();
</script>
