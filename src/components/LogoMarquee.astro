---
/**
 * Marquee infini en CSS pur (zero JS).
 * 10 vrais logos clients reels recuperes du Framer.
 */

interface Logo {
  name: string;
  src: string;
  height?: number;
}

const clients: Logo[] = [
  { name: 'Trimble', src: '/clients/trimble.png', height: 28 },
  { name: 'Yomoni', src: '/clients/yomoni.png', height: 26 },
  { name: 'Solunea', src: '/clients/solunea.png', height: 44 },
  { name: 'Job2bedone partners', src: '/clients/job2bedone.png', height: 34 },
  { name: 'Dunforce', src: '/clients/dunforce.svg', height: 28 },
  { name: 'MOFFI', src: '/clients/moffi.png', height: 30 },
  { name: 'Dr.Rubber', src: '/clients/dr-rubber.png', height: 24 },
  { name: 'Les Épaulettes', src: '/clients/epaulettes.png', height: 32 },
  { name: 'Nestore', src: '/clients/nestore.png', height: 22 },
];

interface Props {
  title?: string;
  duration?: number;
}
const { title = 'Ils nous font confiance', duration = 40 } = Astro.props as Props;

const logos = [...clients, ...clients];
---

<section class="py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-center text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
      {title}
    </p>

    <div class="mt-10 marquee-mask">
      <div class="marquee-track" style={`animation-duration:${duration}s`}>
        {
          logos.map((c, i) => (
            <div class="marquee-item" aria-hidden={i >= clients.length ? 'true' : undefined}>
              <img
                src={c.src}
                alt={`Logo ${c.name}`}
                style={`height:${c.height || 32}px; width:auto;`}
                class="marquee-logo"
                loading="lazy"
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .marquee-mask {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 120px, black calc(100% - 120px), transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 120px, black calc(100% - 120px), transparent);
  }
  .marquee-track {
    display: flex;
    width: max-content;
    gap: 5rem;
    align-items: center;
    animation: marquee-scroll linear infinite;
    will-change: transform;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
  .marquee-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 140px;
    height: 56px;
  }
  /* Convertit les logos colores en blanc/creme sur fond dark, conserve l'opacite */
  .marquee-logo {
    filter: brightness(0) invert(0.95);
    opacity: 0.75;
    transition: opacity 200ms ease;
    max-width: 180px;
    object-fit: contain;
  }
  .marquee-item:hover .marquee-logo {
    opacity: 1;
  }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
