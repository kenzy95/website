---
import { BlurredInfiniteSlider } from './animations/InfiniteSlider';

/**
 * Logos clients reels d'Agence Simple - via Clearbit Logo API (URLs publiques stables).
 * Pour les clients sans domaine public clair, fallback en wordmark texte.
 */
interface Logo {
  name: string;
  domain?: string;
}

const clients: Logo[] = [
  { name: 'Trimble', domain: 'trimble.com' },
  { name: 'Yomoni', domain: 'yomoni.fr' },
  { name: 'Solunea', domain: 'solunea.fr' },
  { name: 'Job2bedone' },
  { name: 'Dunforce', domain: 'dunforce.com' },
  { name: 'Happycolis' },
  { name: 'Invent-App' },
  { name: 'Wedoit' },
];

interface Props {
  title?: string;
  speed?: number;
}

const { title = 'Ils nous font confiance', speed = 60 } = Astro.props as Props;
---

<section class="py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-center text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
      {title}
    </p>
    <div class="mt-10">
      <BlurredInfiniteSlider client:load speed={speed} speedOnHover={20} gap={64} fadeWidth={120}>
        {
          clients.map((c) => (
            <div class="flex items-center justify-center min-w-[140px] h-14">
              {c.domain ? (
                <img
                  src={`https://logo.clearbit.com/${c.domain}?size=120`}
                  alt={`Logo ${c.name}`}
                  class="h-9 w-auto opacity-70 hover:opacity-100 transition-opacity"
                  style="filter: brightness(0) invert(0.92);"
                  loading="lazy"
                  width="120"
                  height="36"
                />
              ) : (
                <span
                  class="text-(--color-creme)/70 hover:text-(--color-creme) transition-colors whitespace-nowrap"
                  style="font-family: var(--font-display); font-weight: 600; font-size: 1.5rem; letter-spacing: -0.02em;"
                >
                  {c.name}
                </span>
              )}
            </div>
          ))
        }
      </BlurredInfiniteSlider>
    </div>
  </div>
</section>
