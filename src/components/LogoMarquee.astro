---
/**
 * Marquee infini en CSS pur (zero JS).
 * 10 vrais logos clients reels recuperes du Framer.
 */

interface Logo {
  name: string;
  src: string;
  height?: number;
}

const clients: Logo[] = [
  { name: 'Trimble', src: '/clients/trimble.png', height: 44 },
  { name: 'Yomoni', src: '/clients/yomoni.png', height: 40 },
  { name: 'Solunea', src: '/clients/solunea.png', height: 64 },
  { name: 'Job2bedone partners', src: '/clients/job2bedone.png', height: 52 },
  { name: 'Dunforce', src: '/clients/dunforce.svg', height: 44 },
  { name: 'MOFFI', src: '/clients/moffi.png', height: 46 },
  { name: 'Dr.Rubber', src: '/clients/dr-rubber.png', height: 38 },
  { name: 'Les Épaulettes', src: '/clients/epaulettes.png', height: 48 },
  { name: 'Nestore', src: '/clients/nestore.png', height: 36 },
];

interface Props {
  title?: string;
  duration?: number;
}
const { title = 'Ils nous font confiance', duration = 40 } = Astro.props as Props;

const logos = [...clients, ...clients];
---

<section class="logo-marquee-section">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-center text-xs font-semibold uppercase tracking-[0.2em] logo-marquee-title">
      {title}
    </p>

    <div class="mt-8 marquee-mask">
      <div class="marquee-track" style={`animation-duration:${duration}s`}>
        {
          logos.map((c, i) => (
            <div class="marquee-item" aria-hidden={i >= clients.length ? 'true' : undefined}>
              <img
                src={c.src}
                alt={`Logo ${c.name}`}
                style={`height:${c.height || 44}px; width:auto;`}
                class="marquee-logo"
                loading="lazy"
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* Section : fond creme + radius top pour transition propre depuis le dark dessus */
  .logo-marquee-section {
    background: var(--color-creme);
    padding: 3rem 0 2.5rem;
    border-radius: 32px 32px 0 0;
    position: relative;
    z-index: 5;
  }
  @media (min-width: 768px) {
    .logo-marquee-section {
      padding: 3.5rem 0 3rem;
    }
  }

  .logo-marquee-title {
    color: var(--color-encre);
    opacity: 0.55;
  }

  .marquee-mask {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 120px, black calc(100% - 120px), transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 120px, black calc(100% - 120px), transparent);
  }
  .marquee-track {
    display: flex;
    width: max-content;
    gap: 5rem;
    align-items: center;
    animation: marquee-scroll linear infinite;
    will-change: transform;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
  .marquee-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 160px;
    height: 72px;
  }
  /* Logos en couleurs naturelles sur fond creme, legere desaturation pour cohesion */
  .marquee-logo {
    opacity: 0.85;
    filter: grayscale(20%);
    transition: opacity 200ms ease, filter 200ms ease;
    max-width: 220px;
    object-fit: contain;
  }
  .marquee-item:hover .marquee-logo {
    opacity: 1;
    filter: grayscale(0%);
  }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
