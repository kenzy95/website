---
/**
 * Marquee infini en CSS pur (zero JS, perf maximale).
 * Children dupliques 2x dans le DOM pour boucle seamless.
 * Mask gradient pour fade gauche/droite.
 * Hover pause via animation-play-state.
 */

interface Logo {
  name: string;
  domain?: string;
}

const clients: Logo[] = [
  { name: 'Trimble', domain: 'trimble.com' },
  { name: 'Yomoni', domain: 'yomoni.fr' },
  { name: 'Solunea', domain: 'solunea.fr' },
  { name: 'Job2bedone' },
  { name: 'Dunforce', domain: 'dunforce.com' },
  { name: 'Happycolis' },
  { name: 'Invent-App' },
  { name: 'Wedoit' },
];

interface Props {
  title?: string;
  duration?: number;
}
const { title = 'Ils nous font confiance', duration = 35 } = Astro.props as Props;

// Children duplique 2x pour boucle infinie
const logos = [...clients, ...clients];
---

<section class="py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-center text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
      {title}
    </p>

    <div class="mt-10 marquee-mask">
      <div class="marquee-track" style={`animation-duration:${duration}s`}>
        {
          logos.map((c, i) => (
            <div class="marquee-item" aria-hidden={i >= clients.length ? 'true' : undefined}>
              {c.domain ? (
                <img
                  src={`https://logo.clearbit.com/${c.domain}?size=120`}
                  alt={`Logo ${c.name}`}
                  class="h-9 w-auto opacity-75 hover:opacity-100 transition-opacity"
                  style="filter: brightness(0) invert(0.92);"
                  loading="lazy"
                  width="120"
                  height="36"
                />
              ) : (
                <span
                  class="text-(--color-creme)/75 hover:text-(--color-creme) transition-colors whitespace-nowrap"
                  style="font-family: var(--font-display); font-weight: 600; font-size: 1.5rem; letter-spacing: -0.02em;"
                >
                  {c.name}
                </span>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .marquee-mask {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 120px, black calc(100% - 120px), transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 120px, black calc(100% - 120px), transparent);
  }
  .marquee-track {
    display: flex;
    width: max-content;
    gap: 4rem;
    animation: marquee-scroll linear infinite;
    will-change: transform;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
  .marquee-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 140px;
    height: 56px;
  }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
