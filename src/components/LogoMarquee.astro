---
/**
 * Marquee infini en CSS pur (zero JS).
 * 10 vrais logos clients reels recuperes du Framer.
 */

interface Logo {
  name: string;
  src: string;
  height?: number;
}

const clients: Logo[] = [
  { name: 'Trimble', src: '/clients/trimble.png', height: 64 },
  { name: 'Yomoni', src: '/clients/yomoni.png', height: 58 },
  { name: 'Solunea', src: '/clients/solunea.png', height: 90 },
  { name: 'Job2bedone partners', src: '/clients/job2bedone.png', height: 76 },
  { name: 'Dunforce', src: '/clients/dunforce.svg', height: 64 },
  { name: 'MOFFI', src: '/clients/moffi.png', height: 68 },
  { name: 'Dr.Rubber', src: '/clients/dr-rubber.png', height: 56 },
  { name: 'Les Épaulettes', src: '/clients/epaulettes.png', height: 70 },
  { name: 'Nestore', src: '/clients/nestore.png', height: 52 },
];

interface Props {
  title?: string;
  duration?: number;
}
const { title = 'Ils nous font confiance', duration = 40 } = Astro.props as Props;

const logos = [...clients, ...clients];
---

<section class="logo-marquee-section">
  <p class="logo-marquee-eyebrow">{title}</p>

  <div class="logo-marquee-card">
    <div class="marquee-mask">
      <div class="marquee-track" style={`animation-duration:${duration}s`}>
        {
          logos.map((c, i) => (
            <div class="marquee-item" aria-hidden={i >= clients.length ? 'true' : undefined}>
              <img
                src={c.src}
                alt={`Logo ${c.name}`}
                style={`height:${c.height || 64}px; width:auto;`}
                class="marquee-logo"
                loading="lazy"
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* Section : conteneur dark, garde l'eyebrow + card blanche centree (pattern agencesimple.fr Framer) */
  .logo-marquee-section {
    padding: 3rem 1.5rem 3.5rem;
    position: relative;
    z-index: 5;
  }
  @media (min-width: 768px) {
    .logo-marquee-section { padding: 3.5rem 2rem 4rem; }
  }

  .logo-marquee-eyebrow {
    text-align: center;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-creme);
    opacity: 0.55;
    margin-bottom: 2rem;
  }

  /* Card blanche centree, max 1200px, border-radius pill (match Framer 70px) */
  .logo-marquee-card {
    max-width: 1200px;
    margin: 0 auto;
    background: #FFFFFF;
    border-radius: 70px;
    padding: 2.5rem 0;
    overflow: hidden;
  }
  @media (max-width: 640px) {
    .logo-marquee-card {
      border-radius: 32px;
      padding: 2rem 0;
    }
  }

  .marquee-mask {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 80px, black calc(100% - 80px), transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 80px, black calc(100% - 80px), transparent);
  }
  .marquee-track {
    display: flex;
    width: max-content;
    gap: 5rem;
    align-items: center;
    animation: marquee-scroll linear infinite;
    will-change: transform;
  }
  .marquee-track:hover { animation-play-state: paused; }

  .marquee-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 200px;
    height: 110px;
  }
  /* Logos en couleurs naturelles sur fond blanc, legere desaturation pour cohesion */
  .marquee-logo {
    opacity: 0.85;
    filter: grayscale(20%);
    transition: opacity 200ms ease, filter 200ms ease;
    max-width: 260px;
    object-fit: contain;
  }
  .marquee-item:hover .marquee-logo {
    opacity: 1;
    filter: grayscale(0%);
  }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
