---
/**
 * Dashboard mail "Meeting Point" - vraie image du Framer.
 * Utilisee dans le ContainerScroll du hero.
 */
---

<img
  src="/images/hero-dashboard.svg"
  alt="Boîte de réception Meeting Point - email de Pierre Lachance"
  class="hero-dashboard-img"
  loading="eager"
  fetchpriority="high"
/>

<style>
  .hero-dashboard-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top left;
    border-radius: 16px;
  }
  @media (min-width: 768px) {
    .hero-dashboard-img { border-radius: 20px; }
  }
</style>
