---
/**
 * Background animé du hero.
 *
 * 3 couches superposees :
 * 1. Grille subtile (encre lines opacity 6%) avec mask radial pour fade vers les bords
 * 2. Aurora animee : gradient lineaire bleu/orange/violet qui defile en boucle 20s
 *    + 2nd layer avec mix-blend-mode difference pour texture supplementaire
 * 3. Vignette radiale : assombrit les bords pour focus sur le centre
 *
 * Inspire 21st.dev (AuroraHero) + hero-1 (grid). Adapte palette charte v2 :
 * bleu signature #1E90FF, orange chaleur #F47B3F, violet decoratif #764CDC.
 *
 * Pas de framer-motion : CSS pur via @keyframes background-position.
 */
---

<div class="hero-bg" aria-hidden="true">
  <!-- Couche 1 : Grille subtile -->
  <div class="hero-bg__grid"></div>

  <!-- Couche 2 : Aurora animee (gradient defilant) -->
  <div class="hero-bg__aurora-1"></div>
  <div class="hero-bg__aurora-2"></div>

  <!-- Couche 3 : Vignette radiale (assombrit les bords) -->
  <div class="hero-bg__vignette"></div>
</div>

<style>
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  /* === GRILLE === */
  .hero-bg__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 5rem 5rem;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, #000 50%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, #000 50%, transparent 100%);
  }

  /* === AURORA === */
  .hero-bg__aurora-1 {
    position: absolute;
    inset: -50%;
    background:
      repeating-linear-gradient(
        110deg,
        rgba(30, 144, 255, 0.5) 0%,
        rgba(118, 76, 220, 0.4) 12%,
        rgba(244, 123, 63, 0.45) 24%,
        rgba(30, 144, 255, 0.5) 36%
      );
    background-size: 200% 100%;
    filter: blur(80px);
    opacity: 0.35;
    animation: aurora-shift 24s linear infinite;
  }

  .hero-bg__aurora-2 {
    position: absolute;
    inset: -30%;
    background:
      radial-gradient(circle at 20% 30%, rgba(244, 123, 63, 0.35), transparent 40%),
      radial-gradient(circle at 80% 70%, rgba(30, 144, 255, 0.4), transparent 45%),
      radial-gradient(circle at 60% 20%, rgba(118, 76, 220, 0.3), transparent 40%);
    filter: blur(40px);
    opacity: 0.7;
    animation: aurora-drift 18s ease-in-out infinite alternate;
  }

  /* === VIGNETTE === */
  .hero-bg__vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 100% 80% at 50% 50%,
      transparent 30%,
      rgba(15, 27, 63, 0.4) 70%,
      rgba(15, 27, 63, 0.85) 100%
    );
  }

  /* === KEYFRAMES === */
  @keyframes aurora-shift {
    0% { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
  }
  @keyframes aurora-drift {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(3%, -2%) scale(1.05); }
    100% { transform: translate(-2%, 3%) scale(0.98); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg__aurora-1,
    .hero-bg__aurora-2 {
      animation: none;
    }
  }
</style>
