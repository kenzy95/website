---
/**
 * Card "Partenaire WILCO" - inspiree du Framer actuel (card violette flottante).
 * Centree sous le marquee logos, badge avec gradient pour rappeler le visuel
 * d'origine sans tomber dans le gradient 2022 saturé.
 */
---

<section class="py-10">
  <div class="mx-auto max-w-6xl px-6 flex justify-center">
    <div class="wilco-card">
      <span class="wilco-card__eyebrow">Partenaire officiel</span>
      <span class="wilco-card__name">WILCO</span>
    </div>
  </div>
</section>

<style>
  .wilco-card {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
    padding: 1rem 1.6rem;
    border-radius: 18px;
    overflow: hidden;
    isolation: isolate;
    background:
      linear-gradient(135deg, rgba(118, 76, 220, 0.95), rgba(30, 144, 255, 0.95));
    box-shadow:
      0 10px 30px -10px rgba(118, 76, 220, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.08) inset;
  }
  .wilco-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at top right, rgba(244, 123, 63, 0.35), transparent 60%),
      radial-gradient(ellipse at bottom left, rgba(255, 255, 255, 0.15), transparent 55%);
    pointer-events: none;
    z-index: 0;
  }
  .wilco-card__eyebrow {
    position: relative;
    z-index: 1;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.85);
  }
  .wilco-card__name {
    position: relative;
    z-index: 1;
    font-family: var(--font-logo);
    font-weight: 800;
    font-size: 1.625rem;
    letter-spacing: 0.05em;
    color: #FFFFFF;
  }
</style>
