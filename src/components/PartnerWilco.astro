---
/**
 * Card "Partenaire WILCO" - utilise le vrai badge Wilco du Framer.
 * Centree sous le marquee logos.
 */
---

<section class="py-10">
  <div class="mx-auto max-w-6xl px-6 flex justify-center">
    <div class="wilco-card" role="img" aria-label="Partenaire officiel Wilco">
      <img src="/clients/wilco-partner.png" alt="" class="wilco-card__img" loading="lazy" />
      <span class="wilco-card__label">Partenaire officiel</span>
    </div>
  </div>
</section>

<style>
  .wilco-card {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    align-items: stretch;
    padding: 0.85rem 1rem;
    border-radius: 20px;
    overflow: hidden;
    isolation: isolate;
    background: rgba(250, 247, 242, 0.04);
    border: 1px solid rgba(250, 247, 242, 0.1);
    backdrop-filter: blur(8px);
    box-shadow:
      0 12px 30px -12px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.06) inset;
  }
  .wilco-card__img {
    width: auto;
    height: 56px;
    border-radius: 10px;
    display: block;
  }
  .wilco-card__label {
    margin-top: 0.6rem;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(250, 247, 242, 0.7);
  }
</style>
