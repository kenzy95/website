---
/**
 * Card "Partenaire WILCO" - vraie banniere SVG du Framer.
 * Le SVG d'origine fait 648x560 avec gradients pink/orange/yellow.
 * Le label "Partenaire" est ajoute en overlay top-left.
 */
---

<section class="wilco-section">
  <div class="mx-auto max-w-6xl px-6 flex justify-center">
    <a
      href="https://www.wilco.community"
      target="_blank"
      rel="noopener noreferrer"
      class="wilco-banner"
      aria-label="Partenaire officiel Wilco - voir Wilco"
    >
      <img
        src="/images/wilco-banner.webp"
        alt=""
        class="wilco-banner__img"
        loading="lazy"
        width="1920"
        height="1080"
      />
      <span class="wilco-banner__label">Partenaire</span>
      <span class="wilco-banner__name">WILCO</span>
    </a>
  </div>
</section>

<style>
  /* Section : negative margin top -> card a cheval sur le bas du dashboard */
  /* Encart reduit, leger chevauchement sur le dashboard au-dessus (Kenzy 2026-07-05) */
  .wilco-section {
    position: relative;
    z-index: 5;
    margin-top: -2.5rem;
    padding-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .wilco-section {
      margin-top: -3rem;
      padding-bottom: 1.5rem;
    }
  }

  .wilco-banner {
    position: relative;
    display: block;
    width: 100%;
    max-width: 15rem;
    aspect-ratio: 648 / 280;
    border-radius: 24px;
    overflow: hidden;
    isolation: isolate;
    box-shadow:
      0 20px 50px -20px rgba(118, 76, 220, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.08) inset;
    transition: transform 250ms ease, box-shadow 250ms ease;
  }
  .wilco-banner:hover {
    transform: translateY(-3px);
    box-shadow:
      0 24px 60px -20px rgba(118, 76, 220, 0.65),
      0 0 0 1px rgba(255, 255, 255, 0.12) inset;
  }
  .wilco-banner__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }
  .wilco-banner__label {
    position: absolute;
    top: 1.1rem;
    left: 1.5rem;
    z-index: 2;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    color: rgba(250, 247, 242, 0.95);
    letter-spacing: -0.01em;
  }
  .wilco-banner__name {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    font-family: var(--font-logo);
    font-weight: 800;
    font-size: clamp(2.5rem, 7vw, 4rem);
    color: #FFFFFF;
    letter-spacing: 0.04em;
    text-shadow:
      0 2px 12px rgba(0, 0, 0, 0.3),
      0 0 30px rgba(255, 255, 255, 0.2);
  }
</style>
