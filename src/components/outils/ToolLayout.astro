---
/**
 * Layout partage des 3 pages calculateurs /outils : hero encre compact + corps
 * creme arrondi (calc + methodologie via slots) + CTA final bande encre.
 * Regle audit I1 : le calculateur ne vise aucune requete en propre, la
 * methodologie transparente le rend citable (LLM) sans concurrencer les articles.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Container from '@components/ui/Container.astro';
import GlassButton from '@components/ui/GlassButton.astro';
import Breadcrumb from '@components/Breadcrumb.astro';

interface Props {
  metaTitle: string;
  metaDescription: string;
  toolName: string;
  h1: string;
  accent: string;
  lead: string;
}
const { metaTitle, metaDescription, toolName, h1, accent, lead } = Astro.props;

const breadcrumb = [
  { name: 'Outils', href: '/outils' },
  { name: toolName },
];
---

<BaseLayout title={metaTitle} description={metaDescription} bodyClass="!bg-[#0F1B3F]">
  <Header slot="header" variant="dark" />

  <div class="bg-[#0F1B3F]">
    <!-- Hero encre compact -->
    <section class="relative overflow-hidden pt-10 pb-14 sm:pb-16">
      <div aria-hidden="true" class="glow-bleu w-[26rem] h-[26rem] -top-16 -right-10 opacity-45"></div>
      <div aria-hidden="true" class="glow-violet w-[28rem] h-[28rem] top-32 -left-28 opacity-40"></div>

      <Container size="default" class="relative z-10">
        <div class="tool-crumb">
          <Breadcrumb items={breadcrumb} />
        </div>
        <p class="tool-eyebrow mt-9">Outil gratuit</p>
        <h1 class="tool-h1">
          {h1}
          <span class="tool-accent">{accent}</span>
        </h1>
        <p class="tool-lead">{lead}</p>
      </Container>
    </section>

    <!-- Corps creme : calculateur + methodologie -->
    <section class="tool-body">
      <Container size="default">
        <slot name="calc" />
        <div class="tool-prose">
          <slot name="methodo" />
        </div>
      </Container>
    </section>

    <!-- CTA final -->
    <section class="relative overflow-hidden py-16 sm:py-20">
      <div aria-hidden="true" class="glow-bleu w-[22rem] h-[22rem] -top-8 left-1/3 opacity-40"></div>
      <Container size="narrow" class="relative z-10 text-center">
        <h2 class="tool-final__h2">Envie de confronter ces chiffres à votre cas réel ?</h2>
        <p class="tool-final__p">
          Le premier échange est un diagnostic gratuit de 30 minutes : on regarde votre cible, votre
          panier moyen et votre cycle de vente, et on vous dit franchement si la prospection sortante
          est un bon canal pour vous.
        </p>
        <div class="mt-8 flex justify-center">
          <GlassButton href="/contact" size="lg" withArrow ariaLabel="Réserver un diagnostic gratuit">
            Réserver un diagnostic gratuit
          </GlassButton>
        </div>
      </Container>
    </section>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .tool-crumb :global(nav) { color: rgba(250, 247, 242, 0.55); }
  .tool-crumb :global(a) { color: rgba(250, 247, 242, 0.7); }
  .tool-crumb :global(a:hover) { color: var(--color-bleu); }

  .tool-eyebrow {
    font-size: var(--text-eyebrow);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-orange);
  }
  .tool-h1 {
    margin-top: 1.15rem;
    max-width: 52rem;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.14;
    letter-spacing: -0.03em;
    color: var(--color-creme);
  }
  .tool-accent {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    color: var(--color-bleu);
  }
  .tool-lead {
    margin-top: 1.4rem;
    max-width: 44rem;
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: rgba(250, 247, 242, 0.8);
  }

  .tool-body {
    position: relative;
    z-index: 5;
    background: var(--color-creme);
    border-radius: 32px 32px 0 0;
    padding: 3.5rem 0 4.5rem;
  }
  @media (min-width: 768px) {
    .tool-body { padding: 4.5rem 0 5rem; }
  }

  .tool-prose {
    max-width: 46rem;
    margin-top: 3.5rem;
  }
  .tool-prose :global(h2) {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    letter-spacing: -0.02em;
    color: var(--color-encre);
    margin-top: 2.75rem;
  }
  .tool-prose :global(h2:first-child) { margin-top: 0; }
  .tool-prose :global(p) {
    margin-top: 1.1rem;
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: rgba(15, 27, 63, 0.82);
  }
  .tool-prose :global(ul) {
    margin-top: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .tool-prose :global(li) {
    position: relative;
    padding-left: 1.6rem;
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: rgba(15, 27, 63, 0.82);
  }
  .tool-prose :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--color-bleu);
  }
  .tool-prose :global(a) {
    color: var(--color-bleu);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(30, 144, 255, 0.35);
  }
  .tool-prose :global(a:hover) {
    text-decoration-color: var(--color-bleu);
  }

  .tool-final__h2 {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    letter-spacing: -0.02em;
    color: var(--color-creme);
  }
  .tool-final__p {
    margin-top: 1.25rem;
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: rgba(250, 247, 242, 0.75);
  }
</style>
