---
/**
 * Card calculateur partagee par les 3 pages /outils.
 * Rendu : sliders (inputs) + outputs reactifs. Le calcul lui-meme est fourni
 * par la page via un <script is:inline> qui ecoute les inputs [data-calc-input]
 * et ecrit dans les [data-calc-out]. Zero framework.
 */

export interface CalcInput {
  id: string;
  label: string;
  min: number;
  max: number;
  step: number;
  value: number;
  unit?: string;
  hint?: string;
}
export interface CalcOutput {
  id: string;
  label: string;
  main?: boolean;
}

interface Props {
  inputs: CalcInput[];
  outputs: CalcOutput[];
}
const { inputs, outputs } = Astro.props;

const fmt = (n: number) => n.toLocaleString('fr-FR');
---

<div class="calc-card" data-calc-card>
  <div class="calc-inputs">
    {inputs.map((inp, i) => (
      <div class="calc-input">
        <div class="calc-input__head">
          <span class="calc-input__num">{i + 1}</span>
          <label for={`calc-${inp.id}`} class="calc-input__label">{inp.label}</label>
        </div>
        <input
          type="range"
          id={`calc-${inp.id}`}
          min={inp.min}
          max={inp.max}
          step={inp.step}
          value={inp.value}
          data-calc-input={inp.id}
        />
        <div class="calc-input__legend">
          <span>{fmt(inp.min)}{inp.unit ?? ''}</span>
          <span class="calc-input__value" data-calc-display={inp.id}>{fmt(inp.value)}{inp.unit ?? ''}</span>
          <span>{fmt(inp.max)}{inp.unit ?? ''}</span>
        </div>
        {inp.hint && <p class="calc-input__hint">{inp.hint}</p>}
      </div>
    ))}
  </div>

  <div class="calc-outputs">
    {outputs.map((out) => (
      <div class:list={['calc-output', out.main && 'calc-output--main']}>
        <p class="calc-output__label">{out.label}</p>
        <p class="calc-output__value" data-calc-out={out.id}>–</p>
      </div>
    ))}
  </div>
</div>

<style>
  .calc-card {
    background: #ffffff;
    border: 1px solid rgba(15, 27, 63, 0.07);
    border-radius: 24px;
    box-shadow: 0 10px 40px -18px rgba(15, 27, 63, 0.2);
    padding: 2rem 1.75rem;
    display: grid;
    gap: 2.25rem;
  }
  @media (min-width: 900px) {
    .calc-card {
      grid-template-columns: 1.4fr 1fr;
      padding: 2.5rem;
    }
  }

  .calc-inputs {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }
  .calc-input__head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .calc-input__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: rgba(30, 144, 255, 0.12);
    color: var(--color-bleu);
    font-size: 0.78rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .calc-input__label {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-encre);
  }
  .calc-input input[type='range'] {
    width: 100%;
    margin-top: 0.7rem;
    accent-color: var(--color-bleu);
    cursor: pointer;
  }
  .calc-input__legend {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 0.3rem;
    font-size: 0.78rem;
    color: rgba(15, 27, 63, 0.45);
  }
  .calc-input__value {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-bleu);
  }
  .calc-input__hint {
    margin-top: 0.35rem;
    font-size: 0.78rem;
    color: rgba(15, 27, 63, 0.5);
  }

  .calc-outputs {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }
  .calc-output {
    padding: 1.1rem 1.3rem;
    border-radius: 16px;
    background: var(--color-creme);
    border: 1px solid rgba(15, 27, 63, 0.06);
  }
  .calc-output__label {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(15, 27, 63, 0.55);
  }
  .calc-output__value {
    margin-top: 0.3rem;
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    color: var(--color-encre);
  }
  .calc-output--main {
    background: var(--color-encre);
  }
  .calc-output--main .calc-output__label {
    color: rgba(250, 247, 242, 0.6);
  }
  .calc-output--main .calc-output__value {
    color: #ffffff;
    font-size: 1.9rem;
  }
  .calc-output--main .calc-output__value {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
  }
</style>
