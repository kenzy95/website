---
/**
 * Section Processus - 4 etapes 01-04 sticky scroll (reprise du Framer).
 * Liste de etapes a gauche, visuel sticky a droite.
 * Pas d'image stock photo (charte v2 bannit) : visuel CSS pur avec mockup process.
 */

const steps = [
  {
    num: '01',
    title: 'Analyse du marché et de vos cibles',
    body: "On commence par un workshop de 60 minutes pour comprendre votre cible et identifier les bons segments de marché. Pas de templates génériques.",
  },
  {
    num: '02',
    title: 'Trouver les contacts de vos prospects',
    body: 'On identifie et collecte les coordonnées des décideurs clés au sein des entreprises ciblées. Sourcing manuel + vérification email.',
  },
  {
    num: '03',
    title: "Création de l'infrastructure email",
    body: "On met en place des systèmes performants pour gérer l'envoi de vos emails. Domaines secondaires dédiés, paramétrage technique, warmup.",
  },
  {
    num: '04',
    title: 'Gestion des campagnes et des réponses',
    body: "On surveille en temps réel les performances des campagnes, en ajustant les stratégies en fonction des taux d'ouverture, de clics et de réponse.",
  },
];
---

<section class="process-section">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-2xl mb-14">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-(--color-orange)">
        Processus
      </p>
      <h2
        class="mt-5 text-(--color-creme) leading-(--leading-title)"
        style="font-family: var(--font-sans); font-weight: 700; font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em;"
      >
        Comment on travaille,<br />étape par étape.
      </h2>
    </div>

    <div class="process-grid">
      <!-- Steps a gauche -->
      <ol class="process-steps">
        {
          steps.map((s) => (
            <li class="process-step">
              <div class="process-step__num-wrap">
                <span class="process-step__num">{s.num}</span>
                <span class="process-step__line" aria-hidden="true"></span>
              </div>
              <div class="process-step__content">
                <h3 class="process-step__title">{s.title}</h3>
                <p class="process-step__body">{s.body}</p>
              </div>
            </li>
          ))
        }
      </ol>

      <!-- Visuel sticky a droite : vraie photo du Framer + overlay caption -->
      <aside class="process-visual">
        <div class="process-visual__sticky">
          <figure class="process-photo">
            <img
              src="/images/process-photo.png"
              alt="Atelier de cadrage avec un client"
              class="process-photo__img"
              loading="lazy"
              width="600"
              height="600"
            />
            <figcaption class="process-photo__caption">
              <span class="process-photo__chip">Atelier de cadrage</span>
              <p class="process-photo__text">
                On commence toujours par un atelier de 60 minutes avec vous, sans slides.
              </p>
            </figcaption>
          </figure>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .process-section {
    padding: 5rem 0 7rem;
  }

  .process-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 1024px) {
    .process-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
  }

  /* === STEPS === */
  .process-steps {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .process-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.5rem;
    align-items: flex-start;
  }
  .process-step__num-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .process-step__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: #1E90FF;
    color: #FFFFFF;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    box-shadow: 0 8px 24px -10px rgba(30, 144, 255, 0.5);
  }
  .process-step__line {
    flex: 1;
    width: 2px;
    background: linear-gradient(to bottom, rgba(30, 144, 255, 0.3), transparent);
    min-height: 2rem;
  }
  .process-step:last-child .process-step__line { display: none; }

  .process-step__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-style: italic;
    font-size: clamp(1.25rem, 2.2vw, 1.625rem);
    line-height: 1.2;
    color: var(--color-creme);
    letter-spacing: -0.01em;
  }
  .process-step__body {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(250, 247, 242, 0.65);
    max-width: 32rem;
  }

  /* === VISUEL : photo du Framer + caption === */
  .process-visual {
    display: none;
  }
  @media (min-width: 1024px) {
    .process-visual { display: block; }
  }
  .process-visual__sticky {
    position: sticky;
    top: 6rem;
  }
  .process-photo {
    position: relative;
    margin: 0;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 20px 50px -20px rgba(0, 0, 0, 0.5);
  }
  .process-photo__img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    aspect-ratio: 1 / 1;
  }
  .process-photo__caption {
    position: absolute;
    left: 1.25rem;
    right: 1.25rem;
    bottom: 1.25rem;
    background: rgba(15, 27, 63, 0.85);
    backdrop-filter: blur(12px);
    border-radius: 16px;
    padding: 1rem 1.25rem;
    color: var(--color-creme);
  }
  .process-photo__chip {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-orange);
    margin-bottom: 0.5rem;
  }
  .process-photo__text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.45;
    color: var(--color-creme);
  }
</style>
