---
/**
 * Lamp Glow - element decoratif au-dessus du titre hero.
 *
 * 2 cones conic-gradient + barre horizontale + halo radial.
 * Taille reduite (h 8rem, max-w 40rem) pour rester discret et ne pas
 * pousser le titre hors du viewport.
 *
 * CSS pur, animation au mount via @keyframes.
 */

interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props as Props;
---

<div class:list={['lamp', className]} aria-hidden="true">
  <div class="lamp__cone lamp__cone--left"></div>
  <div class="lamp__cone lamp__cone--right"></div>
  <div class="lamp__glow"></div>
  <div class="lamp__bar"></div>
</div>

<style>
  .lamp {
    position: relative;
    width: 100%;
    max-width: 40rem;
    height: 8rem;
    margin: 0 auto;
    pointer-events: none;
    isolation: isolate;
  }

  /* Cone gauche : conic-gradient ouvert vers le bas-droit, depuis le haut */
  .lamp__cone {
    position: absolute;
    top: 0;
    bottom: 0;
    overflow: hidden;
    opacity: 0;
    animation: lamp-fade-in 0.9s ease-out 0.1s forwards;
  }

  .lamp__cone--left {
    right: 50%;
    width: 16rem;
    background: conic-gradient(from 70deg at 100% 0%, rgba(30, 144, 255, 0.7), transparent 40%);
    animation:
      lamp-fade-in 0.9s ease-out 0.1s forwards,
      lamp-grow-left 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
  }
  .lamp__cone--right {
    left: 50%;
    width: 16rem;
    background: conic-gradient(from 290deg at 0% 0%, transparent 60%, rgba(30, 144, 255, 0.7));
    animation:
      lamp-fade-in 0.9s ease-out 0.1s forwards,
      lamp-grow-right 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
  }

  /* Halo radial sous la barre (lueur diffuse) */
  .lamp__glow {
    position: absolute;
    top: 0;
    left: 50%;
    width: 22rem;
    height: 6rem;
    transform: translateX(-50%);
    background: radial-gradient(
      ellipse 100% 100% at 50% 0%,
      rgba(30, 144, 255, 0.55),
      rgba(30, 144, 255, 0.18) 40%,
      transparent 70%
    );
    filter: blur(16px);
    opacity: 0;
    animation: lamp-fade-in 1s ease-out 0.3s forwards;
  }

  /* Barre lumineuse horizontale (la tige de la lampe) - au-dessus de tout */
  .lamp__bar {
    position: absolute;
    top: 0;
    left: 50%;
    height: 2px;
    width: 9rem;
    background: linear-gradient(
      to right,
      transparent,
      rgba(30, 144, 255, 0.95) 20%,
      #FFFFFF 50%,
      rgba(30, 144, 255, 0.95) 80%,
      transparent
    );
    transform: translateX(-50%);
    box-shadow:
      0 0 8px rgba(30, 144, 255, 0.95),
      0 0 24px rgba(30, 144, 255, 0.7),
      0 0 48px rgba(30, 144, 255, 0.5);
    z-index: 2;
    animation: lamp-bar-grow 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
    opacity: 0;
  }

  /* Animations */
  @keyframes lamp-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes lamp-grow-left {
    from { width: 8rem; }
    to { width: 16rem; }
  }
  @keyframes lamp-grow-right {
    from { width: 8rem; }
    to { width: 16rem; }
  }
  @keyframes lamp-bar-grow {
    from { width: 4rem; opacity: 0; }
    to { width: 9rem; opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lamp__cone, .lamp__bar, .lamp__glow {
      animation: none;
      opacity: 1;
    }
    .lamp__cone--left, .lamp__cone--right { width: 16rem; }
    .lamp__bar { width: 9rem; }
  }
</style>
